    }

    public function getWidget(string $path): string {
        if(empty($this['values']))
            $this['values'] = $this->loadPromptSettings();
        $files = wire('files');
        $intro = $this->getIntro();
        $placeholder = $this->getPlaceholder();
        $submitText = $this->getButtonText();
        $resetText = $this->getResetText();
        $thinkingText = $this->getThinkingText();
        $disclaimerText = $this->getDisclaimerText();
        $footerText = $this->getFooterText();
        $widgetFile =  $files->render($path, [
            'intro' => $intro,
            'placeholder'=>$placeholder,
            'button_text'=>$submitText,
            'reset_text'=>$resetText,
            'thinking_text'=>$thinkingText,
            'disclaimer_text'=>$disclaimerText,
            'footer_text'=>$footerText
        ]);
        return $widgetFile;
    }


    public function isBlacklistTerm($message): bool
    {
        $sanitizer = $this->wire('sanitizer');
        $cfg       = $this->chatai->promptService()->loadPromptSettings();

        if (empty($cfg['use_blacklist']) || empty($cfg['blacklist'])) {
            return false;
        }

        $msg = mb_strtolower($sanitizer->text($message));
        if ($msg === '') return false;

        $terms = array_filter(array_map('trim', explode(',', $cfg['blacklist'])));

        foreach ($terms as $t) {
            $t = mb_strtolower($sanitizer->text($t));

            // Convert "hang myself" → "hang\s+myself"
            $pattern = '/\b' . preg_quote(str_replace(' ', '___SPACE___', $t), '/') . '\b/iu';
            $pattern = str_replace('___SPACE___', '\s+', $pattern);

            if (preg_match($pattern, $msg)) {
                $this->wire('log')->save(
                    'chatai-blacklist-debug',
                    "Matched phrase '{$t}' in message: '{$msg}'"
                );
                return true;
            }
        }

        return false;
    }


    // Dashboard features

    /** Path to backfill log */
    protected function backfillLogPath(): string {
        $config = $this->wire('config');
        $dir = $config->paths->logs . 'chatai';
        if (!is_dir($dir)) @mkdir($dir, $config->chmodDir, true);
        return $dir . '/chatai_backfill.txt';
    }

    /** Append a JSON line to the backfill log */
    protected function backfillLog(array $row): void {
        $row['t'] = date('c');
        $logPath = $this->backfillLogPath();
        @file_put_contents($logPath, json_encode($row) . PHP_EOL, FILE_APPEND);
    }


    /**
     * Run Backfill & Reconcile across the site.
     * - $dryRun: don't write vectors, only report
     * - $chunk: batch size for memory/time safety
     * Returns a summary array with counts.
     */
    protected function runBackfillReconcile(bool $dryRun = false, $selector = '') : array {
        $pages = $this->wire('pages');
        $cfg   = $this->loadPromptSettings();
        $rag   = new RAG();
        $config = $this->wire('config');

       // $guest = $this->wire('users')->getGuestUser();
        //$http404 = $config->http404PageID;

        $summary = [
            'eligible_total' => 0,
            'ineligible_total' => 0,
            'indexed_new' => 0,
            'indexed_replaced' => 0,
            'deleted' => 0,
            'errors' => 0,
            'dry_run' => $dryRun,
 //           'chunk' => $cfg['rag_batch_size'],
            'model' => $this->chatai->model ?? '',
        ];

        // Broad candidate scan — you may narrow by templates/parents in RAG::shouldIndexPage
        //$selector = "has_parent!=2, status!=trash, id!=$http404, template!=http404, include=hidden";
        $total = $pages->count($selector);
        $offset = 0;

        while ($offset < $total) {
            //foreach ($pages->find("$selector, start=$offset, limit=$chunk") as $page) {
            foreach ($pages->find($selector) as $page) {
                try {
                    // Decide eligibility (same as saveReady)
                    $eligible = $this->chatai->validTemplate($page, $cfg);
                    $inDb     = $rag->shouldReindex($page);

                    if ($eligible) $summary['eligible_total']++; else $summary['ineligible_total']++;

                    if (!$eligible) {
                        if ($inDb && $page->isTrash()) {
                            if (!$dryRun) $rag->deletePageVectors($page);
                            $summary['deleted']++;
                            $this->backfillLog(['ev'=>'delete', 'id'=>$page->id, 'url'=>$page->url]);
                        }

                        if($page->id === $config->http404PageID) {
                            $this->backfillLog(['ev'=>'warn_excluded', 'id'=>$page->id, 'reason'=>'id denylist']);
                        }
                        continue;
                    }

                    // Eligible
                    if (!$inDb) {
                        if (!$dryRun) $rag->collectPageText($page, $cfg);
                        $summary['indexed_new']++;
                        $this->backfillLog(['ev'=>'index_new', 'id'=>$page->id, 'url'=>$page->url]);
                        continue;
                    } else {
                        // Already in DB
                        if (!$dryRun) {
                            $rag->deletePageVectors($page);
                            $rag->collectPageText($page, $cfg);
                            $this->backfillLog(['ev' => 'index_upd', 'id' => $page->id, 'url' => $page->url]);
                        }
                        $summary['indexed_replaced']++;
                        continue;
                    }

                } catch (\Throwable $e) {
                    $summary['errors']++;
                    $this->backfillLog(['ev'=>'error', 'id'=>$page->id ?? 0, 'msg'=>$e->getMessage()]);
                }
            }
            //$offset += $chunk;
            $offset += 200;
        }

        $this->backfillLog(['ev'=>'summary'] + $summary);
        return $summary;
    }

    public function actionReindexAll($selector, int $langId = 0 ) : void {

        $indexer = new \ProcessWire\ChatAIIndexer();
        $indexer->setWire($this->wire());
        $cfg = $this->loadPromptSettings();


        //$pages = $this->wire('pages')->findMany('has_parent!=2, include=visible, template!=admin');
        //$pages = $this->wire('pages')->findMany('has_parent!=2, template!=admin');
        $pages = $this->wire('pages')->findMany($selector);

        $languages = $this->wire('languages');
        $langIds = ($languages && $languages->count())
            ? array_map(fn($l) => (int)$l->id, iterator_to_array($languages))
            : [ (int)$langId ];

        foreach($pages as $p) {
            foreach($langIds as $lid) $indexer->buildForPage($p, $lid);
        }
        $next = $indexer->bumpIndexVersion();

        $cfg['index_version'] = $next;
        //$this->savePromptSettingsJson(json_encode($cfg));
        $this->chatai->promptService()->savePromptSettings($cfg);
        $this->_promptMemo = $cfg;
        $this->message('Reindex complete.');
    }


}
