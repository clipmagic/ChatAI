class ProcessChatAI extends Process
{

    public $tabs = [];

    public $values = [];

    public $formName = 'chat-ai-settings';

    private ?int $lastBitWarned = null;

    protected $indexer;


    public function __construct()
    {
        parent::__construct();
    }


// TEMP: classifier smoke-test
    // TEMP: classifier smoke-test; returns JSON string for easy echo in Tracy
    public function debugClassify(?string $text = null): string {
        // \ProcessWire\Input $input
        $input = $this->wire('input');

        // prefer explicit arg; fall back to GET/POST ?cl_text=
        if ($text === null) $text = (string) ($input->get('cl_text') ?? $input->post('cl_text') ?? '');

        // \ProcessWire\Classifier $clf
        $clf = new \ProcessWire\Classifier();
        $clf->setWire($this->wire());

        // ensure cfg loads and dict builds
        $cfg  = $clf->getCfg();
        $dict = $clf->buildDictionary();
        $res  = $clf->classify($text);

        $out = [
//            'text'     => $text,
//            'decision' => $res,
//            'dict_ok'  => is_array($dict),
//            'cfg_keys' => array_slice(array_keys($cfg), 0, 8), // peek only
            'dict'     => $dict
        ];

        return json_encode($out, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
    }


    public function init()
    {

        $this->indexer = new \ProcessWire\ChatAIIndexer();
        $this->indexer->setWire($this->wire());
        $this->chatai = $this->wire('modules')->get('ChatAI');

 //       $this->addHookAfter('Pages::saved', $this, 'hookPageSaved');
        $this->addHookAfter('Modules::saveReady', $this, 'hookModuleSaved');
        $this->addHookBefore('InputfieldForm::render', $this, 'initValues');

        $this->addHookAfter('Pages::saved', function ($event) {
            $page = $event->arguments(0);
            $changes = (array)($event->arguments(1) ?? []);
            $cfg = $this->loadPromptSettings();
            if(!isset($cfg['chunk_on_save'])) return;
            $rag = new RAG();

            try {
                $shouldReindex = $rag->shouldReindex($page);
            } catch (\Throwable $e) {
                $this->wire('log')->save('chatai', 'shouldReindex error: ' . $e->getMessage());
            }

            $changedKeys = array_keys($changes);
            $meaningfulKeys = array_diff($changedKeys, ['status', 'modified', 'template']);
            $contentChanged = !empty($meaningfulKeys);

            if (!$shouldReindex && !$contentChanged) {
                return;
            }

            if($page->isTrash() || !$this->chatai->validTemplate($page, $cfg)) {
                try {
                    $rag->deletePageVectors($page);
                } catch (\Throwable $e) {
                    $this->wire('log')->save('chatai', "Page not removed from vec db, Page id $page->id: " . $e->getMessage());
                }
            }

            if ($contentChanged && $shouldReindex) {
                try {
                    $rag->deletePageVectors($page);
                    $languages = $this->wire('languages');
                    if($languages && $languages->count()) {
                        foreach($languages as $lang) {
                            $rag->collectPageText($page, $cfg);
                        }
                    } else {
                        $rag->collectPageText($page, $cfg);
                    }
                } catch (\Throwable $e) {
                    $this->wire('log')->save('chatai', "Index upsert error, Page id $page->id : " . $e->getMessage());
                }
            }
        });

        $this->addHookAfter('Pages::deleted', function($event) {
            $page = $event->arguments(0);
            $rag  = new RAG();
            try { $rag->deletePageVectors($page); }
            catch (\Throwable $e) { $this->wire('log')->save('chatai', 'Index delete error: ' . $e->getMessage()); }
        });

        $this->addHookAfter('ImportPagesCSV::execute', function(HookEvent $event) {
            $processChatAI = $this->wire('modules')->get('ProcessChatAI');
            if (!$processChatAI) return;

            $cfg = $processChatAI->loadPromptSettings();
            if (!empty($cfg['chunk_on_save'])) {
                /** @var ProcessImportPagesCSV $ips */
                $ips = $event->object;
                $ips->warning(
                    $this->_('ChatAI "Update on Save" is currently enabled. For large imports, consider turning it off temporarily to avoid heavy re-indexing during import.')
                );
            }
        });
    }

    //*** Hooks ***//

    public function hookModuleSaved(HookEvent $event) {
        $module = $event->arguments(0);
        if(!$module instanceof self) return;
        $return = $event->return;
        $changed = array_map('strval', array_keys((array)$event->arguments(1)));
        $watched = [
            'rag_include_selectors','rag_exclude_selectors','rag_selectors_rev',
            'stop_terms_hard','stop_terms_soft','custom_terms','meta_terms'
        ];

        $shouldBump = false;
        foreach($changed as $k) {
            foreach($watched as $w) {
                if($k === $w || str_starts_with($k, $w . '_')) { $shouldBump = true; break 2; }
            }
        }
        if($shouldBump) {

            $indexVersion = $this->indexer->bumpIndexVersion();
            $cfg = $this->loadPromptSettings();
            $cfg['index_version'] = $indexVersion;
            $this->savePromptSettingsJson(json_encode($cfg));
            $this->_promptMemo = $cfg;
        }

        $event->return = $return;
    }


    public function initValues(HookEvent $event)
    {
        $form = $event->object;
        if ($form->getFormName() !== $this->formName) return;
        if ($this->wire('input')->requestMethod('POST')) return;

        // Load once and populate defaults
        if (empty($this['values'])) $this['values'] = $this->getValues($form);

        $form->populateValues($this['values']);

        // Multi-language fill for non-default tabs
        $languages = $this->wire('languages');
        if ($languages) {
            foreach ($languages->findNonDefault() as $lang) {
                foreach ($form->getByProperty('useLanguages', true, true) as $field) {
                    if ($x = $form->getChildByName($field->name)) {
                        $langValue = $this['values'][$field->name . '__' . $lang->id] ?? '';
                        $x->set('value' . $lang->id, $langValue);
                    }
                }
            }
        }

        // preview
        $form->prompt->prompt_preview->attr('value', $this->buildPrompt());

        // one-shot
        $event->removeHook($this);
    }


    // Tab builders (lazy-loaded or simple new)
    protected function tabs(array $tab): array
    {
        $user = $this->wire('user');
        $chatai = $this->wire('modules')->get('ChatAI');

        $output = [];
        $output['dashboard'] = new \ChatAI\AdminTabs\DashboardTab();

        $craftPrompt = false;

        if(!empty($chatai->prompt_roles)) {
            foreach ($chatai->prompt_roles as $k) {
                if($user->hasRole($k)) {
                    $craftPrompt = true;
                    break;
                }
            }
        }

        if($user->isSuperuser())
            $craftPrompt = true;

        if($craftPrompt !== false) {
            $output['personalise'] = new \ChatAI\AdminTabs\PersonaliseTab();
            $output['prompt'] = new \ChatAI\AdminTabs\PromptTab();
            $output['dictionary'] = new \ChatAI\AdminTabs\DictionaryTab();
        }

        return $output;
    }



    protected function renderKpiSnapshotJson(): string
    {
        $input = $this->wire('input');

        $days = (int) $input->get('days') ?: 7;
        $days = max(1, min($days, 30)); // clamp to 1–30

        $kpis = '';

        $chatAI = $this->wire('modules')->get('ChatAI');
        if ($chatAI && method_exists($chatAI, 'getObsLog')) {
            $logger = $chatAI->getObsLog();
            if ($logger && method_exists($logger, 'buildInsightsSnapshot')) {
                $kpis = $logger->buildInsightsSnapshot($days);
            }
        }
        return json_encode($kpis);
    }


    protected function renderVolumeDataJson(): string
    {
        $input = $this->wire('input');

        $days = (int) $input->get('days') ?: 7;
        $days = max(1, min($days, 30)); // clamp to 1–30

        $labels = [];
        $totals = [];

        $chatAI = $this->wire('modules')->get('ChatAI');
        if ($chatAI && method_exists($chatAI, 'getObsLog')) {
            $logger = $chatAI->getObsLog();
            if ($logger && method_exists($logger, 'fetchDailyVolume')) {
                $rows = $logger->fetchDailyVolume($days);
                foreach ($rows as $row) {
                    $labels[] = (string) ($row['date'] ?? '');
                    $totals[] = (int) ($row['total'] ?? 0);
                }
            }
        }

        return json_encode([
            'labels' => $labels,
            'totals' => $totals,
        ]);
    }

    protected function renderInsightsJson(): string
    {
        $cfg = $this->loadPromptSettings();
        $input = $this->wire('input');
        $days  = (int) $input->get('days') ?: 7;
        $days  = max(1, min($days, 60));

        $chatAI = $this->wire('modules')->get('ChatAI');
        if (!$chatAI || !method_exists($chatAI, 'getObsLog')) {
            return json_encode([
                'html' => '<p class="chatai-dashboard-muted">' .
                    $this->_('Insights are not available.') .
                    '</p>',
            ]);
        }

        $logger = $chatAI->getObsLog();
        if (!method_exists($logger, 'buildInsightsSnapshot')) {
            return json_encode([
                'html' => '<p class="chatai-dashboard-muted">' .
                    $this->_('Insights are not available.') .
                    '</p>',
            ]);
        }

        // Build snapshot for the selected range
        $snapshot = $logger->buildInsightsSnapshot($days);

        if (!$snapshot || empty($snapshot['total_events'])) {
            return json_encode([
                'html' => '<p class="chatai-dashboard-muted">' .
                    $this->_('No recent activity to analyse for the selected period.') .
                    '</p>',
            ]);
        }

        // Normalise a couple of fields for the heuristic function and summary
        $snapshot['range_days'] = (int) ($snapshot['range_days'] ?? $days);

        $san  = $this->wire('sanitizer');
        $tips = $logger->buildHeuristicInsights($snapshot, $cfg);

        $rangeDays   = (int) ($snapshot['range_days'] ??  $days);
        $totalEvents  = (int) ($snapshot['total_events'] ?? 0);
        $successLabel = isset($snapshot['success_rate'])
            ? ((int) round($snapshot['success_rate'] * 100)) . '%'
            : $this->_('n/a');
        $latencyLabel = isset($snapshot['avg_latency_ms'])
            ? ((int) $snapshot['avg_latency_ms']) . ' ms'
            : $this->_('n/a');

        $html  = '<p class="chatai-dashboard-muted">';
        $html .= sprintf(
            $this->_('Last %d days. Total events: %d. Success rate: %s. Average latency: %s.'),
            $rangeDays,
            $totalEvents,
            $successLabel,
            $latencyLabel
        );
        $html .= '</p>';

        if ($tips) {
            $html .= '<ul class="chatai-dashboard-list">';
            foreach ($tips as $tip) {
                $html .= '<li>' . $san->entities($tip) . '</li>';
            }
            $html .= '</ul>';
        } else {
            $html .= '<p class="chatai-dashboard-muted">' .
                $this->_('No obvious issues detected.') .
                '</p>';
        }

        return json_encode(['html' => $html]);
    }

    protected function renderObslogCsv(): void {
        $input   = $this->wire('input');
        $modules = $this->wire('modules');

        $days = (int) $input->get('days') ?: 7;
        $days = max(1, min($days, 60));

        $chatAI = $modules->get('ChatAI');
        if (!$chatAI || !method_exists($chatAI, 'getObsLog')) {
            header('Content-Type: text/plain; charset=utf-8');
            echo "Observability log is not available.";
            return;
        }

        $logger = $chatAI->getObsLog();
        if (!$logger || !method_exists($logger, 'fetchRange')) {
            header('Content-Type: text/plain; charset=utf-8');
            echo "Observability export is not available.";
            return;
        }

        $today = new \DateTime('today');
        $from  = (clone $today)->modify('-' . ($days - 1) . ' days');
        $rows = $logger->fetchRange($from, $today);

//       $to   = new \DateTime('today'); // now
//        $from = (clone $to)->modify("-{$days} days");
//        $rows = $logger->fetchRange($from, $to);

        $filename = sprintf(
            'chatai_obslog_last_%dd_%s.csv',
            $days,
            date('Ymd_His')
        );

        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename="' . $filename . '"');
        header('Pragma: no-cache');
        header('Expires: 0');

        $out = fopen('php://output', 'w');
        if (!$out) {
            echo "Failed to open output stream.";
            return;
        }

        // 1) Discover all meta keys across this result set
        $metaKeys = [];
        foreach ($rows as $row) {
            if (empty($row['meta'])) continue;
            $decoded = json_decode($row['meta'], true);
            if (!is_array($decoded)) continue;
            foreach ($decoded as $k => $v) {
                if (!array_key_exists($k, $metaKeys)) {
                    $metaKeys[$k] = true;
                }
            }
        }
        $metaKeys = array_keys($metaKeys);
        sort($metaKeys); // stable ordering

        // 2) Write header row: base columns + meta columns
        $baseHeader = ['id', 'created', 'chat_id', 'event_type', 'status', 'model'];
        $header     = array_merge($baseHeader, $metaKeys);
        fputcsv($out, $header);

        // 3) Write each row, flattening meta into columns
        foreach ($rows as $row) {
            $meta = [];
            if (!empty($row['meta'])) {
                $decoded = json_decode($row['meta'], true);
                if (is_array($decoded)) {
                    $meta = $decoded;
                }
            }

            $line = [
                $row['id'],
                $row['created'],
                $row['chat_id'],
                $row['event_type'],
                $row['status'],
                $row['model'],
            ];

            foreach ($metaKeys as $k) {
                $val = $meta[$k] ?? '';

                if (is_bool($val)) {
                    $val = $val ? '1' : '0';
                } elseif (is_array($val)) {
                    // Nested structures should be rare; encode them as JSON
                    $val = json_encode($val, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
                }

                $line[] = $val;
            }

            fputcsv($out, $line);
        }

        fclose($out);
    }


    public function ___execute()
    {
        $input  = $this->wire('input');
        $config = $this->wire('config');

        $api = $input->get->text('api');

        if ($api === 'volumeData') {
            header('Content-Type: application/json; charset=utf-8');
            echo $this->renderVolumeDataJson();
            exit;
        }

        if ($api === 'insights') {
            header('Content-Type: application/json; charset=utf-8');
            echo $this->renderInsightsJson();
            exit;
        }

        if ($api === 'obslogExport') {
            $this->renderObslogCsv();
            exit;
        }

        if ($api === 'kpiSnapshot') {
            header('Content-Type: application/json; charset=utf-8');
            echo $this->renderKpiSnapshotJson();
            exit;
        }



        $this->wire('modules')->get('JqueryWireTabs');
        $tabView = [];

        $this->headline('ChatAI');
        $modules = $this->wire('modules');

        $this->config->styles->add($this->config->urls->ProcessChatAI . 'ProcessChatAI.css');
        $this->config->scripts->add($this->config->urls->ProcessChatAI . 'ProcessChatAI.js');
        // Chart.js from CDN (simple and proven)
        $this->config->scripts->add('https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js');


        $this->values = $this->loadPromptSettings();

        $form = $modules->get('InputfieldForm');
        $form->attr('name+id', $this->formName);

        // Build each tab fieldset and add to form
        foreach ($this->tabs($tabView) as $key => $tab) {
            $out = $tab->build($form, $this->values);   // returns array
            $key = array_key_first($out);
            $tabView[$key] = $out[$key];
            $form = $out['form'];
        }

        // Handle "Run Backfill & Reconcile" for vector db
        if ($this->wire('input')->post('chatai_run_backfill')) {


            $dry = (bool) $this->input->post('chatai_backfill_dry_run');
            $chunk = (int) ($this->input->post('chatai_backfill_chunk') ?: 200);
            if ($chunk < 50)  $chunk = 50;
            if ($chunk > 1000) $chunk = 1000;

            $t0 = microtime(true);
            $summary = $this->runBackfillReconcile($dry, $chunk);
            $summary['latency_ms'] = (int) round((microtime(true) - $t0) * 1000);

            $this->message($this->_('Backfill & Reconcile complete.') . ' ' . json_encode($summary));

            // now run the dictionary indexer
            $this->actionReindexAll();
        }

        // Submit button
        $submit = $this->modules->get('InputfieldSubmit');
        $submit->attr('value', 'submit');
        $submit->attr('value', $this->_('Save'));
        $submit->header = true;
        $form->add($submit);

        if($form->isSubmitted()) {
            $inputPost = $this->wire('input')->post;
            if ($form->process()) {
                $form->populateValues($inputPost);

                $values = [];
                foreach ($inputPost as $key => $value) {
                    if($key === '' || $key === 'submit' || $key === '_InputfieldForm' || str_starts_with($key, 'TOKEN')) continue;
                    $values[$key] = $value;
                }
                $cfg = $this->loadPromptSettings();

                $values['index_version'] = isset($cfg['index_version']) ? $cfg['index_version'] + 1 : 1;
                $values['rag_candidate_templates'] = $this->chatai->asmToIds($values['rag_candidate_templates'] ?? []);
                $values['rag_exclude_templates'] = $this->chatai->asmToIds($values['rag_exclude_templates'] ?? []);

                $this->_promptMemo = $values;

                $this->savePromptSettingsJson(json_encode($this->_promptMemo));

                // delete old index version from cache if it exists
                if(isset($cfg['index_version'])) {
                    $oldVer = $cfg['index_version'];
                    $this->wire('cache')->deleteFor('chatai', "dict:v{$oldVer}:all");
                }

            } else {
//                $errors = $form->getErrors(); // array of error messages…
                $inputs = $form->getErrorInputfields(); // …or array of Inputfields with errors
                $text = "<h3 class='error'>" .$this->_('Your form has errors. Please fix') . "</h3>\n";
                return $text . $form->render();
            }
        }
        return $form->render();
    }

    public function addTab($id, $label, $wrapper = null)
    {
        $this->tabs[$id] = $label;
        if($wrapper) $wrapper->addClass('WireTab');
    }


    public function getValues($form) : array
    {
        $savedData = $this->loadPromptSettings();
        if(!empty($savedData)) return $savedData;

        // OK, nothing in the database.
        // Populate the values with the defaults

        $user = $this->wire('user');
        $data = [];
        $skipTypes = array(
            'InputfieldMarkup',
            'InputfieldSubmit',
        );

        foreach($form->children as $tab) {
            if($tab->count === 0) continue;
            if(in_array($tab->className(),$skipTypes)) continue;
            $inputfieldsArray = $tab->getAll();

            foreach($inputfieldsArray as $tabField) {
                if ($tabField->count === 0) continue;
                $fldName = $tabField->attributes['name'];
                if ($fldName === '' || $fldName === 'submit' || $fldName === '_InputfieldForm' || str_starts_with($fldName, 'TOKEN')) continue;
                if ($user->language->isDefault() || empty($tabField->useLanguages)) {
                    $data[$fldName] = $form->getValueByName($fldName);
                } else {
                    $data[$fldName] = !empty($tabField->getLanguageValue($user->language))
                        ? $tabField->getLanguageValue($user->language)
                        : $form->getValueByName($fldName);
                }
            }
        }
        $this['values'] = $data;
        return $data;
    }

    private function _savePromptSettingsJson(string $json): bool {
        $chatai = $this->modules->get('ChatAI');
        $db = wire('database'); // WireDatabasePDO (PDO)
        $table = $chatai::dbTablePrompt;

        $sql = "INSERT INTO `$table` (id, json) VALUES (1, ?)
            ON DUPLICATE KEY UPDATE json = VALUES(json), created = CURRENT_TIMESTAMP";

        try {
            $stmt = $db->prepare($sql);
            $stmt->bindValue(1, $json, \PDO::PARAM_STR);
            return $stmt->execute();
        } catch(\Throwable $e) {
            $this->wire('log')->save('chatai', "savePromptSettingsJson failed: " . $e->getMessage());
            $this->error($this->_('Failed to save settings.'));
            return false;
        }
    }

    public function savePromptSettingsJson(string $json): bool
    {
        return $this->_savePromptSettingsJson($json);
    }

    private function _loadPromptSettings(): array {

        if (isset($this->_promptMemo)) return $this->_promptMemo;

            $chatai = $this->wire('modules')->get('ChatAI');
            $db = wire('database');
            $table = $chatai::dbTablePrompt;

            $stmt = $db->prepare("SELECT json FROM `$table` WHERE id = 1 LIMIT 1");
            $stmt->execute();
            $row = $stmt->fetch(\PDO::FETCH_ASSOC);
            if (!$row || !isset($row['json'])) return [];
            $cfg = json_decode($row['json'], true) ?: [];

        return  $this->_promptMemo = $cfg;
    }

    public function loadPromptSettings(): array {
        return $this->_loadPromptSettings();
    }


    protected function buildPrompt(): string {
        $session = $this->wire('session');
        //$cfg = $this->_loadPromptSettings();
        if(empty($this['values'])) {
            $session->warning($this->_('Please save before proceeding.'));
           return '';
        }
        $modules = wire('modules');
        $user = wire('user');

        // Custom prompt
        if ($this['values']['autogen'] === 0) {
            // Server-side enforcement: only use the custom text
            $txt = trim((string) $this['values']['custom_prompt']);
            if ($txt !== '') return $txt;
        }

        // Autogenerated prompt
        foreach ($this['values'] as $key => $value) {
            $$key = $value;
        }

        $botname = $this->getLanguageVal('botname');

        // Auto-generated prompt
        $langCode = $user->language ? $user->language->name : 'en';
        $langs = [
            'en' => 'English',
            'en-au' => 'Australian English',
            'es' => 'Spanish',
            'fr' => 'French',
            'de' => 'German'
        ];

        if ($modules->isInstalled('Languages')) {
            foreach ($modules->get('Languages')->languages as $language) {
                $langs[$language->name] = $language->title;
            }
        }

        $langName = isset($langs[$langCode]) ? $langs[$langCode] : 'English';

        $counter = 1;

        $allowed = trim((string)($this['values']['allowed_tags'] ?? 'p,ul,li,ol,strong,em,code,br,a[href],blockquote'));
        $allowedClean = array_values(array_filter(array_map('trim', explode(',', $allowed))));

        /** Build literal tags for the PROMPT (not HTML-escaped) */
        $allowedForPrompt = implode(', ', array_map(function($t) {
            // turn "a[href]" into <a href="">
            if (stripos($t, 'a[') === 0) return '<a href="">';
            // plain tag names (p, ul, li, …) → <p>, <ul>, …
            return '<' . $t . '>';
        }, $allowedClean));

        $prompt = '';
        // Assemble your safe default system prompt
        if(!empty($botname)) {
            $prompt .= "You are {$botname}";
                if (!empty($botrole)) {
                    $prompt .= ", {$botrole}";
                    if (!empty($bizname))
                        $prompt .= " for {$bizname}";
                }
            $prompt .= ".\n";
        }

        if(!empty($autohint)) {
            $prompt .= "\n{$autohint}";
        }

        // 1. Language detections
        $prompt .= "\n{$counter}. **Language Detection**";
        $prompt .= "\n- Automatically detect and respond in the user's language. If the language is unclear, default to {$langName}\n";

        // 2. Tone and style
        if(!empty($tone)) {
            $counter++;
            $prompt .= "\n{$counter}. **Tone & Style**\n";
            $prompt .= "- Maintain a {$tone} tone.\n";
            $prompt .= "- Encourage users without excessive optimism.\n";
            $prompt .= "- Do not use emojis or em dashes.\n";
            $prompt .= "- Keep sentences clear, concise, and straightforward.\n";
            $prompt .= "- Do not identify yourself as {$botname} unless specifically asked.\n";
        }

        // 3. Output formatting
        $counter++;
        $prompt .= "\n{$counter}. **Output Formatting (HTML only)**";
        $prompt .= "\n- Use only these tags: {$allowedForPrompt}.";
        $prompt .= "\n- Output HTML fragments only. Do not include `<html>`, `<head>`, or `<body>`.";
        $prompt .= "\n- Do not include inline CSS, scripts, images, or tables.";
        $prompt .= "\n- Use `<p>` for paragraphs, lists with `<ul>/<ol>`, and `<br>` for simple line breaks.";
        $prompt .= "\n- Escape any user-supplied HTML unless specific formatting is requested. Treat input as plain text by default.";
        $prompt .= "\n- Create links with `<a href='...'>` using only absolute URLs and no other attributes.\n";

        // Safety & Civility
        $counter++;
        $prompt .= "\n{$counter}. **Safety & Civility**";
        $prompt .= "\n- Do not echo rude or obscene language. Respond politely and guide the conversation toward respect.";
        $prompt .= "\n- Decline any harmful or illegal requests succinctly and suggest safer alternatives.";
        $prompt .= "\n- Always acknowledge greetings and ask for what the user would like to know.\n";

        // Brevity
        $counter++;
        $prompt .= "\n{$counter}. **Brevity**";
        $words = !empty($botwords) ? $botwords : 400;
        $prompt .= "\n- Limit responses to approximately {$words} words.";
        $prompt .= "\n- When addressing broad topics, present essential information in short lists.";
        $prompt .= "\n- For greetings or casual conversation, respond naturally and conversationally without meta-commentary.\n";

        // Clarification & Uncertainty
        $counter++;
        $prompt .= "\n{$counter}. **Clarification & Uncertainty**";
        $prompt .= "\n- If critical details are missing, ask up to two brief clarifying questions.";
        $prompt .= "\n- If the user prefers no questions, act on reasonable assumptions and clearly state them.";
        $prompt .= "\n- If information is unavailable, acknowledge this briefly and suggest next steps or what details are needed.\n";

        // Additional Guidance
        $prompt .= "\n**Additional Guidance**";
        $prompt .= "\n- Only validate coverage when the user’s request is complex or multi-part.";
        $prompt .= "\n- Do not state “this covers your greeting” or similar for simple greetings or small talk.";
        $prompt .= "\n- Except when it is a greeting or small talk, if no site context is provided for the current question, reply briefly that no relevant on‑site pages were found, then ask one specific clarifying question. Offer exactly one self‑check tip. Do not mention browsing or technical limitations.";
        $prompt  .= "\nIf you asked a clarifying question, interpret short replies such as {$followup_terms}, or a page title as answers to that question.";

        $prompt .= "\n";
        return $prompt;
    }

    public function getPrompt(): string {
        return $this->buildPrompt();
    }

    public function getIntro(): string {
        $botname = $this->getLanguageVal('botname');
        $botintro = $this->getLanguageVal('botintro');
        $intro = str_ireplace('{botname}', $botname, $botintro);
        return $intro;
    }

    public function getLanguageVal(string $name): string
    {
        if(empty($this['values']))
            $this['values'] = $this->loadPromptSettings();

        $languages = $this->wire('languages');
        $user = $this->wire('user');

        if(!$languages || $user->language->isDefault()) {
            return $this['values'][$name];
        } else {
            $userLangId = $user->language->id;
            $langVal = !empty($this['values'][$name . '__' . $userLangId]) ? $this['values'][$name . '__' . $userLangId] : $this['values'][$name];
            return $langVal;
        }
    }

    public function getPlaceholder (): string
    {
        return $this->getLanguageVal('input_placeholder');
    }

    public function getButtonText (): string
    {
        return $this->getLanguageVal('submit_text');
    }

    public function getResetText (): string
    {
        return $this->getLanguageVal('reset_text');
    }

    public function getThinkingText (): string
    {
        return $this->getLanguageVal('thinking_text');
    }

    public function getDisclaimerText (): string
    {
        return $this->getLanguageVal('disclaimer_text');
    }

    public function getFooterText (): string
    {
        return $this->getLanguageVal('footer_text');
    }

    public function getBotName (): string
    {
        return $this->getLanguageVal('botname');
    }

    public function getWidget(string $path): string {
        if(empty($this['values']))
            $this['values'] = $this->loadPromptSettings();
        $files = wire('files');
        $intro = $this->getIntro();
        $placeholder = $this->getPlaceholder();
        $submitText = $this->getButtonText();
        $resetText = $this->getResetText();
        $thinkingText = $this->getThinkingText();
        $disclaimerText = $this->getDisclaimerText();
        $footerText = $this->getFooterText();
        $widgetFile =  $files->render($path, [
            'intro' => $intro,
            'placeholder'=>$placeholder,
            'button_text'=>$submitText,
            'reset_text'=>$resetText,
            'thinking_text'=>$thinkingText,
            'disclaimer_text'=>$disclaimerText,
            'footer_text'=>$footerText
        ]);
        return $widgetFile;
    }


    public function isBlacklistTerm($message): bool
    {
        $sanitizer = $this->wire('sanitizer');
        $cfg       = $this->loadPromptSettings();

        if (empty($cfg['use_blacklist']) || empty($cfg['blacklist'])) {
            return false;
        }

        $msg = mb_strtolower($sanitizer->text($message));
        if ($msg === '') return false;

        $terms = array_filter(array_map('trim', explode(',', $cfg['blacklist'])));

        foreach ($terms as $t) {
            $t = mb_strtolower($sanitizer->text($t));

            // Convert "hang myself" → "hang\s+myself"
            $pattern = '/\b' . preg_quote(str_replace(' ', '___SPACE___', $t), '/') . '\b/iu';
            $pattern = str_replace('___SPACE___', '\s+', $pattern);

            if (preg_match($pattern, $msg)) {
                $this->wire('log')->save(
                    'chatai-blacklist-debug',
                    "Matched phrase '{$t}' in message: '{$msg}'"
                );
                return true;
            }
        }

        return false;
    }


    // Dashboard features

    /** Path to backfill log */
    protected function backfillLogPath(): string {
        $config = $this->wire('config');
        $dir = $config->paths->logs . 'chatai';
        if (!is_dir($dir)) @mkdir($dir, $config->chmodDir, true);
        return $dir . '/chatai_backfill.txt';
    }

    /** Append a JSON line to the backfill log */
    protected function backfillLog(array $row): void {
        $row['t'] = date('c');
        $logPath = $this->backfillLogPath();
        @file_put_contents($logPath, json_encode($row) . PHP_EOL, FILE_APPEND);
    }


    /**
     * Run Backfill & Reconcile across the site.
     * - $dryRun: don't write vectors, only report
     * - $chunk: batch size for memory/time safety
     * Returns a summary array with counts.
     */
    protected function runBackfillReconcile(bool $dryRun = false, int $chunk = 200): array {
        $pages = $this->wire('pages');
        $cfg   = $this->loadPromptSettings();

        $rag   = new RAG();
        $config = $this->wire('config');
        $chatai = $this->wire('modules')->get('ChataAI');

        $guest = $this->wire('users')->getGuestUser();
        $http404 = $config->http404PageID;

        $summary = [
            'eligible_total' => 0,
            'ineligible_total' => 0,
            'indexed_new' => 0,
            'indexed_replaced' => 0,
            'deleted' => 0,
            'errors' => 0,
            'dry_run' => $dryRun,
            'chunk' => $chunk,
            'model' => $this->chatai->model ?? '',
        ];

        // Broad candidate scan — you may narrow by templates/parents in RAG::shouldIndexPage


        $selector = "has_parent!=2, status!=trash, id!=$http404, template!=http404, include=hidden";
        $total = $pages->count($selector);
        $offset = 0;

        while ($offset < $total) {
            foreach ($pages->find("$selector, start=$offset, limit=$chunk") as $page) {
                try {
                    // Decide eligibility (same as saveReady)
                    //$eligible = $rag->shouldIndexPage($page, $cfg);
                    $eligible = $this->chatai->validTemplate($page, $cfg);
                    $inDb     = $rag->shouldReindex($page);

                    if ($eligible) $summary['eligible_total']++; else $summary['ineligible_total']++;

                    if (!$eligible) {
                        if ($inDb && $page->isTrash()) {
                            if (!$dryRun) $rag->deletePageVectors($page);
                            $summary['deleted']++;
                            $this->backfillLog(['ev'=>'delete', 'id'=>$page->id, 'url'=>$page->url]);
                        }

                        if($page->id === $config->http404PageID) {
                            $this->backfillLog(['ev'=>'warn_excluded', 'id'=>$page->id, 'reason'=>'id denylist']);
                        }
                        continue;
                    }

                    // Eligible
                    if (!$inDb) {
                        if (!$dryRun) $rag->collectPageText($page, $cfg);
                        $summary['indexed_new']++;
                        $this->backfillLog(['ev'=>'index_new', 'id'=>$page->id, 'url'=>$page->url]);
                        continue;
                    } else {
                        // Already in DB
                        if (!$dryRun) {
                            $rag->deletePageVectors($page);
                            $rag->collectPageText($page, $cfg);
                            $this->backfillLog(['ev' => 'index_upd', 'id' => $page->id, 'url' => $page->url]);
                        }
                        $summary['indexed_replaced']++;
                        continue;
                    }

                } catch (\Throwable $e) {
                    $summary['errors']++;
                    $this->backfillLog(['ev'=>'error', 'id'=>$page->id ?? 0, 'msg'=>$e->getMessage()]);
                }
            }
            $offset += $chunk;
        }

        $this->backfillLog(['ev'=>'summary'] + $summary);
        return $summary;
    }

    public function actionReindexAll(int $langId = 0) {
        $indexer = new \ProcessWire\ChatAIIndexer();
        $indexer->setWire($this->wire());
        //$pages = $this->wire('pages')->findMany('has_parent!=2, include=visible, template!=admin');
        $pages = $this->wire('pages')->findMany('has_parent!=2, template!=admin');


        $languages = $this->wire('languages');
        $langIds = ($languages && $languages->count())
            ? array_map(fn($l) => (int)$l->id, iterator_to_array($languages))
            : [ (int)$langId ];

        foreach($pages as $p) {
            foreach($langIds as $lid) $indexer->buildForPage($p, $lid);
        }
        $next = $indexer->bumpIndexVersion();
        $cfg = $this->loadPromptSettings();
        $cfg['index_version'] = $next;
        $this->savePromptSettingsJson(json_encode($cfg));
        $this->_promptMemo = $cfg;
        $this->message('Reindex complete.');
    }


    /* Hookable methods */
    public function ___beforeSend(array $request): array {
        return $request; // no-op by default
    }



}
