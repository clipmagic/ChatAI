class ProcessChatAI extends Process
{

    public $tabs = [];

    public $values = [];

    public $formName = 'chat-ai-settings';

    private ?int $lastBitWarned = null;

    protected $indexer;

    protected $classifier;


    public function __construct()
    {
        parent::__construct();
    }


// TEMP: classifier smoke-test
    // TEMP: classifier smoke-test; returns JSON string for easy echo in Tracy
    public function debugClassify(?string $text = null): string {
        // \ProcessWire\Input $input
        $input = $this->wire('input');

        // prefer explicit arg; fall back to GET/POST ?cl_text=
        if ($text === null) $text = (string) ($input->get('cl_text') ?? $input->post('cl_text') ?? '');

        // \ProcessWire\Classifier $clf
        $clf = new \ProcessWire\Classifier();
        $clf->setWire($this->wire());

        // ensure cfg loads and dict builds
        $cfg  = $clf->getCfg();
        $dict = $clf->buildDictionary();
        $res  = $clf->classify($text);

        $out = [
            'text'     => $text,
            'decision' => $res,
            'dict_ok'  => is_array($dict),
            'cfg_keys' => array_slice(array_keys($cfg), 0, 8), // peek only
            'dict'     => $dict
        ];

        return json_encode($out, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);
    }


    public function init()
    {

        $this->indexer = new \ProcessWire\ChatAIIndexer();
        $this->indexer->setWire($this->wire());

        $this->classifier = new \ProcessWire\Classifier();
        $this->classifier->setWire($this->wire());

        $this->chatai = $this->wire('modules')->get('ChatAI');

        $this->addHookBefore('InputfieldForm::render', $this, 'initValues');

        $this->addHookAfter('Pages::saved', function ($event) {
            $page = $event->arguments(0);
            $changes = (array)($event->arguments(1) ?? []);

            $svc = $this->chatai->promptService();
            $cfg = $svc->loadPromptSettings();

            if(!isset($cfg['chunk_on_save'])) return;
            $rag = new RAG();

            try {
                $shouldReindex = $rag->shouldReindex($page);
            } catch (\Throwable $e) {
                $this->wire('log')->save('chatai', 'shouldReindex error: ' . $e->getMessage());
            }

            $changedKeys = array_keys($changes);
            $meaningfulKeys = array_diff($changedKeys, ['status', 'modified', 'template']);
            $contentChanged = !empty($meaningfulKeys);

            if (!$shouldReindex && !$contentChanged) {
                return;
            }

            if($page->isTrash() || !$this->chatai->validTemplate($page, $cfg)) {
                try {
                    $rag->deletePageVectors($page);
                } catch (\Throwable $e) {
                    $this->wire('log')->save('chatai', "Page not removed from vec db, Page id $page->id: " . $e->getMessage());
                }
            }

            if ($contentChanged && $shouldReindex) {
                try {
                    $rag->deletePageVectors($page);
                    $languages = $this->wire('languages');
                    if($languages && $languages->count()) {
                        foreach($languages as $lang) {
                            $rag->collectPageText($page, $cfg);
                        }
                    } else {
                        $rag->collectPageText($page, $cfg);
                    }
                } catch (\Throwable $e) {
                    $this->wire('log')->save('chatai', "Index upsert error, Page id $page->id : " . $e->getMessage());
                }
            }
        });

        $this->addHookAfter('Pages::deleted', function($event) {
            $page = $event->arguments(0);
            $rag  = new RAG();
            try { $rag->deletePageVectors($page); }
            catch (\Throwable $e) { $this->wire('log')->save('chatai', 'Index delete error: ' . $e->getMessage()); }
        });

        $this->addHookAfter('ImportPagesCSV::execute', function(HookEvent $event) {

            $svc = $this->chatai->promptService();
            $cfg = $svc->loadPromptSettings();
            if (!empty($cfg['chunk_on_save'])) {
                /** @var ProcessImportPagesCSV $ips */
                $ips = $event->object;
                $ips->warning(
                    $this->_('ChatAI "Update on Save" is currently enabled. For large imports, consider turning it off temporarily to avoid heavy re-indexing during import.')
                );
            }
        });
    }

    //*** Hooks ***//

    public function initValues(HookEvent $event)
    {
        $form = $event->object;
        if ($form->getFormName() !== $this->formName) return;
        if ($this->wire('input')->requestMethod('POST')) return;

        $chatai = $this->wire('modules')->get('ChatAI');

        $cfg = $chatai->promptService()->loadPromptSettings();

        if(empty($cfg)) {
            $cfg = $this->getValues($form);
            $chatai->promptService()->savePromptSettings($cfg);
        }

        foreach($form->children() as $tab) {
            if($tab->className === 'InputfieldSubmit') continue;
            $tab->populateValues($cfg);
        }

        // Multi-language fill for non-default tabs
        $languages = $this->wire('languages');
        if ($languages) {
            foreach ($languages->findNonDefault() as $lang) {
                foreach ($form->getByProperty('useLanguages', true, true) as $field) {
                    if ($x = $form->getChildByName($field->name)) {
                        $langValue = $cfg[$field->name . '__' . $lang->id] ?? '';
                        $x->set('value' . $lang->id, $langValue);
                    }
                }
            }
        }

        // preview
        $form->prompt->prompt_preview->attr('value', $chatai->promptService()->getPrompt());

        // one-shot
        $event->removeHook($this);
    }


    // Tab builders (lazy-loaded or simple new)
    protected function tabs(array $tab): array
    {
        $user = $this->wire('user');

        $output = [];
        $output['dashboard'] = new \ChatAI\AdminTabs\DashboardTab();

        $craftPrompt = false;

        if(!empty($this->chatai->prompt_roles)) {
            foreach ($this->chatai->prompt_roles as $k) {
                if($user->hasRole($k)) {
                    $craftPrompt = true;
                    break;
                }
            }
        }

        if($user->isSuperuser())
            $craftPrompt = true;

        if($craftPrompt !== false) {
            $output['personalise'] = new \ChatAI\AdminTabs\PersonaliseTab();
            $output['prompt'] = new \ChatAI\AdminTabs\PromptTab();
            $output['dictionary'] = new \ChatAI\AdminTabs\DictionaryTab();
        }

        return $output;
    }

    protected function renderKpiSnapshotJson(): string
    {
        $input = $this->wire('input');

        $days = (int) $input->get('days') ?: 7;
        $days = max(1, min($days, 30)); // clamp to 1–30

        $kpis = '';

        $chatAI = $this->chatai;
        if ($chatAI && method_exists($chatAI, 'getObsLog')) {
            $logger = $chatAI->getObsLog();
            if ($logger && method_exists($logger, 'buildInsightsSnapshot')) {
                $kpis = $logger->buildInsightsSnapshot($days);
            }
        }
        return json_encode($kpis);
    }


    protected function renderVolumeDataJson(): string
    {
        $input = $this->wire('input');

        $days = (int) $input->get('days') ?: 7;
        $days = max(1, min($days, 30)); // clamp to 1–30

        $labels = [];
        $totals = [];

        $chatAI = $this->chatai;
        if ($chatAI && method_exists($chatAI, 'getObsLog')) {
            $logger = $chatAI->getObsLog();
            if ($logger && method_exists($logger, 'fetchDailyVolume')) {
                $rows = $logger->fetchDailyVolume($days);
                foreach ($rows as $row) {
                    $labels[] = (string) ($row['date'] ?? '');
                    $totals[] = (int) ($row['total'] ?? 0);
                }
            }
        }

        return json_encode([
            'labels' => $labels,
            'totals' => $totals,
        ]);
    }

    protected function renderInsightsJson(): string
    {
        $chatai = $this->chatai;

        if (!$chatai || !method_exists($chatai, 'getObsLog')) {
            return json_encode([
                'html' => '<p class="chatai-dashboard-muted">' .
                    $this->_('Insights are not available.') .
                    '</p>',
            ]);
        }


        $svc = $this->chatai->promptService();
        $cfg = $svc->loadPromptSettings();

        $input = $this->wire('input');
        $days  = (int) $input->get('days') ?: 7;
        $days  = max(1, min($days, 60));


        $logger = $chatai->getObsLog();
        if (!method_exists($logger, 'buildInsightsSnapshot')) {
            return json_encode([
                'html' => '<p class="chatai-dashboard-muted">' .
                    $this->_('Insights are not available.') .
                    '</p>',
            ]);
        }

        // Build snapshot for the selected range
        $snapshot = $logger->buildInsightsSnapshot($days);

        if (!$snapshot || empty($snapshot['total_events'])) {
            return json_encode([
                'html' => '<p class="chatai-dashboard-muted">' .
                    $this->_('No recent activity to analyse for the selected period.') .
                    '</p>',
            ]);
        }

        // Normalise a couple of fields for the heuristic function and summary
        $snapshot['range_days'] = (int) ($snapshot['range_days'] ?? $days);

        $san  = $this->wire('sanitizer');
        $tips = $logger->buildHeuristicInsights($snapshot, $cfg);

        $rangeDays   = (int) ($snapshot['range_days'] ??  $days);
        $totalEvents  = (int) ($snapshot['total_events'] ?? 0);
        $successLabel = isset($snapshot['success_rate'])
            ? ((int) round($snapshot['success_rate'] * 100)) . '%'
            : $this->_('n/a');
        $latencyLabel = isset($snapshot['avg_latency_ms'])
            ? ((int) $snapshot['avg_latency_ms']) . ' ms'
            : $this->_('n/a');

        $html  = '<p class="chatai-dashboard-muted">';
        $html .= sprintf(
            $this->_('Last %d days. Total events: %d. Success rate: %s. Average latency: %s.'),
            $rangeDays,
            $totalEvents,
            $successLabel,
            $latencyLabel
        );
        $html .= '</p>';

        if ($tips) {
            $html .= '<ul class="chatai-dashboard-list">';
            foreach ($tips as $tip) {
                $html .= '<li>' . $san->entities($tip) . '</li>';
            }
            $html .= '</ul>';
        } else {
            $html .= '<p class="chatai-dashboard-muted">' .
                $this->_('No obvious issues detected.') .
                '</p>';
        }

        return json_encode(['html' => $html]);
    }

    protected function renderObslogCsv(): void {
        $input   = $this->wire('input');
        $modules = $this->wire('modules');

        $days = (int) $input->get('days') ?: 7;
        $days = max(1, min($days, 60));

        $chatAI = $this->chatai;
        if (!$chatAI || !method_exists($chatAI, 'getObsLog')) {
            header('Content-Type: text/plain; charset=utf-8');
            echo "Observability log is not available.";
            return;
        }

        $logger = $chatAI->getObsLog();
        if (!$logger || !method_exists($logger, 'fetchRange')) {
            header('Content-Type: text/plain; charset=utf-8');
            echo "Observability export is not available.";
            return;
        }

        $today = new \DateTime('today');
        $from  = (clone $today)->modify('-' . ($days - 1) . ' days');
        $rows = $logger->fetchRange($from, $today);

//       $to   = new \DateTime('today'); // now
//        $from = (clone $to)->modify("-{$days} days");
//        $rows = $logger->fetchRange($from, $to);

        $filename = sprintf(
            'chatai_obslog_last_%dd_%s.csv',
            $days,
            date('Ymd_His')
        );

        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename="' . $filename . '"');
        header('Pragma: no-cache');
        header('Expires: 0');

        $out = fopen('php://output', 'w');
        if (!$out) {
            echo "Failed to open output stream.";
            return;
        }

        // 1) Discover all meta keys across this result set
        $metaKeys = [];
        foreach ($rows as $row) {
            if (empty($row['meta'])) continue;
            $decoded = json_decode($row['meta'], true);
            if (!is_array($decoded)) continue;
            foreach ($decoded as $k => $v) {
                if (!array_key_exists($k, $metaKeys)) {
                    $metaKeys[$k] = true;
                }
            }
        }
        $metaKeys = array_keys($metaKeys);
        sort($metaKeys); // stable ordering

        // 2) Write header row: base columns + meta columns
        $baseHeader = ['id', 'created', 'chat_id', 'event_type', 'status', 'model'];
        $header     = array_merge($baseHeader, $metaKeys);
        fputcsv($out, $header);

        // 3) Write each row, flattening meta into columns
        foreach ($rows as $row) {
            $meta = [];
            if (!empty($row['meta'])) {
                $decoded = json_decode($row['meta'], true);
                if (is_array($decoded)) {
                    $meta = $decoded;
                }
            }

            $line = [
                $row['id'],
                $row['created'],
                $row['chat_id'],
                $row['event_type'],
                $row['status'],
                $row['model'],
            ];

            foreach ($metaKeys as $k) {
                $val = $meta[$k] ?? '';

                if (is_bool($val)) {
                    $val = $val ? '1' : '0';
                } elseif (is_array($val)) {
                    // Nested structures should be rare; encode them as JSON
                    $val = json_encode($val, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
                }

                $line[] = $val;
            }

            fputcsv($out, $line);
        }

        fclose($out);
    }

    protected function pruneObslogRetainDays(int $retainDays): int
    {
        $retainDays = max(1, (int) $retainDays);

        $dt = new \DateTimeImmutable('now', new \DateTimeZone('UTC'));
        $cutoff = $dt->modify("-{$retainDays} days")->format('Y-m-d H:i:s');

        try {
            $db = $this->wire('database');
            $sql = "DELETE FROM chatai_obslog WHERE created < :cutoff";
            $stmt = $db->prepare($sql);
            $stmt->bindValue(':cutoff', $cutoff);
            $stmt->execute();
        } catch(WireException $e) {
            $this->error($e->getMessage());
        }
        return (int) $stmt->rowCount();
    }

    protected function getRagReindexOptionsFromPost(): array {
        $in = $this->wire('input');

        $dry = (bool) $in->post('rag_dry_run');

        $base = trim((string) $in->post('rag_selector'));
        $config = $this->wire('config');
        $adminRootPageID = (int) $config->adminRootPageID;
        $http404ID = $config->http404PageID;
        if($base === '') $base = "has_parent!=$adminRootPageID, include=all, template!=admin, id!=$http404ID, template!=http404";

        $startId = (int) $in->post('rag_start_id');
        if($startId < 0) $startId = 0;

        $batch = (int) $in->post('rag_batch_size');
        if($batch < 50) $batch = 50;
        if($batch > 1000) $batch = 1000;

        return [
            'dry' => $dry,
            'base_selector' => $base,
            'start_id' => $startId,
            'batch_size' => $batch,
        ];
    }

    protected function buildRagSelector(string $baseSelector, int $startId, int $batchSize): string {
        $s = trim($baseSelector);

        // Strip a few common disallowed parts if pasted in anyway.
        $s = preg_replace('/\b(?:sort|limit|start|id)\s*([=!<>]=?|~)\s*[^,]+/i', '', $s);
        $s = trim(preg_replace('/\s*,\s*/', ', ', trim($s, " \t\n\r\0\x0B,")));

        $config = $this->wire('config');
        $adminRootPageID = (int) $config->adminRootPageID;
        $http404ID = $config->http404PageID;
        if($s === '') $s = "has_parent!=$adminRootPageID, include=all, template!=admin, id!=$http404ID, template!=http404";;

        if($startId > 0) $s .= ", id>$startId";
        $s .= ", sort=id, limit=$batchSize";

        return $s;
    }

    public function ___execute()
    {
        if (!$this->wire('user')->hasPermission('chatai')) {
            throw new WirePermissionException();
        }

        $input  = $this->wire('input');

        $api = $input->get->text('api');

        if ($api === 'volumeData') {
            header('Content-Type: application/json; charset=utf-8');
            echo $this->renderVolumeDataJson();
            exit;
        }

        if ($api === 'insights') {
            header('Content-Type: application/json; charset=utf-8');
            echo $this->renderInsightsJson();
            exit;
        }

        if ($api === 'obslogExport') {
            $this->renderObslogCsv();
            exit;
        }

        if ($api === 'kpiSnapshot') {
            header('Content-Type: application/json; charset=utf-8');
            echo $this->renderKpiSnapshotJson();
            exit;
        }

        $this->wire('modules')->get('JqueryWireTabs');
        $tabView = [];

        $this->headline('ChatAI');
        $modules = $this->wire('modules');

        $this->config->styles->add($this->config->urls->ProcessChatAI . 'ProcessChatAI.css');
        $this->config->scripts->add($this->config->urls->ProcessChatAI . 'ProcessChatAI.js');
        // Chart.js from CDN (simple and proven)
        $this->config->scripts->add('https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js');


        $svc = $this->chatai->promptService();
        $cfg = $svc->loadPromptSettings();


        $form = $modules->get('InputfieldForm');
        $form->attr('name+id', $this->formName);

        // Build each tab fieldset and add to form
        foreach ($this->tabs($tabView) as $key => $tab) {
            $out = $tab->build($form, $cfg);   // returns array
            $key = array_key_first($out);
            $tabView[$key] = $out[$key];
            $form = $out['form'];
        }

        // Handle prune obslog days
        if($input->post->submit_prune_obslog) {
            $raw = trim((string) $input->post->prune_retain_days);
            if($raw === '') {
                $this->error($this->_('Please enter the number of days to retain.'));
                $this->wire('session')->redirect('./');
            }
            $days = (int) $raw;
            if($days < 1) {
                $this->error($this->_('Retain days must be at least 1.'));
                $this->wire('session')->redirect('./');
            }
            if($days > 3650) $days = 3650;
            $deleted = $this->pruneObslogRetainDays($days);
            $this->message(sprintf(
                $this->_('Pruned %d observation log entries older than %d days.'),
                $deleted,
                $days
            ));
            $this->wire('session')->redirect('./');
        }


        // Handle "Run Backfill & Reconcile" for vector db
        if($this->wire('input')->post('rag_run_reindex')) {
            $opts = $this->getRagReindexOptionsFromPost();
            $selector = $this->buildRagSelector($opts['base_selector'], $opts['start_id'], $opts['batch_size']);
            $t0 = microtime(true);
            $summary = $this->runBackfillReconcile($opts['dry'], $selector);
            $summary['latency_ms'] = (int) round((microtime(true) - $t0) * 1000);

            $this->message($this->_('Re-index & Reconcile complete.') . ' ' . json_encode($summary));
            $dryRun = $opts['dry'];

            $this->actionReindexAll($selector);
        }

        // Submit button
        $submit = $this->modules->get('InputfieldSubmit');
        $submit->attr('value', $this->_('Save'));
        $submit->header = true;
        $form->add($submit);

        if($form->isSubmitted()) {
            $inputPost = $this->wire('input')->post;

            $inputProcessed = true;
            foreach($form->children as $tab) {
                if(!$tab->processInput($inputPost)) {
                    $inputProcessed = false;
                    break;
                }
            }
            if ($inputProcessed ) {
                $values = [];
                foreach ($inputPost as $key => $value) {
                    if($key === '' || $key === 'submit' || $key === '_InputfieldForm' || str_starts_with($key, 'TOKEN')) continue;
                    $values[$key] = $value;
                }
                $cfg = $this->chatai->promptService()->loadPromptSettings();

                $values['index_version'] = isset($cfg['index_version']) ? $cfg['index_version'] + 1 : 1;
                $values['rag_candidate_templates'] = $this->chatai->asmToIds($values['rag_candidate_templates'] ?? []);
                $values['rag_exclude_templates'] = $this->chatai->asmToIds($values['rag_exclude_templates'] ?? []);

                $this->_promptMemo = $values;
                $this->chatai->promptService()->savePromptSettings($this->_promptMemo);

                $prefixes = $this->classifier->dictionaryPrefixes();

                $shouldBump = false;

                // Check both direct keys and suffixed keys: prefix and prefix_*
                foreach ($prefixes as $p) {
                    // direct key
                    if (array_key_exists($p, $values) && (string)($cfg[$p] ?? '') !== (string)$values[$p]) {
                        $shouldBump = true;
                        break;
                    }

                    // suffixed keys: scan new values for prefix_*
                    foreach ($values as $k => $v) {
                        if ($k === $p || str_starts_with((string)$k, $p . '_')) {
                            if ((string)($cfg[$k] ?? '') !== (string)$v) {
                                $shouldBump = true;
                                break 2;
                            }
                        }
                    }
                }


                // If bump needed, bump using indexer helper and bust old cache
                if ($shouldBump) {
                    $oldVer = $this->indexer->getIndexVersion();
                    $this->indexer->bumpIndexVersion(); // updates stored prompt settings
                    if ($oldVer) $this->wire('cache')->deleteFor('chatai', "dict:v{$oldVer}:all");
                }

                // Reload prompt settings so we do not overwrite index_version (and anything else updated by bump)
                $cfg2 = (array) $this->chatai->promptService()->loadPromptSettings();

                // Merge: start from stored cfg, then overlay the posted values (except you can skip index_version entirely)
                unset($values['index_version']);
                $merged = array_merge($cfg2, $values);

                $this->_promptMemo = $merged;
                $this->chatai->promptService()->savePromptSettings($this->_promptMemo);

            } else {
//                $errors = $form->getErrors(); // array of error messages…
                $inputs = $form->getErrorInputfields(); // …or array of Inputfields with errors
                $text = "<h3 class='error'>" .$this->_('Your form has errors. Please fix') . "</h3>\n";
                return $text . $form->render();
            }
        }
        return $form->render();
    }

    public function addTab($id, $label, $wrapper = null)
    {
        $this->tabs[$id] = $label;
        if($wrapper) $wrapper->addClass('WireTab');
    }


    public function getValues($form) : array
    {
        //$savedData = $this->chatai->promptService->loadPromptSettings();
        $svc = $this->chatai->promptService();
        $savedData = $svc->loadPromptSettings();
        if(!empty($savedData)) return $savedData;

        // OK, nothing in the database.
        // Populate the values with the defaults

        $user = $this->wire('user');
        $data = [];
        $skipTypes = array(
            'InputfieldMarkup',
            'InputfieldSubmit',
        );

        foreach($form->children as $tab) {
            if(in_array($tab->className(),$skipTypes)) continue;
            $inputfieldsArray = $tab->getAll();

            foreach($inputfieldsArray as $tabField) {
                $fldName = $tabField->attributes['name'] ?? '';
                if ($fldName === '' || $fldName === 'submit' || $fldName === '_InputfieldForm' || str_starts_with($fldName, 'TOKEN')) continue;
                if ($user->language->isDefault() || empty($tabField->useLanguages)) {
                    $data[$fldName] = $form->getValueByName($fldName);
                } else {
                    $data[$fldName] = !empty($tabField->getLanguageValue($user->language))
                        ? $tabField->getLanguageValue($user->language)
                        : $form->getValueByName($fldName);
                }
            }
        }
        $this['values'] = $data;
        return $data;
    }

 /*   private function _savePromptSettingsJson(string $json): bool {
        $chatai = $this->chatai;
        $db = wire('database'); // WireDatabasePDO (PDO)
        $table = $chatai::dbTablePrompt;

