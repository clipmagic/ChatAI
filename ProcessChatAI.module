    public function loadPromptSettings(): array {
        return $this->chatai->promptService()->loadPromptSettings();
    }


    public function getPrompt(): string {
        return $this->chatai->promptService()->getPrompt();
    }

    public function getIntro(): string {
        return $this->chatai->promptService()->getIntro();
    }

