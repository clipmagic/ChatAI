    /**
     * @param array $messagesForApi
     * @return stdClass
     * @throws WireException
     */
    public function callModelForText(array $messagesForApi): \stdClass
    {
        return $this->modelClient()->call(
            $messagesForApi,
            (string) ($this->agenttools_model_id ?? ""),
            [
                "max_tokens" => (int) ($this->max_completion_tokens ?? 1000),
                "reasoning_effort" => (string) ($this->reasoning_effort ?? ""),
                "verbosity" => (string) ($this->verbosity ?? ""),
                "timeout" => (int) ($this->llm_timeout ?? 25),
            ],
        );
    }

    /**
     * @param string $msg
     * @param int|null $langId
     * @param array $cfg
     * @return bool
     */
    protected function isCurrentPageRef(
        string $msg,
        ?int $langId,
        array $cfg,
    ): bool {
        $key = $langId ? "current_page_refs__{$langId}" : "current_page_refs";
        $list = (string) ($cfg[$key] ?? ($cfg["current_page_refs"] ?? ""));
        if ($list === "") {
            return false;
        }

        $msg = mb_strtolower(trim($msg));

        foreach (explode(",", $list) as $ref) {
            $ref = mb_strtolower(trim($ref));
            if ($ref === "") {
                continue;
            }
            if (mb_strpos($msg, $ref) !== false) {
                return true;
            }
        }
        return false;
    }

    /**
     * @param string $msg
     * @param int|null $langId
     * @param array $cfg
     * @param int $pageId
     * @return string
     */
    protected function getRetrievalScope(
        string $msg,
        ?int $langId,
        array $cfg,
        int $pageId,
    ): string {
        if ($pageId > 0 && $this->isCurrentPageRef($msg, $langId, $cfg)) {
            return "page";
        }

        return "site";
    }

    /**
     * @param string $label
     * @param string $scope
     * @param callable $cfgLang
     * @return string
     */
    protected function buildNoContextReply(
        string $label,
        string $scope,
        callable $cfgLang,
    ): string {
        if ($label === "no_access") {
            return $cfgLang("no_access_reply") ?:
                "I’m sorry, I don’t have access to the page. Please ask me something else about this site.";
        }

        if ($scope === "page") {
            if ($label === "meta") {
                return $cfgLang("meta_reply") ?:
                    "I can help with information from this page. What would you like to know about it?";
            }

            if ($label === "ambiguous") {
                if ($follow = $cfgLang("followup_reply")) {
                    return $follow;
                }

                return $cfgLang("no_context_reply") ?:
                    "I couldn’t find that on this page. What part of this page would you like me to check?";
            }

            return $cfgLang("no_context_reply") ?:
                "I couldn’t find that on this page. What would you like me to look for here?";
        }

        if ($label === "meta") {
            return $cfgLang("meta_reply") ?:
                $cfgLang("no_context_reply") ?:
                "I can help with pages and information on this site. Ask me what you’re looking for.";
        }

        if ($label === "ambiguous") {
            if ($follow = $cfgLang("followup_reply")) {
                return $follow;
            }

            return $cfgLang("no_context_reply") ?:
                "Tell me what you’re looking for and I’ll point you to the right page.";
        }

        return $cfgLang("no_context_reply") ?:
            "I couldn’t find a relevant page on this site. What would you like me to look for?";
    }

    /**
     * @param array $payload
     * @return array|false[]
     * @throws WireException
     * @throws WirePermissionException
     */
    protected function handleUrlsInPayload(array &$payload): array
    {
        $config = $this->wire("config");
        $pages = $this->wire("pages");

        $msg = (string) ($payload["msg"] ?? "");
        $pid = (int) ($payload["pageId"] ?? 0);

        // Allowed hosts (PW convention)
        $httpHosts = is_array($config->httpHosts)
            ? $config->httpHosts
            : [$config->httpHost];

        $allowedHosts = array_values(
            array_filter(
                array_map(function ($h) {
                    $h = strtolower(trim((string) $h));
                    return $h !== "" ? $h : null;
                }, $httpHosts),
            ),
        );

        // Extract URLs
        if (!preg_match_all('~https?://[^\s<>"\'\)\]]+~i', $msg, $m)) {
            return ["blocked" => false, "has_url" => false];
        }

        $urls = $m[0] ?? [];
        if (!$urls) {
            return ["blocked" => false, "has_url" => false];
        }

        $firstOnSiteUrl = null;

        foreach ($urls as $u) {
            $host = strtolower((string) parse_url($u, PHP_URL_HOST));
            if ($host !== "" && in_array($host, $allowedHosts, true)) {
                $firstOnSiteUrl = $u;
                break; // accept first on-site URL
            }
        }

        if (!$firstOnSiteUrl) {
            // URLs were present, none were on-site
            return [
                "blocked" => true,
                "has_url" => true,
                "reason" => "no_onsite_url",
            ];
        }

        // We have at least one on-site URL; optionally resolve to pageId
        if ($pid < 1) {
            $p = $pages->get($firstOnSiteUrl);
            if ($p && $p->id && $p->viewable()) {
                $payload["pageId"] = (int) $p->id;
            }
        }

        return [
            "blocked" => false,
            "has_url" => true,
            "onsite_url" => $firstOnSiteUrl,
        ];
    }

    /**
     * @param string $userMessage
     * @param int|null $langId
     * @param int|null $pid
     * @param string|null $url
     * @param array $meta
     * @return array
     * @throws WireException
     */
    protected function buildSendContext(
        string $userMessage,
        ?int $langId = null,
        ?int $pid = null,
        ?string $url = null,
        array $meta = [],
    ): array {
        $san = $this->wire("sanitizer");
        $user = $this->wire("user");

        $result = (object) [
            "stop" => false,
            "error" => null,
            "reply" => null,
            "html" => null,
            "blacklisted" => false,
            "name" => null,
        ];

        $msg = $san->text($userMessage);
        $langId = $langId !== null ? (int) $san->int($langId) : null;
        if ($langId < 1) {
            $langId = null;
        }

        $pid = $pid !== null ? (int) $san->int($pid) : 0;
        if ($pid < 1) {
            $pid = 0;
        }

        $url = $url !== null ? (string) $san->url($url) : "";

        $payload = [
            "status" => "ok",
            "openai_error" => null,
            "msg" => $msg,
            "reply" => null,
            "error" => null,
            "pageId" => $pid,
            "langId" => $langId,
            "url" => $url,
        ];

        return [
            "msg" => $msg,
            "langId" => $langId,
            "pid" => $pid,
            "url" => $url,
            "meta" => $meta,
            "payload" => $payload,
            "result" => $result,
            "user" => $user,
        ];
    }

    /**
     * @param int|null $langId
     * @return void
     */
    protected function applyLanguageContext(?int $langId): void
    {
        if ($langId === null) {
            return;
        }

        try {
            $languages = $this->wire("languages");
            if ($languages && $langId) {
                $lang = $languages->get($langId);
                if ($lang && $lang->id) {
                    $languages->setLanguage($lang);
                }
            }
        } catch (\Throwable $e) {
            /* ignore */
        }
    }

    /**
     * @param array $ctx
     * @return stdClass|null
     * @throws WireException
     * @throws WirePermissionException
     */
    protected function handleLocalFlow(array &$ctx): ?\stdClass
    {
        $msg = $ctx["msg"];
        $payload = &$ctx["payload"];
        $result = $ctx["result"];

        $result->name = $this->promptService()->getBotName();
        $result = $this->isMessageAllowed($msg);

        $urlCheck = $this->handleUrlsInPayload($payload);
        if (!empty($urlCheck["blocked"])) {
            $result->error = $this->getErrorMessage(16);
            $payload["status"] = "blocked";
            $payload["reply"] = $result->error->msg;
            return $this->handleCTA($payload, $result);
        }

        if ($result && $result->error) {
            $payload["status"] = "not_allowed";
            $payload["error"] = $result->error;
            return $this->handleCTA($payload, $result);
        }

        $svc = $this->promptService();
        $decision = $this->classifier->classify($msg);
        $cfg = $svc->loadPromptSettings();
        $userLangId = (int) ($ctx["user"]->language->id ?? 0);

        $cfgLang = function (string $key) use ($cfg, $userLangId) {
            $k = $key . "__" . $userLangId;
            return (string) ($cfg[$k] ?? ($cfg[$key] ?? ""));
        };

        $ctx["svc"] = $svc;
        $ctx["decision"] = $decision;
        $ctx["cfg"] = $cfg;
        $ctx["userLangId"] = $userLangId;
        $ctx["cfgLang"] = $cfgLang;

        $label = (string) ($decision["label"] ?? "");

        if ($label === "small_talk") {
            $result->reply =
                $cfgLang("smalltalk_reply") ?:
                "Hello. How can I help you today?";
            $payload["status"] = $label;
            $payload["reply"] = $result->reply;
            return $this->handleCTA($payload, $result);
        }

        if ($label === "blocked_action") {
            $result->reply =
                $cfgLang("blocked_action_verbs_reply") ?:
                "I’m sorry. I can’t do that. Please ask me something else about this site.";
            $payload["status"] = $label;
            $payload["reply"] = $result->reply;
            return $this->handleCTA($payload, $result);
        }

        $ctx["result"] = $result;
        return null;
    }

    /**
     * @param array $ctx
     * @return stdClass|null
     * @throws WireException
     * @throws WirePermissionException
     */
    protected function prepareRetrieval(array &$ctx): ?\stdClass
    {
        $msg = $ctx["msg"];
        $langId = $ctx["langId"];
        $pid = $ctx["pid"];
        $payload = &$ctx["payload"];
        $result = $ctx["result"];
        $cfg = $ctx["cfg"];
        $cfgLang = $ctx["cfgLang"];
        $decision = $ctx["decision"];
        $user = $ctx["user"];

        $label = (string) ($decision["label"] ?? "");
        $ragLangId = $langId ?? 0;
        $k = 6;
        $retrievalScope = $this->getRetrievalScope($msg, $langId, $cfg, $pid);

        if ($retrievalScope === "page") {
            $p = $this->wire("pages")->get((int) $pid);
            if ($p && $p->id && !$this->rag->shouldIndexPage($p, $cfg)) {
                $label = "no_access";
                $top = [];
            }
        }

        if (!isset($top)) {
            if ($retrievalScope === "page") {
                $top = $this->rag->retrieveTopKForPage(
                    $msg,
                    $ragLangId,
                    $pid,
                    $k,
                    60,
                    $user,
                );
            } else {
                $top = $this->rag->retrieveTopK(
                    $msg,
                    $ragLangId,
                    $k,
                    60,
                    $user,
                );
            }
        }

        $this->wire("log")->save(
            "chatai",
            "retrieval scope={$retrievalScope} label={$label} pid=" . (int) $pid,
        );

        if (empty($top)) {
            $result->reply = $this->buildNoContextReply(
                $label,
                $retrievalScope,
                $cfgLang,
            );
            $payload["status"] = $label;
            $payload["replyText"] = $result->reply;
            return $this->handleCTA($payload, $result);
        }

        $ctx["label"] = $label;
        $ctx["retrievalScope"] = $retrievalScope;
        $ctx["top"] = $top;
        $ctx["context"] = $this->rag->buildContextFromChunks($top);
        $ctx["result"] = $result;

        return null;
    }

    /**
     * @param array $ctx
     * @param array $messages
     * @param array $credit
     * @return array
     * @throws WireException
     */
    protected function executeModelRequest(array &$ctx, array $messages, array $credit): array
    {
        $msg = $ctx["msg"];
        $result = $ctx["result"];
        $userLangId = $ctx["userLangId"];
        $payload = &$ctx["payload"];

        $started = microtime(true);

        try {
            $messages = $this->beforeSend($messages);
            $modelResult = $this->callModelForText($messages);
            $modelResult = $this->normaliseResponse($modelResult);
            $modelResult = $this->afterSend($modelResult);

            if (!empty($modelResult->cutoff)) {
                $result->cutoff = true;
                $result->error = $this->getErrorMessage(20);
            }

            $ph = $this->previewAndHash((string) $msg);
            $event = !empty($result->cutoff) ? "cutoff" : "reply";

            $meta = [
                "event" => $event,
                "chat_id" => $this->getCurrentChatId(),
                "latency_ms" => (int) round(
                    (microtime(true) - $started) * 1000,
                ),
                "count" => (int) ($credit["count"] ?? 0),
                "remaining" => (int) ($credit["remaining"] ?? 0),
                "max_messages" => (int) ($credit["max"] ?? 0),
                "stop" => false,
                "lang_id" => (int) ($userLangId ?? 0),
                "model" => (string) ($modelResult->model ?? $this->modelClient()->selectedLabel((string) ($this->agenttools_model_id ?? ""))),
                "endpoint" => (string) ($modelResult->endpoint ?? ""),
                "cutoff" => !empty($result->cutoff),
                "input_tokens" => (int) ($modelResult->input_tokens ?? 0),
                "output_tokens" => (int) ($modelResult->output_tokens ?? 0),
                "user_msg_preview" => $ph["preview"],
                "user_msg_hash" => $ph["hash"],
            ];

            if (empty($modelResult->ok)) {
                $meta["err_code"] = !empty($modelResult->error)
                    ? (string) $modelResult->error
                    : "unknown";
            } else {
                $meta["stop"] = (bool) $result->stop;

                $answerSource =
                    $result->html ?? ($result->reply ?? ($modelResult->text ?? ""));
                $meta["answer_len"] = strlen(
                    (string) strip_tags((string) $answerSource),
                );
            }

            $this->obsLog($modelResult, $meta);

            $ctx["result"] = $result;
            $ctx["payload"] = $payload;

            return [
                "model" => $modelResult,
                "meta" => $meta,
            ];
        } catch (\Throwable $e) {
            $this->wire("log")->save(
                "chatai",
                "sendMessage model error: " . $e->getMessage(),
            );

            $meta = [
                "err_code" => "exception",
            ];

            return [
                "model" => (object) ["ok" => false, "error" => "exception"],
                "meta" => $meta,
            ];
        }
    }

    /**
     * @param array $ctx
     * @param stdClass $modelResult
     * @param array $credit
     * @return stdClass
     * @throws WireException
     */
    protected function finaliseSuccessfulResponse(
        array &$ctx,
        \stdClass $modelResult,
        array $credit,
    ): \stdClass {
        $result = $ctx["result"];
        $payload = &$ctx["payload"];
        $session = $this->wire("session");
        $hist = $session->getFor("chatai", "history") ?? [];

        $raw = (string) $modelResult->text;

        $allowed = trim(
            (string) ($this["values"]["allowed_tags"] ??
                "p,ul,li,ol,strong,em,code,br,a[href]"),
        );

        if (preg_match('/(^|,)\\s*a(\\s*,|$)/i', $allowed)) {
            $allowed = preg_replace(
                '/(^|,)\\s*a(\\s*,|$)/i',
                '$1a[href]$2',
                $allowed,
            );
        }

        $allowed = implode(
            ",",
            array_filter(array_map("trim", explode(",", $allowed))),
        );

        $result->html = $this->wire("sanitizer")->purify($raw, [
            "HTML.Allowed" => $allowed,
        ]);

        $plain = trim(strip_tags($raw));
        $result->reply = $this->wire("sanitizer")->entities($plain);

        if ($plain !== "") {
            $hist[] = ["role" => "assistant", "content" => $plain];
            $session->setFor("chatai", "history", array_slice($hist, -6));
        }

        if (
            empty($result->cutoff) &&
            isset($credit["remaining"]) &&
            (int) $credit["max"] > 0
        ) {
            $remaining = (int) $credit["remaining"];

            if ($remaining === 1) {
                if (empty($result->stop)) {
                    $result->error = $this->getErrorMessage(10);
                    $result->stop = false;
                }
            } elseif ($remaining === 0) {
                $result->error = $this->getErrorMessage(4);
                $result->stop = true;
                $payload["status"] = "cutoff";
                $payload["error"] = $result->error;
            }
        }

        $payload["reply"] = $result->reply;
        $ctx["result"] = $this->handleCTA($payload, $result);

        return $ctx["result"];
    }

    /**
     * @param string $userMessage
     * @param int|null $langId
     * @param int|null $pid
     * @param string|null $url
     * @param array $meta
     * @return stdClass
     * @throws WireException
     * @throws WirePermissionException
     */
    public function sendMessage(
        string $userMessage,
        ?int $langId = null,
        ?int $pid = null,
        ?string $url = null,
        array $meta = [],
    ): \stdClass {
        $ctx = $this->buildSendContext($userMessage, $langId, $pid, $url, $meta);
        $msg = $ctx["msg"];
        $langId = $ctx["langId"];
        $pid = $ctx["pid"];
        $url = $ctx["url"];
        $payload = &$ctx["payload"];
        $result = $ctx["result"];

        $this->applyLanguageContext($langId);

        if ($early = $this->handleLocalFlow($ctx)) {
            return $early;
        }

        $svc = $ctx["svc"];
        $userLangId = $ctx["userLangId"];
        $messages = [];

        $session = $this->wire("session");
        $system = $session->getFor("chatai", "system_prompt");
        if (!$system) {
            $system = ["role" => "system", "content" => $svc->getPrompt()];
            $session->setFor("chatai", "system_prompt", $system);
        }
        $messages[] = ["role" => "system", "content" => $system];

        if ($retrieval = $this->prepareRetrieval($ctx)) {
            return $retrieval;
        }

        $context = $ctx["context"];

        // optional: add RAG context as an extra system message if you built it
        $hist = $session->getFor("chatai", "history") ?? [];
        $hist[] = ["role" => "user", "content" => $msg];
        $hist = array_slice($hist, -6); // keep last ~6 entries total
        $session->setFor("chatai", "history", $hist);
        if (!empty($context)) {
            $messages[] = [
                "role" => "system",
                "content" => "Site context:\n" . $context,
            ];
        }
        foreach ($hist as $h) {
            $messages[] = $h;
        }

        // User message last
        $messages[] = ["role" => "user", "content" => $msg];

        // Message limit: only applies to OpenAI calls
        $credit = $this->consumeMessageCredit();
        if (!empty($credit["blocked"])) {
            $result->error = $this->getErrorMessage(4); // reached limit
            $result->stop = true;
            // Optional CTA
            $payload["status"] = "blocked";
            $payload["error"] = $result->error;
            $payload["reply"] = $result->reply;
            $result = $this->handleCTA($payload, $result);
            return $result;
        }

        $exec = $this->executeModelRequest($ctx, $messages, $credit);
        $m = $exec["model"];
        $meta = $exec["meta"];
        $result = $ctx["result"];

        // Interpret (single exit point)
        if (empty($m->ok)) {
            return $this->handleModelError($m, $result, $payload, $meta);
        }

        return $this->finaliseSuccessfulResponse($ctx, $m, $credit);
    }

    /**
     * @param $ctx
     * @param $data
     * @return void
     */
    protected function handleResponse($ctx, $data) {}

    /**
     * @param $m
     * @return stdClass
     */
    protected function normaliseResponse($m): \stdClass
    {
        $type = gettype($m);

        switch ($type) {
            case "string":
                // JSON string response
                $decoded = json_decode($m, false); // decode as object
                return $decoded instanceof \stdClass ? $decoded : (object) [];

            case "array":
                // Associative array -> object
                return (object) $m;

            case "object":
                // Already what we want
                return $m instanceof \stdClass ? $m : (object) $m;

            case "NULL":
                return (object) [];

            case "boolean":
            case "integer":
            case "double":
                // Unexpected primitive; preserve value for debugging
                return (object) ["value" => $m];

            default:
                // Resources or anything truly odd
                return (object) [];
        }
    }

    /**
     * @param stdClass $m
     * @param stdClass $result
     * @param array $payload
     * @param array $meta
     * @return stdClass
     */
    protected function handleModelError(
        \stdClass $m,
        \stdClass $result,
        array $payload,
        array $meta,
    ): \stdClass {
        $code = "";
        if (!empty($meta["err_code"])) {
            $code = (string) $meta["err_code"];
        } elseif (!empty($m->error)) {
            $code = (string) $m->error;
        } else {
            $code = "unknown";
        }

        // Normalize provider “too busy / quota / throttled” signals to case 15
        if (
            in_array(
                $code,
                [
                    "rate_limit_exceeded",
                    "rate_limit",
                    "insufficient_quota",
                    "throttled",
                ],
                true,
            )
        ) {
            $result->error = $this->getErrorMessage(15); // object with msg + warning
            $result->stop = false;

            $payload["status"] = $code;
            $payload["reply"] = (string) ($result->reply ?? "");
            $payload["error"] = $result->error;

            return $this->handleCTA($payload, $result);
        }

        // Everything else → generic failure (case 6)
        $result->error = $this->getErrorMessage(6); // object with msg + warning
        $result->stop = true;

        $payload["status"] = "failed";
        $payload["reply"] = (string) ($result->reply ?? "");
        $payload["error"] = $result->error;

        return $this->handleCTA($payload, $result);
    }

    /**
     * @param array $payload
     * @param stdClass $result
     * @return stdClass
     */
    protected function handleCTA(array $payload, \stdClass $result)
    {
        $cta = $this->afterResponse($payload);
        // if original $payload array returned, hook not used
        if (is_string($cta)) {
            $cta = trim((string) $cta);
            if ($cta !== "") {
                $result->cta = $cta;
            }
        }
        return $result;
    }

    /** helper stubs  */

    protected function consumeMessageCredit(): array
    {
        $session = $this->wire("session");
        $max = (int) $this->max_messages;

        if ($max <= 0) {
            return [
                "blocked" => false,
                "max" => 0,
                "count" => 0,
                "remaining" => 0,
            ];
        }

        $count = (int) ($session->getFor("chatai", "count") ?? 0);

        if ($count >= $max) {
            return [
                "blocked" => true,
                "max" => $max,
                "count" => $count,
                "remaining" => 0,
            ];
        }

        $count++;
        $session->setFor("chatai", "count", $count);

        return [
            "blocked" => false,
            "max" => $max,
            "count" => $count,
            "remaining" => max(0, $max - $count),
        ];
    }

    /**
     * @return ChatAIObsLog
     */
    public function getObsLog(): \ProcessWire\ChatAIObsLog
    {
        return $this->logger;
    }

    /**
     * @return ChatAIModelClient
     */
    public function modelClient(): \ProcessWire\ChatAIModelClient
    {
        return $this->modelClient;
    }

    // logs one compact event to chatai_obslog

    /**
     * @param $result
     * @param array $meta
     * @return void
     */
    protected function obsLog($result, array $meta = []): void
    {
        $logger = $this->getObsLog();
        if (!$logger) {
            return;
        }

        // Delegate. ChatAI should not assemble obslog payloads.
        $logger->logFromResult($result, $meta);
    }

    /** @return array{preview:string, hash:string} */
    protected function previewAndHash(string $text, int $limit = 120): array
    {
        // Normalise to plain text
        if (class_exists("\ProcessWire\WireTextTools")) {
            $tt = new \ProcessWire\WireTextTools();
            $plain = $tt->markupToText($text);
        } else {
            $plain = strip_tags($text);
        }
        $plain = trim($plain);

        // Safe UTF-8
        if (!mb_detect_encoding($plain, "UTF-8", true)) {
            $plain = mb_convert_encoding($plain, "UTF-8", "UTF-8");
        }

        // Preview
        $preview = mb_substr($plain, 0, $limit);
        if (mb_strlen($plain) > $limit) {
            $preview .= "…";
        }

        // Hash can include knobs that affect semantics
        $hash = hash(
            "sha256",
            json_encode(
                [
                    "text" => $plain,
                    "model" => (string) ($this->agenttools_model_id ?? ""),
                    "lang" => (int) ($this->langId ?? 0),
                    "system" => (string) ($this->systemPrompt ?? ""),
                ],
                JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE,
            ),
        );

        return ["preview" => $preview, "hash" => $hash];
    }

    /**
     * @param $number
     * @param $val1
     * @param $val2
     * @return stdClass
     */
    public function getErrorMessage($number, $val1 = null, $val2 = null)
    {
        $errorMsg = new stdClass();
        switch ($number) {
            case 1: // blocked/blacklist
                $errorMsg->msg = $this->_("You have been blocked. Goodbye.");
                $errorMsg->warning = true;
                break;

            case 2: // empty input
                $errorMsg->msg = $this->_("No message submitted.");
                break;

            case 4: // limit reached
                $errorMsg->msg = $this->_("Too many questions. Goodbye.");
                $errorMsg->warning = true;
                break;

            case 5: // token budget (optional usage)
                $errorMsg->msg = $this->_("Insufficient OpenAI tokens");
                break;

            case 6: // generic model/transport failure
                $errorMsg->msg = $this->_(
                    "Ooops! Something went wrong. Please try again later.",
                );
                $errorMsg->warning = true;
                break;

            case 7: // rephrase
                $errorMsg->msg = $this->_("Please rephrase your question");
                break;

            case 9: // off-topic (unused)
                $errorMsg->msg = $this->_("Not blacklisted but off topic");
                break;

            case 10: // near-limit warning
                $errorMsg->msg = $this->_(
                    "You have one question left before I have to go. Make it a good one!",
                );
                $errorMsg->warning = true;
                break;

            case 11: // last question
                $errorMsg->msg = $this->_(
                    "This chat has reached its limit. Please start a new chat to continue.",
                );
                break;

            case 12: // unexpected API response structure
                $errorMsg->msg = $this->_("Unexpected API response structure.");
                break; //

            case 13: // lockout due to repeated inappropriate messages
                $errorMsg->msg = $this->_(
                    "You have been locked out due to repeated inappropriate messages.",
                );
                $errorMsg->warning = true;
                break;

            case 14: // rephrase with counters
                if (!empty($val1) && !empty($val2)) {
                    $template = $this->_(
                        "Please rephrase your question (Warning: %d/%d)",
                    );
                    $errorMsg->msg = sprintf($template, $val1, $val2);
                    $errorMsg->warning = true;
                } else {
                    $errorMsg->msg = $this->_("Please rephrase your question.");
                }
                break;

            case 15: // rate limited / busy (translatable)
                $errorMsg->msg = $this->_(
                    "We are a bit busy. Please try again shortly.",
                );
                $errorMsg->warning = true;
                break;

            case 16: // invalid URL(s) in message
                $errorMsg->msg = $this->_(
                    "I can only help with pages and information on this site. Please use a link from this site, or remove external links and try again.",
                );
                $errorMsg->warning = true;
                break;

            case 20: // too few tokens
                $errorMsg->msg = $this->_(
                    "This chat has reached its limit. Please start a new chat to continue.",
                );
                break;

            default:
                $errorMsg->msg = $this->_("Invalid message number: " . $number);
                break;
        }
        $errorMsg->number = $number;
        return $errorMsg;
    }

    /** Hookable Methods **/

    /** Hook: mutate outbound request before sending to the model. */
    /** @param array $messages */
    public function ___beforeSend(array $messages): array
    {
        return $messages;
    }

    /** Hook: inspect/mutate raw vendor response before normalisation. */
    /** @param array $rawResponse */
    public function ___afterSend(array|object $rawResponse): array|object
    {
        return $rawResponse; // no-op by default
    }

    /** Hook: last-mile payload tweak before returning JSON to the widget. */
    /** @param array $payload */
    public function ___afterResponse(array $payload): array
    {
        return $payload;
    }

    /**
     * Hook: provide an embedding vector for the given text.
     * Default implementation uses the configured OpenAI-compatible embedding settings.
     *
     * @throws WireException
     */
    public function ___embedText(string $text): array
    {
        $entry = $this->resolveEmbeddingModelEntry();
        $apiKey = trim((string) ($entry["key"] ?? ""));
        $endpoint = trim((string) ($entry["endpoint"] ?? ""));
        $model = trim((string) ($entry["model"] ?? ""));

        if ($apiKey === "") {
            throw new WireException("Embedding AgentTools model does not have an API key configured.");
        }
        if ($model === "") {
            throw new WireException("Embedding AgentTools model is not configured.");
        }
        if ($endpoint === "") {
            throw new WireException("Embedding AgentTools endpoint is not configured.");
        }

        $http = new WireHttp();
        $http->setHeader("Authorization", "Bearer " . $apiKey);
        $http->setHeader("Content-Type", "application/json");
        $payload = [
            "model" => $model,
            "input" => $text,
        ];

        $res = $http->post($endpoint, json_encode($payload));
        if (!$res) {
            throw new WireException("Embedding API error");
        }

        $json = json_decode($res, true);
        if (!isset($json["data"][0]["embedding"]) || !is_array($json["data"][0]["embedding"])) {
            throw new WireException("Invalid embedding response");
        }

        return $json["data"][0]["embedding"];
    }

    /**
     * @return array
     * @throws WireException
     */
    public function currentEmbeddingConfig(): array
    {
        $entry = $this->resolveEmbeddingModelEntry();
        $apiKey = trim((string) ($entry["key"] ?? ""));
        $endpoint = trim((string) ($entry["endpoint"] ?? ""));
        $model = trim((string) ($entry["model"] ?? ""));

        return [
            "provider" => (string) ($entry["provider"] ?? ""),
            "endpoint" => $endpoint,
            "model" => $model,
            "api_key_hash" => $apiKey !== "" ? hash("sha256", $apiKey) : "",
        ];
    }

    /**
     * @return string
     * @throws WireException
     */
    public function currentEmbeddingFingerprint(): string
    {
        return hash(
            "sha256",
            json_encode(
                $this->currentEmbeddingConfig(),
                JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE,
            ),
        );
    }

    /**
     * @param Page $page
     * @return bool
     */
    public function ___isEligibleForChat(Page $page): bool
    {
        // Default: do not change existing behaviour.
        // Developers can hook this to return false based on field values.
        return true;
    }

    /**
     * @return array
     * @throws WireException
     */
    protected function resolveEmbeddingModelEntry(): array
    {
        $modelId = (string) ($this->agenttools_embedding_model_id ?? "");
        $entry = $this->modelClient()->modelEntry($modelId);
        if (!$entry) {
            throw new WireException("Embedding AgentTools model is not available.");
        }

        return $entry;
    }

    /**
     * @param Page $p
     * @param array $cfg
     * @return bool
     */
    public function validTemplate(Page $p, array $cfg): bool
    {
        if (!$p->id) {
            return false;
        }

        $inclIds = array_map("intval", $cfg["rag_include_templates"] ?? []);
        $exclIds = array_map("intval", $cfg["rag_exclude_templates"] ?? []);

        $tplId = (int) $p->template->id;

        if ($exclIds && in_array($tplId, $exclIds, true)) {
            return false;
        }
        if ($inclIds && !in_array($tplId, $inclIds, true)) {
            return false;
        }

        // Optional per-page exclusion
        if (
            $p->hasField("chatai_exclude") &&
            (int) $p->get("chatai_exclude") === 1
        ) {
            return false;
        }

        return true;
    }

    /* Install, Upgrade, Uninstall */

    /**
     * @return void
     * @throws WireException
     */
    private static function _createDBTables()
    {
        $db = wire("database");

        $sql = <<<SQL

            -- Config / prompt JSON (used for \$cfg)
            CREATE TABLE IF NOT EXISTS chatai_prompt (
              id TINYINT UNSIGNED NOT NULL PRIMARY KEY DEFAULT 1,
              json LONGTEXT NOT NULL,
              created TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
              modified TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
            ) ENGINE=InnoDB
              DEFAULT CHARSET=utf8mb4
              COLLATE=utf8mb4_unicode_520_ci;

            -- Obs log: simple event logger for dashboard and stats
            CREATE TABLE IF NOT EXISTS chatai_obslog (
              id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
              chat_id VARCHAR(64) NOT NULL DEFAULT '',
              event_type VARCHAR(32) NOT NULL DEFAULT '',
              status VARCHAR(32) NOT NULL DEFAULT '',
              model VARCHAR(64) NOT NULL DEFAULT '',
              meta MEDIUMTEXT NULL,
              created TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
              PRIMARY KEY (id),
              KEY ix_created (created),
              KEY ix_chat (chat_id),
              KEY ix_event (event_type)
            ) ENGINE=InnoDB
              DEFAULT CHARSET=utf8mb4
              COLLATE=utf8mb4_unicode_520_ci;

            -- Vectors: RAG chunks (can be regenerated)
            DROP TABLE IF EXISTS chatai_vec_chunks;
            CREATE TABLE chatai_vec_chunks (
             id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
             page_id INT UNSIGNED NOT NULL,
             lang_id VARCHAR(16) NOT NULL DEFAULT '0',
             chunk_index INT UNSIGNED NOT NULL,
             source_url TEXT NULL,
             title VARCHAR(255) NULL,
             headings MEDIUMTEXT NULL,
             slug VARCHAR(255) NULL,
             text MEDIUMTEXT NOT NULL,
             embedding_csv LONGTEXT NOT NULL,
             created TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
             indexed_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
             PRIMARY KEY (id),
             KEY ix_page_lang (page_id, lang_id),
             KEY ix_page_indexed_at (page_id, indexed_at),
             FULLTEXT KEY ft_text (text)
            ) ENGINE=InnoDB
              DEFAULT CHARSET=utf8mb4;
        SQL;

        try {
            $db->query($sql);
        } catch (\Throwable $e) {
            wire("log")->save(
                "errors",
                "Failed to create ChatAI tables. " . $e->getMessage(),
            );
        }
    }

    /**
     * @return void
     * @throws WireException
     * @throws WirePermissionException
     */
    private function _createTemplate()
    {
        $templates = wire("templates");
        $files = wire("files");
        $config = wire("config");
        $pages = wire("pages");
        $fieldgroups = wire("fieldgroups");
        $modules = wire("modules");

        $apiTpl = $templates->get("name=chatai-api");
        if (!$apiTpl) {
            // Create fieldgroup
            $fieldgroup = new Fieldgroup();
            $fieldgroup->name = "chatai-api";
            $fieldgroup->add("title");

            // save fieldgroup
            $fieldgroups->save($fieldgroup);

            // get fieldgroup
            $fieldgroup = $fieldgroups->get("chatai-api");

            // Create template
            $template = new Template();
            $template->name = "chatai-api";
            $template->label = self::modName . " API Template";
            $template->fieldgroup = $fieldgroup;
            $template->filename = $config->paths->templates . "chatai-api.php";
            $template->noChildren = 1;
            $template->noParents = -1; // one page only
            $template->contentType = "json";
            $template->https = 1; // always only https
            $template->noAppendTemplateFile = 1; // disable auto-append of eg _main.php
            $template->noUnpublish = 1; // must always be published

            // save template
            $templates->save($template);
        }

        $templateFileExists = $files->exists(
            $config->paths->templates . "chatai-api.php",
        );
        if (!$templateFileExists) {
            $files->copy(
                $modules->siteModulesPath . self::modName . "/chatai-api.php",
                $config->paths->templates . "chatai-api.php",
            );
        }

        $apiPage = $pages->get("name=chatai-api");
        if ($apiPage instanceof NullPage) {
            $apiPage = new Page();
            $apiPage->name = "chatai-api";
            $apiPage->parent = 1;
            $apiPage->template = "chatai-api";
            $apiPage->of(false);
            $apiPage->title = self::modName . " API";
            $apiPage->status(["hidden", "published"]);
            $apiPage->save();
        }

    }

    /**
     * @return void
     * @throws WireException
     * @throws WirePermissionException
     */
    public function ___install(): void
    {
        self::_createDBTables();
        $this->_createTemplate();

        $permissions = $this->wire()->permissions;
        if (!$permissions->get("chatai")) {
            $p = new Permission();
            $p->name = "chatai";
            $p->title = "ChatAI administration";
            $permissions->add($p);
        }
    }

    /**
     * @return void
     * @throws WireException
     * @throws WirePermissionException
     */
    public function ___uninstall()
    {
        $database = wire("database");
        $pages = wire("pages");
        $templates = wire("templates");

        $sql = <<<SQL
                -- Drop the tables in dependency order (children first)
                DROP TABLE IF EXISTS chatai_prompt;
                DROP TABLE IF EXISTS chatai_obslog;
                DROP TABLE IF EXISTS chatai_vec_chunks;
        SQL;

        try {
            $database->query($sql);
        } catch (WireException $e) {
            wire("log")->save(
                "error",
                "Failed to delete ChatAI db tables. " . $e->getMessage(),
            );
        }

        $apiPage = $pages->get("name=chatai-api");
        if (!$apiPage instanceof NullPage) {
            $pages->delete($apiPage);
        }

        $apiTemplate = $templates->get("name=chatai-api");
        if ($apiTemplate) {
            $templates->delete($apiTemplate);
        }

        // clear anything in the cache
        $this->wire("cache")->deleteFor("chatai");
    }
}
