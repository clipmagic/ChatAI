<?php
/**
 * ProcessWire Chatbot Module - Core Functionality
 */

namespace ProcessWire;

use stdClass;

class ChatAI extends WireData implements Module, ConfigurableModule
{
    public const CHATAI_VEC_TABLE = "chatai_vec_chunks";

    const dbTableName = "chatai";

    const dbTablePrompt = "chatai_prompt";

    const modName = "ChatAI";

    /** @var \ProcessWire\RAG */
    protected ?\ProcessWire\RAG $rag = null;

    /** @var \ProcessWire\ChatAIIndexer */
    protected ?\ProcessWire\ChatAIIndexer $indexer = null;

    /** @var \ProcessWire\Classifier */
    protected ?\ProcessWire\Classifier $classifier = null;

    /** @var \ProcessWire\ChatAIObsLog */
    protected ?\ProcessWire\ChatAIObsLog $logger = null;

    protected ?\ProcessWire\ChatAIModelClient $modelClient = null;

    protected ?\ProcessWire\ChatAIPromptService $promptService = null;

    public function construct()
    {
        parent::__construct();
    }

    public function init()
    {
        // Load helpers
        require_once __DIR__ . "/classes/ChatAIModelClient.php";
        require_once __DIR__ . "/classes/Indexing/ChatAIIndexer.php";
        require_once __DIR__ . "/classes/RAG/RAG.php";
        require_once __DIR__ . "/classes/Classifier.php";
        require_once __DIR__ . "/classes/ChatAIObsLog.php";
        require_once __DIR__ . "/classes/ChatAIPromptService.php";

        // Shared services
        if ($this->rag === null) {
            $this->rag = new \ProcessWire\RAG();
            $this->rag->setWire($this->wire());
        }

        if ($this->indexer === null) {
            $this->indexer = new \ProcessWire\ChatAIIndexer();
            $this->indexer->setWire($this->wire());
        }

        if ($this->classifier === null) {
            $this->classifier = new \ProcessWire\Classifier();
            $this->classifier->setWire($this->wire());
        }

        if ($this->logger === null) {
            $this->logger = new \ProcessWire\ChatAIObsLog();
            $this->logger->setWire($this->wire());
        }

        if ($this->modelClient === null) {
            $this->modelClient = new \ProcessWire\ChatAIModelClient();
            $this->modelClient->setWire($this->wire());
        }

        if ($this->promptService === null) {
            $this->promptService = new \ProcessWire\ChatAIPromptService();
            $this->promptService->setWire($this->wire());
        }

        if ($this->wire("process") && !$this->modelClient()->modelEntry((string) ($this->agenttools_model_id ?? ""))) {
            $this->warning("AgentTools model missing; ChatAI model-backed replies may not function.");
        }

        // Hooks
        $this->addHookAfter("Pages::saved", function (HookEvent $event) {
            $page = $event->arguments(0);
            $changes = (array) ($event->arguments(1) ?? []);

            $cfg = (array) $this->promptService()->loadPromptSettings();
            if (empty($cfg["chunk_on_save"])) {
                return;
            }

            $changedKeys = array_keys($changes);
            $meaningfulKeys = array_diff($changedKeys, [
                "status",
                "modified",
                "template",
            ]);
            $contentChanged = !empty($meaningfulKeys);

            $this->processRagForPage($page, $cfg, [
                "mode" => "on_save",
                "contentChanged" => $contentChanged,
                "dryRun" => false,
            ]);
        });

        $this->addHookAfter("Pages::deleted", function ($event) {
            $page = $event->arguments(0);
            $rag = $this->rag();
            try {
                $rag->deletePageVectors($page);
            } catch (\Throwable $e) {
                $this->wire("log")->save(
                    "chatai",
                    "Index delete error: " . $e->getMessage(),
                );
            }
        });

        $this->addHookAfter("ImportPagesCSV::execute", function (
            HookEvent $event,
        ) {
            $svc = $this->promptService();
            $cfg = $svc->loadPromptSettings();
            if (!empty($cfg["chunk_on_save"])) {
                $ips = $event->object;
                $ips->warning(
                    $this->_(
                        'ChatAI "Update on Save" is currently enabled. For large imports, consider turning it off temporarily to avoid heavy re-indexing during import.',
                    ),
                );
            }
        });

        $this->addHookAfter("Languages::deleted", function (HookEvent $event) {
            $language = $event->arguments(0); // Page
            if (!$language || !$language->id) {
                return;
            }

            $langId = (int) $language->id;

            try {
                $this->rag()->deleteLanguageVectors($langId);
                $this->wire("log")->save(
                    "chatai",
                    "Deleted vectors for removed language lang_id={$langId}",
                );
            } catch (\Throwable $e) {
                $this->wire("log")->save(
                    "chatai",
                    "Language vector delete failed lang_id={$langId}: " .
                        $e->getMessage(),
                );
            }
        });
    }

    /* Hook functions */
    /**
     * @param Page $page
     * @param array $cfg
     * @param array $opts
     * @return array
     * @throws WireException
     */
    public function processRagForPage(
        Page $page,
        array $cfg,
        array $opts = [],
    ): array {
        $dryRun = !empty($opts["dryRun"]);
        $mode = (string) ($opts["mode"] ?? "bulk"); // 'on_save' | 'bulk'
        $contentChanged =
            $mode === "on_save" ? !empty($opts["contentChanged"]) : true;
        $forceRebuild = !empty($opts["forceRebuild"]); // bulk only: rebuild even if already in DB

        $out = [
            "page_id" => (int) $page->id,
            "eligible_now" => false,
            "deleted" => false,
            "indexed_new" => false,
            "indexed_replaced" => false,
            "skipped" => "",
            "error" => null,
        ];

        $rag = $this->rag();

        // Determine indexability now
        $isIndexableNow = $rag->shouldIndexPage($page, $cfg);

        // Optional site override
        if (
            $isIndexableNow &&
            method_exists($this, "isEligibleForChat") &&
            !$this->isEligibleForChat($page)
        ) {
            $isIndexableNow = false;
        }

        $out["eligible_now"] = $isIndexableNow;

        // If not indexable now, remove vectors and stop
        if (!$isIndexableNow) {
            if (!$dryRun) {
                try {
                    $rag->deletePageVectors($page);
                } catch (\Throwable $e) {
                    $out["error"] = $e->getMessage();
                    $this->wire("log")->save(
                        "chatai",
                        "RAG delete error, Page id {$page->id}: " .
                            $e->getMessage(),
                    );
                }
            }
            $out["deleted"] = true; // intent: should be deleted (or would be in dry run)
            $out["skipped"] = "not_indexable";
            return $out;
        }

        // On-save mode: only do work if meaningful content changed
        if ($mode === "on_save" && !$contentChanged) {
            $out["skipped"] = "no_content_change";
            return $out;
        }

        if ($mode === "bulk") {
            // Decide using DB facts, not policy
            $stats = $rag->getPageVectorStats($page->id);

            $hasVectors = !empty($stats["chunks"]);

            $indexedAtTs = 0;
            if (!empty($stats["indexed_at"])) {
                $indexedAtTs = strtotime($stats["indexed_at"]);
                if ($indexedAtTs === false) {
                    $indexedAtTs = 0;
                }
            }

            // Not indexed at all
            if (!$hasVectors) {
                if (!$dryRun) {
                    try {
                        $rag->collectPageText($page, $cfg);
                    } catch (\Throwable $e) {
                        $out["error"] = $e->getMessage();
                        $this->wire("log")->save(
                            "chatai",
                            "RAG index error, Page id {$page->id}: " .
                                $e->getMessage(),
                        );
                        return $out;
                    }
                }
                $out["indexed_new"] = true;
                return $out;
            }

            // Already indexed, and unchanged since last index, and no force rebuild
            if (
                !$forceRebuild &&
                $indexedAtTs > 0 &&
                (int) $page->modified <= $indexedAtTs
            ) {
                $out["skipped"] = "unchanged";
                return $out;
            }

            // Otherwise rebuild
            if (!$dryRun) {
                try {
                    $rag->deletePageVectors($page);
                    $rag->collectPageText($page, $cfg);
                } catch (\Throwable $e) {
                    $out["error"] = $e->getMessage();
                    $this->wire("log")->save(
                        "chatai",
                        "RAG rebuild error, Page id {$page->id}: " .
                            $e->getMessage(),
                    );
                    return $out;
                }
            }

            $out["indexed_replaced"] = true;
            return $out;
        }

        // On-save mode: rebuild (delete + collect)
        if (!$dryRun) {
            try {
                $rag->deletePageVectors($page);
                $rag->collectPageText($page, $cfg);
            } catch (\Throwable $e) {
                $out["error"] = $e->getMessage();
                $this->wire("log")->save(
                    "chatai",
                    "RAG upsert error, Page id {$page->id}: " .
                        $e->getMessage(),
                );
                return $out;
            }
        }

        $out["indexed_replaced"] = true;
        return $out;
    }

    /* Module functions */

    /* Class getters */

    /**
     * @return RAG
     */
    public function rag(): \ProcessWire\RAG
    {
        return $this->rag;
    }

    /**
     * @return ChatAIIndexer
     */
    public function indexer(): \ProcessWire\ChatAIIndexer
    {
        return $this->indexer;
    }

    /**
     * @return Classifier
     */
    public function classifier(): \ProcessWire\Classifier
    {
        return $this->classifier;
    }

    /**
     * @return ChatAIObsLog
     */
    public function logger(): \ProcessWire\ChatAIObsLog
    {
        return $this->logger;
    }

    /**
     * @return ChatAIPromptService
     */
    public function promptService(): \ProcessWire\ChatAIPromptService
    {
        return $this->promptService;
    }

    /**
     * Resolve the configured RAG view path for install/runtime fallback usage.
     *
     * @return string
     */
    protected function configuredRagViewPath(): string
    {
        $config = $this->wire('config');
        $moduleConfig = (array) $this->wire('modules')->getConfig(self::modName);
        $ragView = trim((string) ($moduleConfig['rag_view'] ?? ''));
        if($ragView === '') {
            $ragView = '/site/modules/ChatAI/classes/RAG/chatai-rag.php';
        }
        $root = rtrim((string) $config->paths->root, '/');
        if($root !== '' && $root[0] !== '/') {
            $root = '/' . $root;
        }
        $fullPath = $root . '/' . ltrim($ragView, '/');
        return realpath($fullPath) ?: $fullPath;
    }

    /**
     * @return string
     * @throws WireException
     */
    public function renderWidget(): string
    {
        return $this->promptService()->getWidget((string) $this->widget);
    }

    /**
     * @return string
     */
    public function renderStyles(): string
    {
        $css = "<link rel='stylesheet' href='$this->css' type='text/css'>";
        return $css;
    }

    /**
     * @return string
     */
    public function renderScript(): string
    {
        $js = "<script src='$this->js' ></script>";
        return $js;
    }

    /**
     * @param $message
     * @return stdClass
     * @throws WireException
     */
    public function isMessageAllowed($message): \stdClass
    {
        $session = $this->wire("session");

        $output = new \stdClass(); // optional: fully qualify
        $output->name = $this->promptService()->getBotName();
        $output->blacklisted = false;
        $output->stop = false;
        $output->error = null;
        $output->reply = null;
        $output->html = null;

        // Optional: resolve lang ID once for logging
        // so you do not depend on an external $langId variable.
        $langId = (int) ($this->wire("user")->language->id ?? 0);

        // Check message is not empty. Fallback from HTML check
        if ($message === "") {
            $output->error = $this->getErrorMessage(2);
            return $output;
        }

        // blacklist check
        $blacklistTerm = $this->promptService()->isBlacklistTerm($message);
        if (!$blacklistTerm) {
            return $output;
        }

        $strikes =
            (int) ($session->getFor("chatai", "blacklist_strikes") ?? 0) + 1;
        $session->setFor("chatai", "blacklist_strikes", $strikes);

        if ($strikes && $strikes >= $this->max_strikes) {
            $output->stop = true;
            $output->blacklistTerm = true;
            $output->blacklisted = true;
            $err = $this->getErrorMessage(13);

            // Log hard blacklist event with IP
            try {
                $ip = (string) $this->wire("input")->ip;

                $ph = $this->previewAndHash((string) $message);

                $meta = [
                    "event" => "blocked",
                    "chat_id" => $this->getCurrentChatId(),
                    "ip" => $ip,
                    "ip_hash" => hash("sha256", $ip),
                    "reason" => "blacklist",
                    "lang_id" => (int) ($langId ?? 0),
                    "user_msg_preview" => $ph["preview"],
                    "user_msg_hash" => $ph["hash"],
                ];

                $this->obsLog(["ok" => false, "error" => "blacklist"], $meta);
            } catch (\Throwable $e) {
                $this->wire("log")->save("chatai-obslog", $e->getMessage());
            }
        } else {
            $output->stop = false;
            $err = $this->getErrorMessage(14, $strikes, $this->max_strikes);
        }

        $output->error = $err;
        $output->reply = $err->msg;

        return $output;
    }

    /**
     * @return string
     * @throws WireException
     * @throws \Random\RandomException
     */
    protected function getCurrentChatId(): string
    {
        $session = $this->wire("session");

        $chatId = (string) $session->getFor("chatai", "chat_id");
        if (!$chatId) {
            // Short, opaque id; not user-identifying
            $chatId = bin2hex(random_bytes(8)); // 16 hex chars
            $session->setFor("chatai", "chat_id", $chatId);
        }

        return $chatId;
    }

