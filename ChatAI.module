    /* Hook functions */
    public function processRagForPage(Page $page, array $cfg, array $opts = []): array {

        $dryRun         = !empty($opts['dryRun']);
        $mode           = (string) ($opts['mode'] ?? 'bulk'); // 'on_save' | 'bulk'
        $contentChanged = ($mode === 'on_save') ? !empty($opts['contentChanged']) : true;
        $forceRebuild   = !empty($opts['forceRebuild']); // bulk only: rebuild even if already in DB

        $out = [
            'page_id'          => (int) $page->id,
            'eligible_now'     => false,
            'deleted'          => false,
            'indexed_new'      => false,
            'indexed_replaced' => false,
            'skipped'          => '',
            'error'            => null,
        ];


        $rag = $this->rag();

        // Determine indexability now
        $isIndexableNow = $rag->shouldIndexPage($page, $cfg);

        // Optional site override
        if($isIndexableNow && method_exists($this, 'isEligibleForChat') && !$this->isEligibleForChat($page)) {
            $isIndexableNow = false;
        }

        $out['eligible_now'] = $isIndexableNow;

        // If not indexable now, remove vectors and stop
        if(!$isIndexableNow) {
            if(!$dryRun) {
                try {
                    $rag->deletePageVectors($page);
                } catch(\Throwable $e) {
                    $out['error'] = $e->getMessage();
                    $this->wire('log')->save('chatai', "RAG delete error, Page id {$page->id}: " . $e->getMessage());
                }
            }
            $out['deleted'] = true; // intent: should be deleted (or would be in dry run)
            $out['skipped'] = 'not_indexable';
            return $out;
        }

        // On-save mode: only do work if meaningful content changed
        if($mode === 'on_save' && !$contentChanged) {
            $out['skipped'] = 'no_content_change';
            return $out;
        }

        if($mode === 'bulk') {

            // Decide using DB facts, not policy
            $stats = $rag->getPageVectorStats($page->id);

            $hasVectors = !empty($stats['chunks']);

            $indexedAtTs = 0;
            if(!empty($stats['indexed_at'])) {
                $indexedAtTs = strtotime($stats['indexed_at']);
                if($indexedAtTs === false) $indexedAtTs = 0;
            }

            // Not indexed at all
            if(!$hasVectors) {
                if(!$dryRun) {
                    try {
                        $rag->collectPageText($page, $cfg);
                    } catch(\Throwable $e) {
                        $out['error'] = $e->getMessage();
                        $this->wire('log')->save('chatai', "RAG index error, Page id {$page->id}: " . $e->getMessage());
                        return $out;
                    }
                }
                $out['indexed_new'] = true;
                return $out;
            }

            // Already indexed, and unchanged since last index, and no force rebuild
            if(!$forceRebuild && $indexedAtTs > 0 && (int)$page->modified <= $indexedAtTs) {
                $out['skipped'] = 'unchanged';
                return $out;
            }

            // Otherwise rebuild
            if(!$dryRun) {
                try {
                    $rag->deletePageVectors($page);
                    $rag->collectPageText($page, $cfg);
                } catch(\Throwable $e) {
                    $out['error'] = $e->getMessage();
                    $this->wire('log')->save('chatai', "RAG rebuild error, Page id {$page->id}: " . $e->getMessage());
                    return $out;
                }
            }

            $out['indexed_replaced'] = true;
            return $out;
        }

        // On-save mode: rebuild (delete + collect)
        if(!$dryRun) {
            try {
                $rag->deletePageVectors($page);
                $rag->collectPageText($page, $cfg);
            } catch(\Throwable $e) {
                $out['error'] = $e->getMessage();
                $this->wire('log')->save('chatai', "RAG upsert error, Page id {$page->id}: " . $e->getMessage());
                return $out;
            }
        }

        $out['indexed_replaced'] = true;
        return $out;
    }

    public function deleteLanguageVectors(int $langId): void {
        $db = $this->wire('database');
        $stmt = $db->prepare("DELETE FROM `" . self::CHATAI_VEC_TABLE . "` WHERE lang_id=?");
        $stmt->execute([$langId]);
    }

    /* Module functions */

    /* Class getters */

    public function rag(): \ProcessWire\RAG
    {
        return $this->rag;
    }

    public function indexer(): \ProcessWire\ChatAIIndexer
    {
        return $this->indexer;
    }

    public function classifer(): \ProcessWire\Classifier
    {
        return $this->classifier;
    }

    public function logger(): \ProcessWire\ChatAIObsLog
    {
        return $this->logger;
    }

    public function promptService(): \ProcessWire\ChatAIPromptService
    {
        return $this->promptService;
    }

    public function renderWidget() : string
    {
        $config = wire('config');
        $path = $config->paths->root . ltrim($this->widget, '/');
        return $this->promptService()->getWidget($path);
    }

    public function renderStyles() : string
    {
        $css = "<link rel='stylesheet' href='$this->css' type='text/css'>";
        return $css;
    }

    public function renderScript() : string
    {
        $js = "<script src='$this->js' ></script>";
        return $js;
    }

