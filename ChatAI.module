    public function isMessageAllowed($message) : \stdClass {
        $session     = $this->wire('session');

        $output = new \stdClass(); // optional: fully qualify
        $output->name        = $this->promptService()->getBotName();
        $output->blacklisted = false;
        $output->stop        = false;
        $output->error       = null;
        $output->reply       = null;
        $output->html        = null;

        // Optional: resolve lang ID once for logging
        // so you do not depend on an external $langId variable.
        $langId = (int) ($this->wire('user')->language->id ?? 0);

        // Check message is not empty. Fallback from HTML check
        if ($message === '') {
            $output->error = $this->getErrorMessage(2);
            return $output;
        }

        // blacklist check
        $blacklistTerm = $this->promptService()->isBlacklistTerm($message);
        if (!$blacklistTerm) {
            return $output;
        }

        $strikes = (int) ($session->getFor('chatai', 'blacklist_strikes') ?? 0) + 1;
        $session->setFor('chatai', 'blacklist_strikes', $strikes);

        if ($strikes && $strikes >= $this->max_strikes) {
            $output->stop          = true;
            $output->blacklistTerm = true;
            $output->blacklisted   = true;
            $err = $this->getErrorMessage(13);

            // Log hard blacklist event with IP
            try {
                $ip = (string) $this->wire('input')->ip;

                $ph = $this->previewAndHash((string) $message);

                $meta = [
                    'event'            => 'blocked',
                    'chat_id'          => $this->getCurrentChatId(),
                    'ip'               => $ip,
                    'ip_hash'          => hash('sha256', $ip),
                    'reason'           => 'blacklist',
                    'lang_id'          => (int) ($langId ?? 0),
                    'user_msg_preview' => $ph['preview'],
                    'user_msg_hash'    => $ph['hash'],
                ];

                $this->obsLog(['ok' => false, 'error' => 'blacklist'], $meta);
            } catch (\Throwable $e) {
                $this->wire('log')->save('chatai-obslog', $e->getMessage());
            }

        } else {
            $output->stop = false;
            $err = $this->getErrorMessage(14, $strikes, $this->max_strikes);
        }

        $output->error = $err;
        $output->reply = $err->msg;

        return $output;
    }

    protected function getCurrentChatId(): string
    {
        $session = $this->wire('session');

        $chatId = (string) $session->getFor('chatai', 'chat_id');
        if (!$chatId) {
            // Short, opaque id; not user-identifying
            $chatId = bin2hex(random_bytes(8)); // 16 hex chars
            $session->setFor('chatai', 'chat_id', $chatId);
        }

        return $chatId;
    }


    private function buildPostData(string $model, array $messages): \stdClass {
        $p = new \stdClass();
        $p->model    = $model;
        $p->messages = $messages;

        switch (true) {
            // GPT-5 family: use new controls, do not send sampling knobs
            case stripos($model, 'gpt-5') === 0:
                // keep using your existing limit name to avoid refactors
                if (!empty($this->max_completion_tokens)) {
                    $p->max_completion_tokens = (int) $this->max_completion_tokens;
                }
                if (!empty($this->verbosity)) {
                    $p->verbosity = $this->verbosity;                 // low|medium|high
                }
                if (!empty($this->reasoning_effort)) {
                    $p->reasoning_effort = $this->reasoning_effort;   // minimal|low|medium|high
                }
                // intentionally DO NOT set: temperature, top_p, presence_penalty, frequency_penalty
                break;

            // Keep for newer models
            default:
                break;
        }
        return $p;
    }

    /**
     * Decide endpoint + normalize body per model family.
     * Returns [string $url, array $body]
     */
    protected function normalizeApiRequest(string $model, $payload): array
    {
        // deep-cast stdClass → array for [] access
        if (is_object($payload)) $payload = json_decode(json_encode($payload), true);
        $payload = is_array($payload) ? $payload : [];

        $isGpt5 = (stripos($model, 'gpt-5') === 0);

        if ($isGpt5) {
            // GPT-5 → Responses API with `input`
            $endpoint = 'https://api.openai.com/v1/responses';

            // Coerce messages into strings using referenced &$m
            $messages = isset($payload['messages']) && is_array($payload['messages']) ? $payload['messages'] : [];
            foreach ($messages as &$m) {
                if (!isset($m['role'])) $m['role'] = 'user';
                if (!isset($m['content'])) $m['content'] = '';
                if (!is_string($m['content'])) {
                    $m['content'] = is_scalar($m['content']) ? (string)$m['content'] : json_encode($m['content']);
                }
            }
            unset($m);

            // Map chat messages → Responses `input`
            $input = [];
            foreach ($messages as $m) {
                $role = (string)$m['role'];
                // assistant history must be output_text or refusal
                $type = ($role === 'assistant') ? 'output_text' : 'input_text';
                $part = ['type' => $type, 'text' => (string)$m['content']];
                $input[] = [
                    'role' => $role,          // 'system' | 'user' | 'assistant'
                    'content' => [$part],
                ];
            }

            $body = [
                'model' => (string)$model,
                'input' => $input,
            ];

            // tokens/temperature/reasoning mapping stays the same
            if (isset($payload['max_completion_tokens'])) $body['max_output_tokens'] = (int)$payload['max_completion_tokens'];
            //if (isset($payload['temperature'])) $body['temperature'] = (float)$payload['temperature'];
            if (!empty($payload['reasoning_effort'])) $body['reasoning'] = ['effort' => (string)$payload['reasoning_effort']];
            // drop verbosity (not public)


        }
        return [$endpoint, $body];
    }

    public function callModelForText(array $messagesForApi): \stdClass {

        $o = (object)['ok' => false];

        $postData = $this->buildPostData($this->model, $messagesForApi);
        list($url, $body) = $this->normalizeApiRequest($this->model, $postData);

        $http = new \ProcessWire\WireHttp();
        $http->setHeaders([
            'Authorization' => 'Bearer ' . $this->api_key,
            'Content-Type'  => 'application/json',
            'Accept'        => 'application/json',
        ]);
        $http->setTimeout(25);

        try {

            $response = $http->send($url, json_encode($body), 'POST');
            if ($response === false) {
                $this->wire('log')->save('chatai', 'OpenAI transport error: ' . $http->getError());
                $o->error = 'transport_error';
                return $o;
            }
            $data = json_decode($response, true);

            if (!is_array($data)) {
                $this->wire('log')->save('chatai', 'OpenAI: unexpected non-JSON response');
                $o->error = 'unexpected_response';
                return $o;
            }

            $isResponses = (strpos($url, '/responses') !== false);

            // Responses API: detect cutoff early
            if ($isResponses) {
                $status = $data['status'] ?? null;
                $reason = $data['incomplete_details']['reason'] ?? null;
                $input_tokens = $data['usage']['input_tokens'] ?? 0;
                $output_tokens = $data['usage']['output_tokens'] ?? 0;

                if ($status === 'incomplete' && $reason === 'max_output_tokens') {
                    $partial = '';

                    if (!empty($data['output']) && is_array($data['output'])) {
                        foreach ($data['output'] as $seg) {
                            if (empty($seg['content']) || !is_array($seg['content'])) continue;

                            foreach ($seg['content'] as $c) {
                                $type = $c['type'] ?? '';
                                if ($type !== 'output_text' && $type !== 'text') continue;
                                if (empty($c['text'])) continue;

                                $text = $c['text'];

                                // Responses text object: ['value' => '...', ...]
                                if (is_array($text) && isset($text['value'])) {
                                    $text = $text['value'];
                                }

                                if (is_string($text) && $text !== '') {
                                    $partial .= $text;
                                }
                            }
                        }
                    }

                    $o->ok     = true;
                    $o->text   = $this->wire('sanitizer')->textarea($partial);
                    $o->cutoff = true; // flag up to sendMessage()
                    $o->input_tokens = $input_tokens;
                    $o->output_tokens = $output_tokens;
                    return $o;
                }
            }

            // Normal success shapes:

            if ($isResponses) {
                // Modern Responses output → content → type=output_text
                if (!empty($data['output']) && is_array($data['output'])) {
                    foreach ($data['output'] as $seg) {
                        if (empty($seg['content']) || !is_array($seg['content'])) continue;

                        foreach ($seg['content'] as $c) {
                            $type = $c['type'] ?? '';
                            if ($type !== 'output_text' && $type !== 'text') continue;
                            if (empty($c['text'])) continue;

                            $text = $c['text'];

                            // Handle object form: { value: '...', ... }
                            if (is_array($text) && isset($text['value'])) {
                                $text = $text['value'];
                            }

                            if (is_string($text)) {
                                $o->ok   = true;
                                $o->text = $text;
                                $o->input_tokens = $input_tokens;
                                $o->output_tokens = $output_tokens;
                                return $o;
                            }
                        }
                    }
                }

                // Some providers mirror chat-like choices
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok   = true;
                    $o->text = (string)$data['choices'][0]['message']['content'];
                    $o->input_tokens = $input_tokens;
                    $o->output_tokens = $output_tokens;
                    return $o;
                }

            } else {
                // /chat/completions (generic, no gpt-4 specifics)
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok   = true;
                    $o->text = (string)$data['choices'][0]['message']['content'];
                    $o->input_tokens = $input_tokens;
                    $o->output_tokens = $output_tokens;
                    return $o;
                }
            }

            // Provider error surfaced
            if (!empty($data['error'])) {
                $code = strtolower((string)($data['error']['code'] ?? 'provider_error'));
                if (in_array($code, ['rate_limit_exceeded','rate_limit','insufficient_quota','throttled'], true)) {
                    $code = 'rate_limit_exceeded';
                }
                $this->wire('log')->save('chatai', 'OpenAI error: ' . $code . ' | ' . ($data['error']['message'] ?? ''));
                $o->error      = $code;
                $o->chat_error = $data['error'];
                $o->input_tokens = $input_tokens;
                $o->output_tokens = $output_tokens;

                return $o;
            }

            // Unexpected success shape
            $this->wire('log')->save('chatai', 'OpenAI: missing choices/content | body=' . substr($response, 0, 500));
            $o->error = 'unexpected_response';
            return $o;

        } catch (\Throwable $e) {
            $this->wire('log')->save('chatai', 'OpenAI exception: ' . $e->getMessage());
            $o->error = 'exception';
            return $o;
        }
    }

    protected function isCurrentPageRef(string $msg, ?int $langId, array $cfg): bool
    {
        $key = $langId ? "current_page_refs__{$langId}" : "current_page_refs";
        $list = (string)($cfg[$key] ?? $cfg['current_page_refs'] ?? '');
        if ($list === '') return false;

        $msg = mb_strtolower(trim($msg));

        foreach (explode(',', $list) as $ref) {
            $ref = mb_strtolower(trim($ref));
            if ($ref === '') continue;
            if (mb_strpos($msg, $ref) !== false) return true;
        }
        return false;
    }

    protected function handleUrlsInPayload(array &$payload): array
    {
        $config = $this->wire('config');
        $pages  = $this->wire('pages');

        $msg = (string) ($payload['msg'] ?? '');
        $pid = (int) ($payload['pageId'] ?? 0);

        // Allowed hosts (PW convention)
        $httpHosts = is_array($config->httpHosts)
            ? $config->httpHosts
            : [$config->httpHost];

        $allowedHosts = array_values(array_filter(array_map(function ($h) {
            $h = strtolower(trim((string) $h));
            return $h !== '' ? $h : null;
        }, $httpHosts)));

        // Extract URLs
        if (!preg_match_all('~https?://[^\s<>"\'\)\]]+~i', $msg, $m)) {
            return ['blocked' => false, 'has_url' => false];
        }

        $urls = $m[0] ?? [];
        if (!$urls) return ['blocked' => false, 'has_url' => false];

        $firstOnSiteUrl = null;

        foreach ($urls as $u) {
            $host = strtolower((string) parse_url($u, PHP_URL_HOST));
            if ($host !== '' && in_array($host, $allowedHosts, true)) {
                $firstOnSiteUrl = $u;
                break; // accept first on-site URL
            }
        }

        if (!$firstOnSiteUrl) {
            // URLs were present, none were on-site
            return [
                'blocked' => true,
                'has_url' => true,
                'reason'  => 'no_onsite_url',
            ];
        }

        // We have at least one on-site URL; optionally resolve to pageId
        if ($pid < 1) {
            $p = $pages->get($firstOnSiteUrl);
            if ($p && $p->id && $p->viewable()) {
                $payload['pageId'] = (int) $p->id;
            }
        }

        return [
            'blocked' => false,
            'has_url' => true,
            'onsite_url' => $firstOnSiteUrl,
        ];
    }


    public function sendMessage(
        string $userMessage,
        ?int $langId = null,
        ?int $pid = null,
        ?string $url = null,
        array $meta = []
    ): \stdClass
    {
        $san = $this->wire('sanitizer');
        $user = $this->wire('user');

        $result = (object)[
            'stop'        => false,
            'error'       => null,                  // (object){msg:string, warning?:bool} or null
            'reply'       => null,                  // (object){msg:string} or null
            'html'        => null,                  // optional trusted HTML
            'blacklisted' => false,
            'name'        => null,
        ];


        // Validate / normalise (defensive)
        $msg = $san->text($userMessage);
        $langId = $langId !== null ? (int) $san->int($langId) : null;
        if ($langId < 1) $langId = null;
        $pid = $pid !== null ? (int) $san->int($pid) : 0;
        if ($pid < 1) $pid = 0;
        $url = $url !== null ? (string) $san->url($url) : '';


        // Context for CTA hook
        $payload = [
            'status'       => 'ok',
            'openai_error' => null,
            'msg'          => $msg,
            'reply'        => null,
            'error'        => null,
            'pageId'       => $pid,
            'langId'       => $langId,
            'url'          => $url,
        ];

        // Language switch (soft)
        if ($langId !== null) {
            try {
                $languages = $this->wire('languages');
                if ($languages && $langId) {
                    $lang = $languages->get($langId);
                    if ($lang && $lang->id) $languages->setLanguage($lang);
                }
            } catch (\Throwable $e) { /* ignore */ }
        }

        $result->name = $this->promptService()->getBotName();
        $result = $this->isMessageAllowed($msg);
        $urlCheck = $this->handleUrlsInPayload($payload);
        if (!empty($urlCheck['blocked'])) {
            $result->error = $this->getErrorMessage(16);
            $payload['status']    = 'blocked';
            $payload['reply'] = $result->error->msg;
            $result = $this->handleCTA( $payload,  $result);
            return $result;
        }

        if($result && $result->error) {
            // Optional CTA
            $payload['status'] = 'not_allowed';
            $payload['error'] = $result->error;
            $result = $this->handleCTA( $payload,  $result);
            return $result;
        }

        $messages = [];
        $svc = $this->promptService();

        $session = $this->wire('session');
        $system = $session->getFor('chatai','system_prompt');
        if (!$system) {
            $system = ['role'=>'system','content'=>$svc->getPrompt()];
            $session->setFor('chatai','system_prompt', $system);
        }
        $messages[] = ['role'=>'system','content'=> $system];

        // Classify message for context
        $decision = $this->classifier->classify($msg);

        $cfg = $svc->loadPromptSettings();
        $userLangId = $user->language->id;

        $cfgLang = function(string $key) use ($cfg, $userLangId) {
            $k = $key . '__' . $userLangId;
            return (string)($cfg[$k] ?? $cfg[$key] ?? '');
        };

        $label   = (string)($decision['label'] ?? '');

        // Quick out if small talk
        if($label === 'small_talk') {
            $result->reply = $cfgLang('smalltalk_reply') ?: 'Hello. How can I help you today?';
            // Optional CTA
            $payload['status'] = $label;
            $payload['reply'] = $result->reply;
            $result = $this->handleCTA( $payload,  $result);
            return $result;
        }

        // Quick out if blocked action
        if($label === 'blocked_action') {
            $result->reply = $cfgLang('blocked_action_verbs_reply')
                ?: "I’m sorry. I can’t do that. Please ask me something else about this site.";

            // Optional CTA
            $payload['status'] = $label;
            $payload['reply'] = $result->reply;
            $result = $this->handleCTA( $payload,  $result);

            return $result;
        }


        // RAG path
        $ragLangId = $langId ?? 0;
        $k = 6;


        // phrase trigger
        $isCurrentRef = $this->isCurrentPageRef($msg, $langId, $cfg);

        // vague trigger (uses your existing intent label)
        $preferPageForVague = ($pid > 0 && in_array($label, ['meta', 'ambiguous'], true));

        if ($isCurrentRef || $preferPageForVague) {
            // Only treat as no_access when the user explicitly refers to "this/current page"
            if ($isCurrentRef && $pid > 0) {
                $p = $this->wire('pages')->get((int) $pid);
                if ($p && $p->id && !$this->rag->shouldIndexPage($p, $cfg)) {
                    $label = 'no_access';
                    $top = []; // force canned reply
                }
            }

            if (!isset($top)) {
                $top = $this->rag->retrieveTopKForPage($msg, $ragLangId, $pid, $k, 60, $user);
            }
        } else {
            $top = $this->rag->retrieveTopK($msg, $ragLangId, $k, 60, $user);
        }

        if(!empty($top)) {
            $context = $this->rag->buildContextFromChunks($top);
        } else {
            switch ($label) {
                case 'meta':
                    $result->reply = $cfgLang('meta_reply') ?: $cfgLang('no_context_reply')
                        ?: 'I can help with pages and information on this site. Ask me what you’re looking for.';
                    break;

                case 'ambiguous':
                    // Optional: detect follow-up and prefer followup_reply
                    if ($follow = $cfgLang('followup_reply')) {
                        $result->reply = $follow;
                    } else {
                        $result->reply = $cfgLang('no_context_reply')
                            ?: 'Tell me what you’re looking for and I’ll point you to the right page.';
                    }
                    break;

                case 'no_access':
                    $result->reply = $cfgLang('no_access_reply') ?: "I’m sorry, I don’t have access to the page. Please ask me something else about this site.";
                    break;

            }
            // Optional CTA
            $payload['status'] = $label;
            $payload['replyText'] = $result->reply;
            $result = $this->handleCTA( $payload,  $result);
            return $result;
        }

        // optional: add RAG context as an extra system message if you built it
        $hist = $session->getFor('chatai','history') ?? [];
        $hist[] = ['role'=>'user','content'=>$msg];
        $hist = array_slice($hist, -6); // keep last ~6 entries total
        $session->setFor('chatai','history', $hist);
        if (!empty($context)) $messages[] = ['role'=>'system','content'=>"Site context:\n".$context];
        foreach ($hist as $h) $messages[] = $h;


        // User message last
        $messages[] = ['role' => 'user', 'content' => $msg];

        // Message limit: only applies to OpenAI calls
        $credit = $this->consumeMessageCredit();
        if (!empty($credit['blocked'])) {
            $result->error = $this->getErrorMessage(4); // reached limit
            $result->stop  = true;
            // Optional CTA
            $payload['status'] = 'blocked';
            $payload['error'] = $result->error;
            $payload['reply'] = $result->reply;
            $result = $this->handleCTA( $payload,  $result);
            return $result;
        }

        // Model call
        try {
            $started = microtime(true);

            $messages = $this->beforeSend($messages);
            $m = $this->callModelForText($messages);
            $m = $this->normaliseResponse($m);
            $m = $this->afterSend($m);

            // If the low-level wrapper flagged a cutoff, record it on the result
            if (!empty($m->cutoff)) {
                $result->cutoff = true;
                $result->error  = $this->getErrorMessage(20);
            }

            // Common context
            $ph = $this->previewAndHash((string) $msg);
            $event = !empty($result->cutoff) ? 'cutoff' : 'reply';

            $meta = [
                'event'            => $event,
                'chat_id'          => $this->getCurrentChatId(),
                'latency_ms'       => (int) round((microtime(true) - $started) * 1000),
                'count'            => (int) ($credit['count'] ?? 0),
                'remaining'        => (int) ($credit['remaining'] ?? 0),
                'max_messages'     => (int) ($credit['max'] ?? 0),
                'stop'             => false,
                'lang_id'          => (int) ($userLangId ?? 0),
                'model'            => (string) $this->model,
                'endpoint'         => (stripos($this->model, 'gpt-5') === 0 ? '/v1/responses' : '/v1/chat/completions'),
                'cutoff'           => !empty($result->cutoff),
                'input_tokens'      => (int) ($m->input_tokens ?? 0),
                'output_tokens'     => (int) ($m->output_tokens ?? 0),
                'user_msg_preview' => $ph['preview'],
                'user_msg_hash'    => $ph['hash'],
            ];

            // Add ok-dependent meta and log once
            if (empty($m->ok)) {
                $meta['err_code'] = !empty($m->error) ? (string) $m->error : 'unknown';
            } else {
                $meta['stop'] = (bool) $result->stop;

                $answerSource = $result->html ?? $result->reply ?? $m->text ?? '';
                $meta['answer_len'] = strlen((string) strip_tags((string) $answerSource));
            }

            $this->obsLog($m, $meta);

        } catch (\Throwable $e) {
            // Keep this: it is genuinely useful
            $this->wire('log')->save('chatai', 'sendMessage model error: ' . $e->getMessage());

            $m = (object) ['ok' => false, 'error' => 'exception'];

            // Ensure meta exists so later code does not see an undefined variable
            if (!isset($meta) || !is_array($meta)) {
                $meta = [];
            }
            $meta['err_code'] = 'exception';
        }

        // Interpret (single exit point)
        if (empty($m->ok)) {
            return $this->handleModelError($m, $result, $payload, $meta);
        }

        $raw = (string) $m->text; // expected HTML fragment per your prompt

        // Sanitize allowed tags server-side
        $allowed = trim((string)($this['values']['allowed_tags'] ?? 'p,ul,li,ol,strong,em,code,br,a[href]'));

        // Ensure anchor allows href if 'a' present without attribute
        if (preg_match('/(^|,)\\s*a(\\s*,|$)/i', $allowed)) {
            $allowed = preg_replace('/(^|,)\\s*a(\\s*,|$)/i', '$1a[href]$2', $allowed);
        }

        // Normalize spaces
        $allowed = implode(',', array_filter(array_map('trim', explode(',', $allowed))));

        $result->html = $this->wire('sanitizer')->purify(
            $raw,
            [ 'HTML.Allowed' => $allowed ]
        );

        // Plain-text fallback (for screen readers / no-HTML environments)
        $plain = trim(strip_tags($raw));
       // $result->reply = (object)['msg' => $this->wire('sanitizer')->entities($plain)];
        $result->reply = $this->wire('sanitizer')->entities($plain);

        if ($plain !== '') {
            $hist[] = ['role'=>'assistant','content'=>$plain];
            $session->setFor('chatai','history', array_slice($hist, -6));
        }


        $meta['remaining'] = (int) $credit['remaining'];
        $meta['count']     = (int) ($credit['count'] ?? 0);

        // Use remaining credits to warn/stop (OpenAI-call budget)
        // Do NOT show the "one left" warning if cutoff already forces a hard stop UX.
        if (empty($result->cutoff) && isset($credit['remaining']) && (int)$credit['max'] > 0) {

            $remaining = (int) $credit['remaining'];

            if ($remaining === 1) {
                if (empty($result->stop)) { // only if not already a hard stop
                    $result->error = $this->getErrorMessage(10);
                    $result->stop  = false;
                }
            } elseif ($remaining === 0) {
                $result->error = $this->getErrorMessage(4); // or 11
                $result->stop  = true;
                $payload['status'] = 'cutoff';
                $payload['error'] = $result->error;
            }
        }

        // Optional CTA
        $payload['reply'] = $result->reply;
        $result = $this->handleCTA($payload, $result);
        return $result;
    }


    protected function handleResponse($ctx, $data) {

    }

    protected function normaliseResponse($m): \stdClass
    {
        $type = gettype($m);

        switch ($type) {
            case 'string':
                // JSON string response
                $decoded = json_decode($m, false); // decode as object
                return $decoded instanceof \stdClass ? $decoded : (object)[];

            case 'array':
                // Associative array -> object
                return (object) $m;

            case 'object':
                // Already what we want
                return $m instanceof \stdClass ? $m : (object) $m;

            case 'NULL':
                return (object)[];

            case 'boolean':
            case 'integer':
            case 'double':
                // Unexpected primitive; preserve value for debugging
                return (object)['value' => $m];

            default:
                // Resources or anything truly odd
                return (object)[];
        }
    }


    protected function handleModelError(\stdClass $m, \stdClass $result, array $payload, array $meta): \stdClass
    {
        $code = '';
        if (!empty($meta['err_code'])) {
            $code = (string) $meta['err_code'];
        } elseif (!empty($m->error)) {
            $code = (string) $m->error;
        } else {
            $code = 'unknown';
        }

        // Normalize provider “too busy / quota / throttled” signals to case 15
        if (in_array($code, ['rate_limit_exceeded', 'rate_limit', 'insufficient_quota', 'throttled'], true)) {
            $result->error = $this->getErrorMessage(15); // object with msg + warning
            $result->stop  = false;

            $payload['status'] = $code;
            $payload['reply']  = (string) ($result->reply ?? '');
            $payload['error']  = $result->error;

            return $this->handleCTA($payload, $result);
        }

        // Everything else → generic failure (case 6)
        $result->error = $this->getErrorMessage(6); // object with msg + warning
        $result->stop  = true;

        $payload['status'] = 'failed';
        $payload['reply']  = (string) ($result->reply ?? '');
        $payload['error']  = $result->error;

        return $this->handleCTA($payload, $result);
    }


    protected function handleCTA(array $payload, \stdClass $result) {
        $cta = $this->afterResponse($payload);
        // if original $payload array returned, hook not used
        if(is_string($cta)) {
            $cta = trim((string)$cta);
            if ($cta !== '') {
                $result->cta = $cta;
            }
        }
        return $result;
    }

    protected function renderAssistant($ctx, $normalised) {

    }

    /** helper stubs  */

    protected function consumeMessageCredit(): array
    {
        $session = $this->wire('session');
        $max = (int) $this->max_messages;

        if ($max <= 0) {
            return ['blocked' => false, 'max' => 0, 'count' => 0, 'remaining' => 0];
        }

        $count = (int) ($session->getFor('chatai', 'count') ?? 0);

        if ($count >= $max) {
            return ['blocked' => true, 'max' => $max, 'count' => $count, 'remaining' => 0];
        }

        $count++;
        $session->setFor('chatai', 'count', $count);

        return [
            'blocked'   => false,
            'max'       => $max,
            'count'     => $count,
            'remaining' => max(0, $max - $count),
        ];
    }

    public function getObsLog(): \ProcessWire\ChatAIObsLog
    {
        return $this->logger;
    }


    // logs one compact event to chatai_obslog
    protected function obsLog($result, array $meta = []): void
    {
        $logger = $this->getObsLog();
        if (!$logger) return;

        // Delegate. ChatAI should not assemble obslog payloads.
        $logger->logFromResult($result, $meta);
    }

    /** @return array{preview:string, hash:string} */
    protected function previewAndHash(string $text, int $limit = 120): array
    {
        // Normalise to plain text
        if (class_exists('\ProcessWire\WireTextTools')) {
            $tt = new \ProcessWire\WireTextTools();
            $plain = $tt->markupToText($text);
        } else {
            $plain = strip_tags($text);
        }
        $plain = trim($plain);

        // Safe UTF-8
        if (!mb_detect_encoding($plain, 'UTF-8', true)) {
            $plain = mb_convert_encoding($plain, 'UTF-8', 'UTF-8');
        }

        // Preview
        $preview = mb_substr($plain, 0, $limit);
        if (mb_strlen($plain) > $limit) $preview .= '…';

        // Hash can include knobs that affect semantics
        $hash = hash('sha256', json_encode([
            'text'   => $plain,
            'model'  => (string) ($this->model ?? ''),
            'lang'   => (int) ($this->langId ?? 0),
            'system' => (string) ($this->systemPrompt ?? ''),
        ], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE));

        return ['preview' => $preview, 'hash' => $hash];
    }

    public function saveToTranscript(string $role, string $content): void {
        $san = $this->wire('sanitizer');
        $t   = $this->wire('session')->getFor('chatai', 'transcript') ?? [];
        $t[] = [
            'role'    => $san->name($role),         // 'system'|'user'|'assistant'
            'content' => $san->text($content),  // plain text normalization
            'ts'      => time(),
        ];

        $this->wire('session')->setFor('chatai', 'transcript', $t);
    }

    public function getErrorMessage($number, $val1 = null, $val2 = null) {
        $errorMsg = new stdClass();
        switch ($number) {
            case 1: // blocked/blacklist
                $errorMsg->msg = $this->_('You have been blocked. Goodbye.');
                $errorMsg->warning = true;
                break;

            case 2: // empty input
                $errorMsg->msg = $this->_('No message submitted.');
                break;

            case 4: // limit reached
                $errorMsg->msg = $this->_('Too many questions. Goodbye.');
                $errorMsg->warning = true;
                break;

            case 5: // token budget (optional usage)
                $errorMsg->msg = $this->_('Insufficient OpenAI tokens');
                break;

            case 6: // generic model/transport failure
                $errorMsg->msg = $this->_("Ooops! Something went wrong. Please try again later.");
                $errorMsg->warning = true;
                break;

            case 7: // rephrase
                $errorMsg->msg = $this->_('Please rephrase your question');
                break;

            case 9: // off-topic (unused)
                $errorMsg->msg = $this->_('Not blacklisted but off topic');
                break;

            case 10: // near-limit warning
                $errorMsg->msg = $this->_('You have one question left before I have to go. Make it a good one!');
                $errorMsg->warning = true;
                break;

            case 11: // last question
                $errorMsg->msg = $this->_('This chat has reached its limit. Please start a new chat to continue.');
                break;

            case 12: // unexpected API response structure
                $errorMsg->msg = $this->_('Unexpected API response structure.');
                break; //

            case 13: // lockout due to repeated inappropriate messages
                $errorMsg->msg = $this->_('You have been locked out due to repeated inappropriate messages.');
                $errorMsg->warning = true;
                break;

            case 14: // rephrase with counters
                if(!empty($val1) && !empty($val2)) {
                    $template = $this->_("Please rephrase your question (Warning: %d/%d)");
                    $errorMsg->msg = sprintf($template, $val1, $val2);
                    $errorMsg->warning = true;
                } else {
                    $errorMsg->msg = $this->_("Please rephrase your question.");
                }
                break;

            case 15: // rate limited / busy (translatable)
                $errorMsg->msg = $this->_('We are a bit busy. Please try again shortly.');
                $errorMsg->warning = true;
                break;

            case 16: // invalid URL(s) in message
                $errorMsg->msg = $this->_('I can only help with pages and information on this site. Please use a link from this site, or remove external links and try again.');
                $errorMsg->warning = true;
                break;

            case 20: // too few tokens
                $errorMsg->msg = $this->_('This chat has reached its limit. Please start a new chat to continue.');
                break;

            default:
                $errorMsg->msg = $this->_('Invalid message number: ' . $number);
                break;
        }
        $errorMsg->number = $number;
        return $errorMsg;
    }

    // Database functions

    private function withTransaction(callable $fn, int $retries = 3) {
        /** @var \WireDatabasePDO $db */
        $db = wire('database');
        $attempt = 0;

        while (true) {
            $attempt++;
            try {
                if (!$db->inTransaction()) $db->beginTransaction();
                $result = $fn($db);
                $db->commit();
                return $result;
            } catch (\PDOException $e) {
                if ($db->inTransaction()) $db->rollBack();

                // MySQL deadlock or lock wait timeout
                $sqlState = $e->getCode(); // SQLSTATE, e.g. '40001'
                $msg = $e->getMessage();
                $isRetryable = $sqlState === '40001' || strpos($msg, 'Deadlock found') !== false || strpos($msg, 'Lock wait timeout exceeded') !== false;

                if ($isRetryable && $attempt < $retries) {
                    usleep(random_int(20_000, 120_000)); // small jitter 20-120ms
                    continue;
                }
                throw $e;
            }
        }
    }

