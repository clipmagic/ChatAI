<?php
/**
 * ProcessWire Chatbot Module - Core Functionality
 */

namespace ProcessWire;

use stdClass;

class ChatAI extends WireData implements Module, ConfigurableModule
{
    const dbTableName = 'chatai';

    const dbTablePrompt = 'chatai_prompt';

    const modName = 'ChatAI';


    public function construct()
    {
        parent::__construct();
    }

    public function init()
    {
        if (empty($this->api_key)) $this->warning('OpenAI API key missing; ChatAI may not function.');


        // Load helpers
        require_once __DIR__ . '/classes/Indexing/IndexContentExtractor.php';
        require_once __DIR__ . '/classes/Indexing/ChatAIIndexer.php';
        require_once __DIR__ . '/classes/RAG/RAG.php';

        // Shared services
        $this->rag = new \ProcessWire\RAG();
        $this->rag->setWire($this->wire());

        $this->indexer = new \ProcessWire\ChatAIIndexer();
        $this->indexer->setWire($this->wire());
    }

    public function getModuleConfigInputfields(array $data)
    {
        $modules = wire('modules');
        $inputfields = new InputfieldWrapper();

        // OpenAI Settings
        $fieldset = $modules->get('InputfieldFieldset');
        $fieldset->attr('name+id', 'openai');
        $fieldset->label = $this->_('OpenAI Settings');

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'api_key');
        $f->label = $this->_('OpenAI API Key');
        $f->required = true;
        $f->collapsed = 5;
        $f->value = $data['api_key'] ?? '';
        $fieldset->add($f);

        $f = $modules->get('InputfieldSelect');
        $f->attr('name+id', 'model');
        $f->label = $this->_('OpenAI Model');
        $f->columnWidth	= 20;
        $f->addOptions([
            'gpt-5-mini' => "gpt-5-mini",
            'gpt-5-nano' => 'gpt-5-nano',
            'gpt-5' => 'gpt-5',
            'gpt-3.5-turbo' => 'gpt-3.5-turbo',
            'gpt-4o' => 'gpt-4o'
        ]);
        $f->value = $data['model'] ?? 'gpt-5-mini';
        $fieldset->add($f);

        $f = $modules->get('InputfieldSelect');
        $f->attr('name+id', 'verbosity');
        $f->label = $this->_('Verbosity');
        $f->columnWidth	= 20;
        $f->addOptions([
            'low' => "Low",
            'medium' => 'Medium',
            'high' => 'High'
        ]);
        $f->value = $data['verbosity'] ?? 'medium';
        $f->showIf("model=gpt-5|gpt-5-mini|gpt-5-nano");
        $fieldset->add($f);

        $f = $modules->get('InputfieldSelect');
        $f->attr('name+id', 'reasoningEffort');
        $f->label = $this->_('Reasoning Effort');
        $f->columnWidth	= 20;
        $f->addOptions([
            'minimal' => "Minimal",
            'low' => "Low",
            'medium' => 'Medium',
            'high' => 'High'
        ]);
        $f->showIf("model=gpt-5|gpt-5-mini|gpt-5-nano");
        $f->value = $data['reasoningEffort'] ?? 'medium';
        $fieldset->add($f);


        $f = $modules->get('InputfieldFloat');
        $f->attr('name+id', 'temperature');
        $f->label = $this->_('Temperature (0–1)');
        $f->columnWidth	= 20;
        $f->notes = $this->_('Lower is more factual, higher is more creative');
        $f->step = 0.1;
        $f->min = 0;
        $f->max = 1;
        $f->value = $data['temperature'] ?? 0.7;
        $f->showIf("model!=gpt-5|gpt-5-mini|gpt-5-nano");
        $fieldset->add($f);

        $f = $modules->get('InputfieldInteger');
        $f->attr('name+id', 'max_completion_tokens');
        $f->label = $this->_('Max tokens');
        $f->columnWidth	= 20;
        $f->notes = $this->_('Max tokens per message');
        $f->value = $data['max_completion_tokens'] ?? 1000;
        $fieldset->add($f);

        $f = $modules->get('InputfieldInteger');
        $f->attr('name+id', 'max_messages');
        $f->label = $this->_('Maximum questions');
        $f->columnWidth	= 20;
        $f->notes = $this->_('Max questions per conversation');
        $f->value = $data['max_messages'] ?? 20;
        $fieldset->add($f);

        $f = $modules->get('InputfieldInteger');
        $f->attr('name+id', 'max_strikes');
        $f->label = $this->_('Maximum blacklist');
        $f->columnWidth	= 20;
        $f->notes = $this->_('Number of blacklist strikes before being blocked');
        $f->value = $data['max_strikes'] ?? 3;
        $fieldset->add($f);


        $inputfields->add($fieldset);


        $f = $modules->get('InputfieldCheckboxes');
        $f->attr('name+id', 'prompt_roles');
        $f->label = $this->_('Roles allowed to craft prompt');
        $roles = $this->wire('roles');
        $options = [];
        $pageEditPermission = $roles->find("status=published");
        if($pageEditPermission->count > 0) {
            foreach($pageEditPermission->roles as $role) {
                if(!$role->hasPermission('page-edit') || $role->name === 'superuser' ) continue;
                $options[$role->name] = $role->name;
            }
            $f->addOptions($options);
        }
        $value = $data['prompt_roles'] ?? '';
        $f->attr('value', $value);
        $f->columnWidth = 50;
        $note = $this->_("Superuser enabled by default.\r\nYou may optionally add a ChatAI specific role with page-edit permission.");
        $f->notes($note);
        $inputfields->add($f);

        // File locations
        $fieldset = $modules->get('InputfieldFieldset');
        $fieldset->attr('name+id', 'files');
        $fieldset->label($this->_('Files'));

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'widget');
        $f->label($this->_('Path to widget file'));
        $f->notes("Default is /site/modules/ChatAI/chatai-widget.php");
        $value = $data['widget'] ?? '/site/modules/ChatAI/chatai-widget.php';
        $f->attr('value', $value);
        $f->stripTags = true;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'css');
        $f->label($this->_('Path to CSS file'));
        $f->notes("Default is /site/modules/ChatAI/chatai.css");
        $value = $data['css'] ?? '/site/modules/ChatAI/chatai.css';
        $f->attr('value', $value );
        $f->stripTags = true;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'js');
        $f->label($this->_('Path to JS file'));
        $f->notes("Default is /site/modules/ChatAI/chatai.js");
        $value = $data['js'] ?? '/site/modules/ChatAI/chatai.js';
        $f->attr('value', $value);
        $f->stripTags = true;
        $fieldset->add($f);
        $inputfields->add($fieldset);


        $inputfields->add($fieldset);

        return $inputfields;
    }

    /* Module functions */

    public function renderWidget() : string
    {
        $chatProcess = $this->wire('modules')->get('ProcessChatAI');
        $config = wire('config');
        $path = $config->paths->root . ltrim($this->widget, '/');
        return $chatProcess->getWidget($path);
    }

    public function renderStyles() : string
    {
        $css = "<link rel='stylesheet' href='$this->css' type='text/css'>";
        return $css;
    }

    public function renderScript() : string
    {
        $js = "<script src='$this->js' ></script>";
        return $js;
    }

    public function isMessageAllowed($message) : stdClass
    {
        $chatProcess = $this->wire('modules')->get('ProcessChatAI');
        $session = $this->wire('session');
        $output = new stdClass();
        $output->name = $chatProcess->getBotName();

        $blacklisted = $chatProcess->isBlacklisted($message);
        $output->blacklisted = $blacklisted;
        // allowed
        if(!$blacklisted) {
            $output->reply = $message;
        } else {
            // disallowed
            $blacklistStrikes = $session->getFor('chatai', 'blacklist_strikes') ?? 0;
            $blacklistStrikes++;
            $session->setFor('chatai', 'blacklist_strikes', $blacklistStrikes);

            if ($blacklistStrikes >= $this->max_strikes) {
                $session->setFor('chatai', 'blacklist_locked', true);
                $output->stop = true;
                $output->error = $this->getErrorMessage(13); // Error message ID 13
            } else {
                // Soft warning response (strikes < 3)
                $output->stop = false;
                $output->error = $this->getErrorMessage(14,$blacklistStrikes, $this->max_strikes);
            }

            // If previously locked out, auto-reject without checking message
            if ($session->getFor('chatai', 'blacklist_locked')) {
                $output->stop = true;
                $output->error = $this->getErrorMessage(13); // Error message ID 13
            }

        }
        return $output;
    }

    private function buildPostData(string $model, array $messages): \stdClass {
        $p = new \stdClass();
        $p->model    = $model;
        $p->messages = $messages;

        switch (true) {
            // GPT-5 family: use new controls, do not send sampling knobs
            case stripos($model, 'gpt-5') === 0:
                // keep using your existing limit name to avoid refactors
                if (!empty($this->max_completion_tokens)) {
                    $p->max_completion_tokens = (int) $this->max_completion_tokens;
                }
                if (!empty($this->verbosity)) {
                    $p->verbosity = $this->verbosity;                 // low|medium|high
                }
                if (!empty($this->reasoning_effort)) {
                    $p->reasoning_effort = $this->reasoning_effort;   // minimal|low|medium|high
                }
                // intentionally DO NOT set: temperature, top_p, presence_penalty, frequency_penalty
                break;

            // Older models: keep classic sampling parameters
            default:
                if (isset($this->temperature))       $p->temperature = (float) $this->temperature;
                if (!empty($this->max_completion_tokens)) {
                    // works with modern chat completions; keep your current field name
                    $p->max_completion_tokens = (int) $this->max_completion_tokens;
                }
                break;
        }
        return $p;
    }

    /**
     * Decide endpoint + normalize body per model family.
     * Returns [string $url, array $body]
     */
    protected function normalizeApiRequest(string $model, $payload): array {
        // deep-cast stdClass → array for [] access
        if (is_object($payload)) $payload = json_decode(json_encode($payload), true);
        $payload = is_array($payload) ? $payload : [];

        $isGpt5 = (stripos($model, 'gpt-5') === 0);

        if ($isGpt5) {
            // GPT-5 → Responses API with `input`
            $endpoint = 'https://api.openai.com/v1/responses';

            // Coerce messages into strings
            $messages = isset($payload['messages']) && is_array($payload['messages']) ? $payload['messages'] : [];
            foreach ($messages as &$m) {
                if (!isset($m['role']))    $m['role'] = 'user';
                if (!isset($m['content'])) $m['content'] = '';
                if (!is_string($m['content'])) {
                    $m['content'] = is_scalar($m['content']) ? (string)$m['content'] : json_encode($m['content']);
                }
            }
            unset($m);

            // Map chat messages → Responses `input`
            $input = [];
            foreach ($messages as $m) {
                $input[] = [
                    'role'    => $m['role'],
                    'content' => [
                        ['type' => 'input_text', 'text' => $m['content']]
                    ],
                ];
            }
            $body = [
                'model' => (string)$model,
                'input' => $input,
            ];

            // tokens/temperature/reasoning mapping stays the same
            if (isset($payload['max_completion_tokens'])) $body['max_output_tokens'] = (int)$payload['max_completion_tokens'];
            if (isset($payload['temperature']))           $body['temperature']       = (float)$payload['temperature'];
            if (!empty($payload['reasoning_effort']))     $body['reasoning']         = ['effort' => (string)$payload['reasoning_effort']];
            // drop verbosity (not public)

            return [$endpoint, $body];
        }

        // Older/chat models → Chat Completions with `messages`
        $endpoint = 'https://api.openai.com/v1/chat/completions';

        $messages = isset($payload['messages']) && is_array($payload['messages']) ? $payload['messages'] : [];
        foreach ($messages as &$m) {
            if (!isset($m['role']))    $m['role'] = 'user';
            if (!isset($m['content'])) $m['content'] = '';
            if (!is_string($m['content'])) {
                $m['content'] = is_scalar($m['content']) ? (string)$m['content'] : json_encode($m['content']);
            }
        }
        unset($m);

        $body = [
            'model'    => (string)$model,
            'messages' => $messages,
        ];
        if (isset($payload['max_completion_tokens'])) $body['max_tokens']   = (int)$payload['max_completion_tokens'];
        if (isset($payload['temperature']))           $body['temperature']  = (float)$payload['temperature'];
        // strip verbosity/reasoning_effort here
        return [$endpoint, $body];
    }

    /**
     * Returns (object){ ok: bool, text?: string, error?: string, chat_error?: array }
     */
    public function callModelForText(array $messagesForApi): \stdClass {
        $o = (object)['ok' => false];

        // Build from your builder (as you already do)
        $postData = $this->buildPostData($this->model, $messagesForApi);
        list($url, $body) = $this->normalizeApiRequest($this->model, $postData);

        $http = new \ProcessWire\WireHttp();
        $http->setHeaders([
            'Authorization' => 'Bearer ' . $this->api_key,
            'Content-Type'  => 'application/json',
            'Accept'        => 'application/json',
        ]);
        $http->setTimeout(25);

        try {

            $response = $http->send($url, json_encode($body), 'POST');
            if ($response === false) {
                $this->wire('log')->save('chatai', 'OpenAI transport error: ' . $http->getError());
                $o->error = 'transport_error';
                return $o;
            }
            $data = json_decode($response, true);
            $this->obsLog($data);

            // If using /responses, prefer new shapes first
            if (strpos($url, '/responses') !== false) {
                // Prefer new Responses API shapes
                if (!empty($data['output']) && is_array($data['output'])) {
                    foreach ($data['output'] as $seg) {
                        if (!empty($seg['content']) && is_array($seg['content'])) {
                            foreach ($seg['content'] as $c) {
                                $type = $c['type'] ?? '';
                                if (!empty($c['text']) && ($type === 'output_text' || $type === 'text')) {
                                    $o->ok = true; $o->text = (string)$c['text']; return $o;
                                }
                            }
                        }
                    }
                }
                if (!empty($data['output_text']) && is_string($data['output_text'])) {
                    $o->ok = true; $o->text = (string)$data['output_text']; return $o;
                }

                // Fallback to mirrored chat shape if present
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok = true; $o->text = (string)$data['choices'][0]['message']['content']; return $o;
                }
            }
            if (!is_array($data)) {
                $this->wire('log')->save('chatai', 'OpenAI: unexpected non-JSON response');
                $o->error = 'unexpected_response';
                return $o;
            }

            // Success shapes
            if (strpos($url, '/responses') !== false) {
                // Prefer Responses API ‘output’ → content → type=output_text
                if (!empty($data['output']) && is_array($data['output'])) {
                    foreach ($data['output'] as $seg) {
                        if (!empty($seg['content']) && is_array($seg['content'])) {
                            foreach ($seg['content'] as $c) {
                                if (($c['type'] ?? '') === 'output_text' && !empty($c['text'])) {
                                    $o->ok = true; $o->text = (string)$c['text']; return $o;
                                }
                            }
                        }
                    }
                }
                // Some providers still mirror chat ‘choices’
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok = true; $o->text = (string)$data['choices'][0]['message']['content']; return $o;
                }
            } else {
                // /chat/completions
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok = true; $o->text = (string)$data['choices'][0]['message']['content']; return $o;
                }
            }

            // Provider error surfaced
            if (!empty($data['error'])) {
                $code = strtolower((string)($data['error']['code'] ?? 'provider_error'));
                if (in_array($code, ['rate_limit_exceeded','rate_limit','insufficient_quota','throttled'], true)) {
                    $code = 'rate_limit_exceeded';
                }
                $this->wire('log')->save('chatai', 'OpenAI error: ' . $code . ' | ' . ($data['error']['message'] ?? ''));
                $o->error = $code; $o->chat_error = $data['error'];
                return $o;
            }

            // Unexpected success shape — log a snippet so we can see what came back
            $this->wire('log')->save('chatai', 'OpenAI: missing choices/content | body=' . substr($response, 0, 500));
            $o->error = 'unexpected_response';
            return $o;

        } catch (\Throwable $e) {
            $this->wire('log')->save('chatai', 'OpenAI exception: ' . $e->getMessage());
            $o->error = 'exception';
            return $o;
        }
    }

    public function sendMessage(string $userMessage, $langId = null, $meta = []): \stdClass
    {
        $san = $this->wire('sanitizer');
        $chatProcess = $this->wire('modules')->get('ProcessChatAI');

        $result = (object)[
            'stop'        => false,
            'error'       => null,                  // (object){msg:string, warning?:bool} or null
            'reply'       => null,                  // (object){msg:string} or null
            'html'        => null,                  // optional trusted HTML
            'blacklisted' => false,
            'name'        => null,
        ];

        // Language switch (soft)
        if ($langId !== null) {
            try {
                $langId = (int)$san->int($langId);
                $languages = $this->wire('languages');
                if ($languages && $langId) {
                    $lang = $languages->get($langId);
                    if ($lang && $lang->id) $languages->setLanguage($lang);
                }
            } catch (\Throwable $e) { /* ignore */ }
        }
        if ($chatProcess) $result->name = $chatProcess->getBotName(); // <- use -> not ['']

        // Validate
        $msg = $san->text($userMessage);
        if ($msg === '') {
            $result->error = $this->getErrorMessage(2);
            return $result;
        }

        // Limit pre-check
        $count = $this->msgCountGetAndInit();   // should start at 0
        if ($count >= (int)$this->max_messages) {
            $result->stop  = true;
            $result->error = $this->getErrorMessage(4);
            return $result;
        }

        // Blacklist
        if ($chatProcess->isBlacklisted($msg)) {
            $result->blacklisted = true;
            $result->error = (object)['msg' => $this->getErrorMessage(1) ?: 'Message blocked.'];
            return $result;
        }

        // Build messages
        $system = $chatProcess->getPrompt();
        $messages = [
            ['role' => 'system', 'content' => $system],
            ['role' => 'user',   'content' => $msg],
        ];

        // Model call
        try {
           $started = microtime(true);

            // ... after the API call:
            $messages = $chatProcess->beforeSend($messages);
            $m = $this->callModelForText($messages);

            // Normalize to object
            if (is_string($m)) {
                $decoded = json_decode($m, false);          // decode as object
                $m = $decoded ?? (object)[];
            } elseif (is_array($m)) {
                $m = (object) $m;
            } elseif (!is_object($m)) {
                $m = (object) $m;
            }
            $m = $this->afterSend($m);

            // common context
            $ph = $this->previewAndHash((string) $msg);
            $meta = [
                'latency_ms' => (int) round((microtime(true) - $started) * 1000),
                'count'      => (int) $this->msgCountGetAndInit(),
                'remaining'  => null,     // fill once computed
                'stop'       => false,    // fill once set
                'lang_id'    => (int) ($langId ?? 0),   // use your resolved $langId, not $data['lang']
                'model'      => (string) $this->model,
                'endpoint'   => (stripos($this->model, 'gpt-5') === 0 ? '/v1/responses' : '/v1/chat/completions'),
                // for privacy, store only a preview + hash, not full text
                'user_msg'           => $ph['preview'],
                'user_msg_preview'   => $ph['preview'],
                'user_msg_hash'      => $ph['hash'],
            ];

            if (!$m->ok) {
                $meta['err_code'] = isset($m->error) ? (string)$m->error : 'unknown';
                $this->obsLog($m, $meta);
                // ... your existing error mapping & return
            } else {
                // ... your existing success handling, then:
                $after     = $this->msgCountInc();
                $remaining = $this->msgRemaining($after);
                $result->stop = ($remaining === 0);

                $meta['remaining']  = $remaining;
                $meta['stop']       = (bool)$result->stop;
                $meta['answer_len'] = strlen((string)strip_tags($result->html ?? $result->reply->msg ?? $m->text));
                $this->obsLog($m, $meta);
            }

        } catch (\Throwable $e) {
            $this->wire('log')->save('chatai', 'sendMessage model error: ' . $e->getMessage());
            $m = (object)['ok' => false, 'error' => 'exception'];
        }

        // Interpret
        if (!$m->ok) {
            $code = !empty($m->error) ? (string)$m->error : 'unknown';
            // log metrics
            $this->obsLog($m, $meta);

            // Normalize provider “too busy / quota / throttled” signals to case 15
            if (in_array($code, ['rate_limit_exceeded', 'rate_limit', 'insufficient_quota', 'throttled'], true)) {
                $result->error = $this->getErrorMessage(15); // object with msg + warning
                $result->stop  = false;                      // allow retry (your call)
                return $result;
            }

            // Everything else → generic failure (case 6)
            $result->error = $this->getErrorMessage(6);     // object with msg + warning
            $result->stop  = true;                          // or false, if you want retries
            return $result;
        }

        // Model returned success in $m->text
        $after     = $this->msgCountInc();
        $remaining = $this->msgRemaining($after);
        $result->stop = ($remaining === 0);

        $meta['remaining']  = $remaining;
        $meta['stop']       = (bool)$result->stop;
        $meta['answer_len'] = strlen((string)strip_tags($result->html ?? $result->reply->msg ?? $m->text));
        $this->obsLog($m, $meta);

        $raw = (string) $m->text; // expected HTML fragment per your prompt

        // HTML lane — sanitize allowed tags server-side
        // Build Purifier allowlist from config (HTML Purifier syntax)
        $allowed = trim((string)($this['values']['allowed_tags'] ?? 'p,ul,li,ol,strong,em,code,br,a[href]'));

        // Ensure anchor allows href if 'a' present without attribute
        if (preg_match('/(^|,)\\s*a(\\s*,|$)/i', $allowed)) {
            $allowed = preg_replace('/(^|,)\\s*a(\\s*,|$)/i', '$1a[href]$2', $allowed);
        }

        // Normalize spaces
        $allowed = implode(',', array_filter(array_map('trim', explode(',', $allowed))));

        $result->html = $this->wire('sanitizer')->purify(
            $raw,
            [ 'HTML.Allowed' => $allowed ]
        );

        // Plain-text fallback (for screen readers / no-HTML environments)
        $plain = trim(strip_tags($raw));
        $result->reply = (object)['msg' => $this->wire('sanitizer')->entities($plain)];

        // Increment + warnings
        $after     = $this->msgCountInc();
        $remaining = $this->msgRemaining($after);
        if ($remaining === 0) {
            $result->stop  = true;
            $result->error = $this->getErrorMessage(4);   // “Too many questions. Goodbye.”
        } elseif ($remaining === 1) {
            $result->error = $this->getErrorMessage(10);  // “One question left…” (warning=true)
        }
        return $result;
    }

    /** Example helper stubs  */
    protected function msgCountGetAndInit(): int {
        $s = $this->wire('session');
        $v = $s->getFor('chatai', 'count');
        if ($v === null) { $s->setFor('chatai', 'count', 0); return 0; }
        $n = (int)$v; return $n < 0 ? 0 : $n;
    }

    protected function msgCountInc(): int {
        $s = $this->wire('session');
        $n = (int)$s->getFor('chatai', 'count'); $n++;
        $s->setFor('chatai', 'count', $n);
        return $n;
    }

    protected function msgRemaining(int $after): int {
        return max(0, ((int)$this->max_messages) - $after);
    }

    // logs one compact JSON line
    protected function obsLog($result, array $meta = []): void {
        // config + sampling
        $cfg = $this->wire('modules')->get('ProcessChatAI')->loadPromptSettings();
        if (empty($cfg['obs_enabled'])) return;
        $sr = max(1, (int)($cfg['obs_sample_rate'] ?? 1));
        if (mt_rand(1, $sr) !== 1) return;

        // normalize result to array
        if (is_object($result)) $result = json_decode(json_encode($result), true);
        $result = is_array($result) ? $result : [];

        // build payload (prefer your stdClass shape: ok/text/error)
        $out = [
            't'          => date('c'),
            'event'      => 'reply',
            'ok'         => (bool)($result['ok'] ?? false),
            'err_code'   => $result['error'] ?? null,
            'answer_len' => isset($result['text']) ? strlen((string)$result['text']) : null,
        ];

        // merge context (latency, counts, model, endpoint, lang, etc.)
        foreach ($meta as $k => $v) $out[$k] = $v;

        // privacy: hash + preview user_msg if provided
        if (isset($out['user_msg'])) {
            $u = (string)$out['user_msg'];
            $out['user_msg_preview'] = mb_substr($u, 0, 120);
            $out['user_msg_hash']    = hash('sha256', $u);
            unset($out['user_msg']);
        }

        // Write to /site/assets/logs/chatai/chatai_metrics.txt
        $config = $this->wire('config');
        $files  = $this->wire('files');

        $dir  = $config->paths->logs . 'chatai/';
        $file = $dir . 'chatai_metrics.txt';

        if (!is_dir($dir)) {
            // ensures correct perms (uses $config->chmodDir)
            $files->mkdir($dir, true);
        }

        // lightweight rotation (optional)
        if (is_file($file) && filesize($file) > 5 * 1024 * 1024) { // 5 MB
            @rename($file, $file . '.' . date('Ymd-His'));
        }
        file_put_contents($file, json_encode($out, JSON_UNESCAPED_SLASHES) . PHP_EOL, FILE_APPEND | LOCK_EX);
    }

    /** @return array{preview:string, hash:string} */
    protected function previewAndHash(string $text, int $limit = 120): array
    {
        // Normalise to plain text
        if (class_exists('\ProcessWire\WireTextTools')) {
            $tt = new \ProcessWire\WireTextTools();
            $plain = $tt->markupToText($text);
        } else {
            $plain = strip_tags($text);
        }
        $plain = trim($plain);

        // Safe UTF-8
        if (!mb_detect_encoding($plain, 'UTF-8', true)) {
            $plain = mb_convert_encoding($plain, 'UTF-8', 'UTF-8');
        }

        // Preview
        $preview = mb_substr($plain, 0, $limit);
        if (mb_strlen($plain) > $limit) $preview .= '…';

        // Hash can include knobs that affect semantics
        $hash = hash('sha256', json_encode([
            'text'   => $plain,
            'model'  => (string) ($this->model ?? ''),
            'lang'   => (int) ($this->langId ?? 0),
            'system' => (string) ($this->systemPrompt ?? ''),
        ], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE));

        return ['preview' => $preview, 'hash' => $hash];
    }

    public function saveToTranscript(string $role, string $content): void {
        $san = $this->wire('sanitizer');
        $t   = $this->wire('session')->getFor('chatai', 'transcript') ?? [];
        $t[] = [
            'role'    => $san->name($role),         // 'system'|'user'|'assistant'
            'content' => $san->text($content),  // plain text normalization
            'ts'      => time(),
        ];

        $this->wire('session')->setFor('chatai', 'transcript', $t);
    }

