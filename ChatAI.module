<?php
/**
 * ProcessWire Chatbot Module - Core Functionality
 */

namespace ProcessWire;

use stdClass;

class ChatAI extends WireData implements Module, ConfigurableModule
{
    public const CHATAI_VEC_TABLE = 'chatai_vec_chunks';

    const dbTableName = 'chatai';

    const dbTablePrompt = 'chatai_prompt';

    const modName = 'ChatAI';

    /** @var \ProcessWire\RAG */
    protected ?\ProcessWire\RAG $rag = null;

    /** @var \ProcessWire\ChatAIIndexer */
    protected ?\ProcessWire\ChatAIIndexer $indexer = null;

    /** @var \ProcessWire\Classifier */
    protected ?\ProcessWire\Classifier $classifier = null;

    /** @var \ProcessWire\ChatAIObsLog */
    protected ?\ProcessWire\ChatAIObsLog $logger = null;

    protected ?\ProcessWire\ChatAIPromptService $promptService = null;


    public function construct()
    {
        parent::__construct();
    }

    public function init()
    {
        if($this->wire('process') && empty($this->api_key)) {
            $this->warning('OpenAI API key missing; ChatAI may not function.');
        }

        // Load helpers
        require_once __DIR__ . '/classes/Indexing/IndexContentExtractor.php';
        require_once __DIR__ . '/classes/Indexing/ChatAIIndexer.php';
        require_once __DIR__ . '/classes/RAG/RAG.php';
        require_once __DIR__ . '/classes/Classifier.php';
        require_once __DIR__ . '/classes/ChatAIObsLog.php';
        require_once __DIR__ . '/classes/ChatAIPromptService.php';

        // Shared services
        if($this->rag === null) {
            $this->rag = new \ProcessWire\RAG();
            $this->rag->setWire($this->wire());
        }

        if($this->indexer === null) {
            $this->indexer = new \ProcessWire\ChatAIIndexer();
            $this->indexer->setWire($this->wire());
        }

        if($this->classifier === null) {
            $this->classifier = new \ProcessWire\Classifier();
            $this->classifier->setWire($this->wire());
        }

        if($this->logger === null) {
            $this->logger = new \ProcessWire\ChatAIObsLog();
            $this->logger->setWire($this->wire());
        }

        if($this->promptService === null) {
            $this->promptService = new \ProcessWire\ChatAIPromptService();
            $this->promptService->setWire($this->wire());
        }

        // Hooks
        $this->addHookAfter('Pages::saved', function (HookEvent $event) {

            $page    = $event->arguments(0);
            $changes = (array) ($event->arguments(1) ?? []);

            $cfg = (array) $this->promptService()->loadPromptSettings();
            if(empty($cfg['chunk_on_save'])) return;

            $changedKeys    = array_keys($changes);
            $meaningfulKeys = array_diff($changedKeys, ['status', 'modified', 'template']);
            $contentChanged = !empty($meaningfulKeys);

            $this->processRagForPage($page, $cfg, [
                'mode'           => 'on_save',
                'contentChanged' => $contentChanged,
                'dryRun'         => false,
            ]);
        });

        $this->addHookAfter('Pages::deleted', function($event) {
            $page = $event->arguments(0);
            $rag  = $this->rag();
            try { $rag->deletePageVectors($page); }
            catch (\Throwable $e) { $this->wire('log')->save('chatai', 'Index delete error: ' . $e->getMessage()); }
        });

        $this->addHookAfter('ImportPagesCSV::execute', function(HookEvent $event) {

            $svc = $this->promptService();
            $cfg = $svc->loadPromptSettings();
            if (!empty($cfg['chunk_on_save'])) {
                $ips = $event->object;
                $ips->warning(
                    $this->_('ChatAI "Update on Save" is currently enabled. For large imports, consider turning it off temporarily to avoid heavy re-indexing during import.')
                );
            }
        });

        $this->addHookAfter('Languages::deleted', function(HookEvent $event) {

            $language = $event->arguments(0); // Page
            if(!$language || !$language->id) return;

            $langId = (int) $language->id;

            try {
                $this->rag()->deleteLanguageVectors($langId); // implement this
                $this->wire('log')->save('chatai', "Deleted vectors for removed language lang_id={$langId}");
            } catch(\Throwable $e) {
                $this->wire('log')->save('chatai', "Language vector delete failed lang_id={$langId}: " . $e->getMessage());
            }
        });

     }

