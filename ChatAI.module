<?php
/**
 * ProcessWire Chatbot Module - Core Functionality
 */

namespace ProcessWire;

use stdClass;

class ChatAI extends WireData implements Module, ConfigurableModule
{
    const dbTableName = 'chatai';

    const dbTablePrompt = 'chatai_prompt';

    const modName = 'ChatAI';

    /** @var \ProcessWire\RAG */
    protected ?\ProcessWire\RAG $rag = null;

    /** @var \ProcessWire\ChatAIIndexer */
    protected ?\ProcessWire\ChatAIIndexer $indexer = null;

    /** @var \ProcessWire\Classifier */
    protected ?\ProcessWire\Classifier $classifier = null;

    /** @var \ProcessWire\ChatAIObsLog */
    protected ?\ProcessWire\ChatAIObsLog $logger = null;

    protected ?\ProcessWire\ChatAIPromptService $promptService = null;


    public function construct()
    {
        parent::__construct();
    }

    public function init()
    {
        if($this->wire('process') && empty($this->api_key)) {
            $this->warning('OpenAI API key missing; ChatAI may not function.');
        }

        // Load helpers
        require_once __DIR__ . '/classes/Indexing/IndexContentExtractor.php';
        require_once __DIR__ . '/classes/Indexing/ChatAIIndexer.php';
        require_once __DIR__ . '/classes/RAG/RAG.php';
        require_once __DIR__ . '/classes/Classifier.php';
        require_once __DIR__ . '/classes/ChatAIObsLog.php';
        require_once __DIR__ . '/classes/ChatAIPromptService.php';

        // Shared services
        if($this->rag === null) {
            $this->rag = new \ProcessWire\RAG();
            $this->rag->setWire($this->wire());
        }

        if($this->indexer === null) {
            $this->indexer = new \ProcessWire\ChatAIIndexer();
            $this->indexer->setWire($this->wire());
        }

        if($this->classifier === null) {
            $this->classifier = new \ProcessWire\Classifier();
            $this->classifier->setWire($this->wire());
        }

        if($this->logger === null) {
            $this->logger = new \ProcessWire\ChatAIObsLog();
            $this->logger->setWire($this->wire());
        }

        if($this->promptService === null) {
            $this->promptService = new \ProcessWire\ChatAIPromptService();
            $this->promptService->setWire($this->wire());
        }

        // Hooks
        $this->addHookAfter('Pages::saved', function ($event) {
            $page = $event->arguments(0);
            $changes = (array)($event->arguments(1) ?? []);

            $chatai = $this->wire('modules')->get('ChatAI');

            $svc = $chatai->promptService();
            $cfg = $svc->loadPromptSettings();

            if(!isset($cfg['chunk_on_save'])) return;
            $rag = $chatai->rag();

            try {
                $shouldReindex = $rag->shouldReindex($page);
            } catch (\Throwable $e) {
                $this->wire('log')->save('chatai', 'shouldReindex error: ' . $e->getMessage());
            }

            $changedKeys = array_keys($changes);
            $meaningfulKeys = array_diff($changedKeys, ['status', 'modified', 'template']);
            $contentChanged = !empty($meaningfulKeys);

            if (!$shouldReindex && !$contentChanged) {
                return;
            }

            if($page->isTrash() || !$chatai->validTemplate($page, $cfg)) {
                try {
                    $rag->deletePageVectors($page);
                } catch (\Throwable $e) {
                    $this->wire('log')->save('chatai', "Page not removed from vec db, Page id $page->id: " . $e->getMessage());
                }
            }

            if ($contentChanged && $shouldReindex) {
                try {
                    $rag->deletePageVectors($page);
                    $languages = $this->wire('languages');
                    if($languages && $languages->count()) {
                        foreach($languages as $lang) {
                            $rag->collectPageText($page, $cfg);
                        }
                    } else {
                        $rag->collectPageText($page, $cfg);
                    }
                } catch (\Throwable $e) {
                    $this->wire('log')->save('chatai', "Index upsert error, Page id $page->id : " . $e->getMessage());
                }
            }
        });

        $this->addHookAfter('Pages::deleted', function($event) {
            $page = $event->arguments(0);
            $chatai = $this->wire('modules')->get('ChatAI');
            $rag  = $chatai->rag();
            try { $rag->deletePageVectors($page); }
            catch (\Throwable $e) { $this->wire('log')->save('chatai', 'Index delete error: ' . $e->getMessage()); }
        });

        $this->addHookAfter('ImportPagesCSV::execute', function(HookEvent $event) {

            $chatai = $this->wire('modules')->get('ChatAI');
            $svc = $chatai->promptService();
            $cfg = $svc->loadPromptSettings();
            if (!empty($cfg['chunk_on_save'])) {
                $ips = $event->object;
                $ips->warning(
                    $this->_('ChatAI "Update on Save" is currently enabled. For large imports, consider turning it off temporarily to avoid heavy re-indexing during import.')
                );
            }
        });

    }

    public function getModuleConfigInputfields(array $data) : InputfieldWrapper
    {
        $modules     = wire('modules');
        $inputfields = new InputfieldWrapper();

        // OpenAI Settings
        $fieldset = $modules->get('InputfieldFieldset');
        $fieldset->attr('name+id', 'openai');
        $fieldset->label = $this->_('OpenAI Settings');

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'api_key');
        $f->label = $this->_('OpenAI API Key');
        $f->required = true;
        $f->collapsed = 5;
        $f->value = $data['api_key'] ?? '';
        $fieldset->add($f);

        // Model select – GPT-5 family only
        $f = $modules->get('InputfieldSelect');
        $f->attr('name+id', 'model');
        $f->label = $this->_('OpenAI Model');
        $f->columnWidth = 20;
        $f->addOptions([
            'gpt-5-mini' => 'gpt-5-mini (default)',
            'gpt-5-nano' => 'gpt-5-nano',
            'gpt-5.2'    => 'gpt-5.2',
            'gpt-5'      => 'gpt-5',
            'gpt-5.1'    => 'gpt-5.1',
        ]);
        $f->value = $data['model'] ?? 'gpt-5-mini';
        $fieldset->add($f);

        // Verbosity (used by your buildPostData; always visible now)
        $f = $modules->get('InputfieldSelect');
        $f->attr('name+id', 'verbosity');
        $f->label = $this->_('Verbosity');
        $f->columnWidth = 20;
        $f->addOptions([
            'low'    => 'Low',
            'medium' => 'Medium',
            'high'   => 'High',
        ]);
        $f->value = $data['verbosity'] ?? 'medium';
        $fieldset->add($f);

        // Reasoning Effort (GPT-5 style knob; always visible now)
        $f = $modules->get('InputfieldSelect');
        $f->attr('name+id', 'reasoningEffort');
        $f->label = $this->_('Reasoning Effort');
        $f->columnWidth = 20;
        $f->addOptions([
            'minimal' => 'Minimal',
            'low'     => 'Low',
            'medium'  => 'Medium',
            'high'    => 'High',
        ]);
        $f->value = $data['reasoningEffort'] ?? 'medium';
        $fieldset->add($f);

        // Max tokens per message (Responses: max_output_tokens)
        $f = $modules->get('InputfieldInteger');
        $f->attr('name+id', 'max_completion_tokens');
        $f->label = $this->_('Max tokens');
        $f->columnWidth = 20;
        $f->notes = $this->_('Max tokens per message');
        $f->value = $data['max_completion_tokens'] ?? 1000;
        $fieldset->add($f);

        // Max questions per conversation
        $f = $modules->get('InputfieldInteger');
        $f->attr('name+id', 'max_messages');
        $f->label = $this->_('Maximum questions');
        $f->columnWidth = 20;
        $f->notes = $this->_('Max questions per conversation');
        $f->value = $data['max_messages'] ?? 20;
        $fieldset->add($f);

        // Blacklist strikes
        $f = $modules->get('InputfieldInteger');
        $f->attr('name+id', 'max_strikes');
        $f->label = $this->_('Maximum blacklist');
        $f->columnWidth = 20;
        $f->notes = $this->_('Number of blacklist strikes before being blocked');
        $f->value = $data['max_strikes'] ?? 3;
        $fieldset->add($f);

        $inputfields->add($fieldset);

// Roles allowed to access ChatAI dashboard / craft prompt
        $f = $modules->get('InputfieldCheckboxes');
        $f->attr('name+id', 'prompt_roles');
        $f->label = $this->_('Roles allowed to craft prompt');
        $roles = $this->wire('roles');
        $options = [];

        // List all roles except guest and superuser.
        // Superuser is always allowed;
        foreach ($roles as $role) {
            if ($role->name === 'superuser') continue;
            $options[$role->name] = $role->name;
        }

        $f->addOptions($options);

        // Stored as an array of role names; if empty, only superuser can use the dashboard
        $f->value = $data['prompt_roles'] ?? [];

        $f->columnWidth = 50;
        $note = $this->_(
            "Superuser is always allowed.\r\n" .
            "If no roles are selected, only superusers can access the ChatAI dashboard tabs.\r\n" .
            "Select one or more roles (for example the 'chatai' role created on install) to allow them as well."
        );
        $f->notes($note);
        $inputfields->add($f);

        // File locations
        $fieldset = $modules->get('InputfieldFieldset');
        $fieldset->attr('name+id', 'files');
        $fieldset->label($this->_('Files'));

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'widget');
        $f->label($this->_('Path to widget file'));
        $f->notes("Default is /site/modules/ChatAI/chatai-widget.php");
        $value = $data['widget'] ?? '/site/modules/ChatAI/chatai-widget.php';
        $f->attr('value', $value);
        $f->stripTags = true;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'css');
        $f->label($this->_('Path to CSS file'));
        $f->notes("Default is /site/modules/ChatAI/chatai.css");
        $value = $data['css'] ?? '/site/modules/ChatAI/chatai.css';
        $f->attr('value', $value);
        $f->stripTags = true;
        $fieldset->add($f);

        $f = $modules->get('InputfieldText');
        $f->attr('name+id', 'js');
        $f->label($this->_('Path to JS file'));
        $f->notes("Default is /site/modules/ChatAI/chatai.js");
        $value = $data['js'] ?? '/site/modules/ChatAI/chatai.js';
        $f->attr('value', $value);
        $f->stripTags = true;
        $fieldset->add($f);

        $inputfields->add($fieldset);

        return $inputfields;
    }

    /* Module functions */

    /* Class getters */

    public function rag(): \ProcessWire\RAG
    {
        return $this->rag;
    }

    public function indexer(): \ProcessWire\ChatAIIndexer
    {
        return $this->indexer;
    }

    public function classifer(): \ProcessWire\Classifier
    {
        return $this->classifier;
    }

    public function logger(): \ProcessWire\ChatAIObsLog
    {
        return $this->logger;
    }

    public function promptService(): \ProcessWire\ChatAIPromptService
    {
        return $this->promptService;
    }





    public function renderWidget() : string
    {
        $config = wire('config');
        $path = $config->paths->root . ltrim($this->widget, '/');
        return $this->promptService()->getWidget($path);
    }

    public function renderStyles() : string
    {
        $css = "<link rel='stylesheet' href='$this->css' type='text/css'>";
        return $css;
    }

    public function renderScript() : string
    {
        $js = "<script src='$this->js' ></script>";
        return $js;
    }


    public function isMessageAllowed($message) : \stdClass {
       // $chatProcess = $this->wire('modules')->get('ProcessChatAI');
        $session     = $this->wire('session');

        $output = new \stdClass(); // optional: fully qualify
        $output->name        = $this->promptService()->getBotName();
        $output->blacklisted = false;
        $output->stop        = false;
        $output->error       = null;
        $output->reply       = null;
        $output->html        = null;

        // Optional: resolve lang ID once for logging
        // so you do not depend on an external $langId variable.
        $langId = (int) ($this->wire('user')->language->id ?? 0);

        // Check message is not empty. Fallback from HTML check
        if ($message === '') {
            $output->error = $this->getErrorMessage(2);
            return $output;
        }

        // blacklist check
        $blacklistTerm = $this->promptService()->isBlacklistTerm($message);
        if (!$blacklistTerm) {
            return $output;
        }

        $strikes = (int) ($session->getFor('chatai', 'blacklist_strikes') ?? 0) + 1;
        $session->setFor('chatai', 'blacklist_strikes', $strikes);

        if ($strikes && $strikes >= $this->max_strikes) {
            $output->stop          = true;
            $output->blacklistTerm = true;       // optional: also set $output->blacklisted = true;
            $output->blacklisted   = true;
            $err = $this->getErrorMessage(13);

            // Log hard blacklist event with IP
            try {
                $ip = (string) $this->wire('input')->ip;

                $ph = $this->previewAndHash((string) $message);

                $meta = [
                    'event'            => 'blocked',
                    'chat_id'          => $this->getCurrentChatId(),
                    'ip'               => $ip,
                    'ip_hash'          => hash('sha256', $ip),
                    'reason'           => 'blacklist',
                    'lang_id'          => (int) ($langId ?? 0),
                    'user_msg_preview' => $ph['preview'],
                    'user_msg_hash'    => $ph['hash'],
                ];

                $this->obsLog(['ok' => false, 'error' => 'blacklist'], $meta);
            } catch (\Throwable $e) {
                $this->wire('log')->save('chatai-obslog', $e->getMessage());
            }

        } else {
            $output->stop = false;
            $err = $this->getErrorMessage(14, $strikes, $this->max_strikes);
        }

        $output->error = $err;
        $output->reply = $err->msg;

        return $output;
    }

    protected function getCurrentChatId(): string
    {
        $session = $this->wire('session');

        $chatId = (string) $session->getFor('chatai', 'chat_id');
        if (!$chatId) {
            // Short, opaque id; not user-identifying
            $chatId = bin2hex(random_bytes(8)); // 16 hex chars
            $session->setFor('chatai', 'chat_id', $chatId);
        }

        return $chatId;
    }


    private function buildPostData(string $model, array $messages): \stdClass {
        $p = new \stdClass();
        $p->model    = $model;
        $p->messages = $messages;

        switch (true) {
            // GPT-5 family: use new controls, do not send sampling knobs
            case stripos($model, 'gpt-5') === 0:
                // keep using your existing limit name to avoid refactors
                if (!empty($this->max_completion_tokens)) {
                    $p->max_completion_tokens = (int) $this->max_completion_tokens;
                }
                if (!empty($this->verbosity)) {
                    $p->verbosity = $this->verbosity;                 // low|medium|high
                }
                if (!empty($this->reasoning_effort)) {
                    $p->reasoning_effort = $this->reasoning_effort;   // minimal|low|medium|high
                }
                // intentionally DO NOT set: temperature, top_p, presence_penalty, frequency_penalty
                break;

            // Keep for newer models
            default:
                break;
        }
        return $p;
    }

    /**
     * Decide endpoint + normalize body per model family.
     * Returns [string $url, array $body]
     */
    protected function normalizeApiRequest(string $model, $payload): array
    {
        // deep-cast stdClass → array for [] access
        if (is_object($payload)) $payload = json_decode(json_encode($payload), true);
        $payload = is_array($payload) ? $payload : [];

        $isGpt5 = (stripos($model, 'gpt-5') === 0);

        if ($isGpt5) {
            // GPT-5 → Responses API with `input`
            $endpoint = 'https://api.openai.com/v1/responses';

            // Coerce messages into strings using referenced &$m
            $messages = isset($payload['messages']) && is_array($payload['messages']) ? $payload['messages'] : [];
            foreach ($messages as &$m) {
                if (!isset($m['role'])) $m['role'] = 'user';
                if (!isset($m['content'])) $m['content'] = '';
                if (!is_string($m['content'])) {
                    $m['content'] = is_scalar($m['content']) ? (string)$m['content'] : json_encode($m['content']);
                }
            }
            unset($m);

            // Map chat messages → Responses `input`
            $input = [];
            foreach ($messages as $m) {
                $role = (string)$m['role'];
                // assistant history must be output_text or refusal
                $type = ($role === 'assistant') ? 'output_text' : 'input_text';
                $part = ['type' => $type, 'text' => (string)$m['content']];
                $input[] = [
                    'role' => $role,          // 'system' | 'user' | 'assistant'
                    'content' => [$part],
                ];
            }

            $body = [
                'model' => (string)$model,
                'input' => $input,
            ];

            // tokens/temperature/reasoning mapping stays the same
            if (isset($payload['max_completion_tokens'])) $body['max_output_tokens'] = (int)$payload['max_completion_tokens'];
            //if (isset($payload['temperature'])) $body['temperature'] = (float)$payload['temperature'];
            if (!empty($payload['reasoning_effort'])) $body['reasoning'] = ['effort' => (string)$payload['reasoning_effort']];
            // drop verbosity (not public)


        }
        return [$endpoint, $body];
    }

    public function callModelForText(array $messagesForApi): \stdClass {
        $o = (object)['ok' => false];

        $postData = $this->buildPostData($this->model, $messagesForApi);
        list($url, $body) = $this->normalizeApiRequest($this->model, $postData);

        $http = new \ProcessWire\WireHttp();
        $http->setHeaders([
            'Authorization' => 'Bearer ' . $this->api_key,
            'Content-Type'  => 'application/json',
            'Accept'        => 'application/json',
        ]);
        $http->setTimeout(25);

        try {

            $response = $http->send($url, json_encode($body), 'POST');
            if ($response === false) {
                $this->wire('log')->save('chatai', 'OpenAI transport error: ' . $http->getError());
                $o->error = 'transport_error';
                return $o;
            }
            $data = json_decode($response, true);

            if (!is_array($data)) {
                $this->wire('log')->save('chatai', 'OpenAI: unexpected non-JSON response');
                $o->error = 'unexpected_response';
                return $o;
            }

            $isResponses = (strpos($url, '/responses') !== false);

            // Responses API: detect cutoff early
            if ($isResponses) {
                $status = $data['status'] ?? null;
                $reason = $data['incomplete_details']['reason'] ?? null;

                if ($status === 'incomplete' && $reason === 'max_output_tokens') {
                    $partial = '';

                    if (!empty($data['output']) && is_array($data['output'])) {
                        foreach ($data['output'] as $seg) {
                            if (empty($seg['content']) || !is_array($seg['content'])) continue;

                            foreach ($seg['content'] as $c) {
                                $type = $c['type'] ?? '';
                                if ($type !== 'output_text' && $type !== 'text') continue;
                                if (empty($c['text'])) continue;

                                $text = $c['text'];

                                // Responses text object: ['value' => '...', ...]
                                if (is_array($text) && isset($text['value'])) {
                                    $text = $text['value'];
                                }

                                if (is_string($text) && $text !== '') {
                                    $partial .= $text;
                                }
                            }
                        }
                    }

                    $o->ok     = true;
                    $o->text   = $partial;
                    $o->cutoff = true; // flag up to sendMessage()
                    return $o;
                }
            }

            // Normal success shapes:

            if ($isResponses) {
                // Modern Responses output → content → type=output_text
                if (!empty($data['output']) && is_array($data['output'])) {
                    foreach ($data['output'] as $seg) {
                        if (empty($seg['content']) || !is_array($seg['content'])) continue;

                        foreach ($seg['content'] as $c) {
                            $type = $c['type'] ?? '';
                            if ($type !== 'output_text' && $type !== 'text') continue;
                            if (empty($c['text'])) continue;

                            $text = $c['text'];

                            // Handle object form: { value: '...', ... }
                            if (is_array($text) && isset($text['value'])) {
                                $text = $text['value'];
                            }

                            if (is_string($text)) {
                                $o->ok   = true;
                                $o->text = $text;
                                return $o;
                            }
                        }
                    }
                }

                // Some providers mirror chat-like choices
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok   = true;
                    $o->text = (string)$data['choices'][0]['message']['content'];
                    return $o;
                }

            } else {
                // /chat/completions (generic, no gpt-4 specifics)
                if (!empty($data['choices'][0]['message']['content'])) {
                    $o->ok   = true;
                    $o->text = (string)$data['choices'][0]['message']['content'];
                    return $o;
                }
            }

            // Provider error surfaced
            if (!empty($data['error'])) {
                $code = strtolower((string)($data['error']['code'] ?? 'provider_error'));
                if (in_array($code, ['rate_limit_exceeded','rate_limit','insufficient_quota','throttled'], true)) {
                    $code = 'rate_limit_exceeded';
                }
                $this->wire('log')->save('chatai', 'OpenAI error: ' . $code . ' | ' . ($data['error']['message'] ?? ''));
                $o->error      = $code;
                $o->chat_error = $data['error'];
                return $o;
            }

            // Unexpected success shape
            $this->wire('log')->save('chatai', 'OpenAI: missing choices/content | body=' . substr($response, 0, 500));
            $o->error = 'unexpected_response';
            return $o;

        } catch (\Throwable $e) {
            $this->wire('log')->save('chatai', 'OpenAI exception: ' . $e->getMessage());
            $o->error = 'exception';
            return $o;
        }
    }

    public function sendMessage(string $userMessage, $langId = null, int $pid = null, string $url = null, $meta = []): \stdClass
    {
        $san = $this->wire('sanitizer');
        $user = $this->wire('user');

        $result = (object)[
            'stop'        => false,
            'error'       => null,                  // (object){msg:string, warning?:bool} or null
            'reply'       => null,                  // (object){msg:string} or null
            'html'        => null,                  // optional trusted HTML
            'blacklisted' => false,
            'name'        => null,
        ];

        // Language switch (soft)
        if ($langId !== null) {
            try {
                $langId = (int)$san->int($langId);
                $languages = $this->wire('languages');
                if ($languages && $langId) {
                    $lang = $languages->get($langId);
                    if ($lang && $lang->id) $languages->setLanguage($lang);
                }
            } catch (\Throwable $e) { /* ignore */ }
        }
        $result->name = $this->promptService()->getBotName();

        // Validate
        $msg = $san->text($userMessage);

        // Context for CTA hook
        $payload = [
            'status'    => 'ok',
            'openai_error'  => null,
            'msg'  => $msg,
            'reply' => '',
            'error'     => null,
            'pageId'    => $pid,
            'url'       => $url,
        ];


        $result = $this->isMessageAllowed($msg);
        if($result && $result->error) {
            // Optional CTA
            $payload['status'] = 'not_allowed';
            $payload['error'] = $result->error;
            $ctaHtml = $this->afterResponse($payload);
            if ($ctaHtml) {
                $result->cta = $ctaHtml;
            }
            return $result;
        }

        $messages = [];
        $svc = $this->promptService();

        $session = $this->wire('session');
        $system = $session->getFor('chatai','system_prompt');
        if (!$system) {
            $system = ['role'=>'system','content'=>$svc->getPrompt()];
            $session->setFor('chatai','system_prompt', $system);
        }
        $messages[] = ['role'=>'system','content'=> $system];

        // Classify message for context
        $decision = $this->classifier->classify($msg);

        $cfg = $svc->loadPromptSettings();
        $userLangId = $user->language->id;

        $cfgLang = function(string $key) use ($cfg, $userLangId) {
            $k = $key . '__' . $userLangId;
            return (string)($cfg[$k] ?? $cfg[$key] ?? '');
        };

        $label   = (string)($decision['label'] ?? '');

        // Quick out if small talk
        if($label === 'small_talk') {
            $result->reply = $cfgLang('smalltalk_reply') ?: 'Hello. How can I help you today?';
            // Optional CTA
            $payload['status'] = $label;
            $payload['replyText'] = $result->reply;
            $ctaHtml = $this->afterResponse($payload);
            if ($ctaHtml) {
                $result->cta = $ctaHtml;
            }
            return $result;
        }

        // RAG path
        $top = $this->rag->retrieveTopK($msg, $userLangId, 6);
        if(!empty($top)) {
            $context = $this->rag->buildContextFromChunks($top);
        } else {
            switch ($label) {
                case 'meta':
                    $result->reply = $cfgLang('meta_reply') ?: $cfgLang('no_context_reply')
                        ?: 'I can help with pages and information on this site. Ask me what you’re looking for.';
                    break;

                case 'action':
                    $result->reply = $cfgLang('action_reply') ?: "Sure. Tell me what you'd like me to do with the site content.";
                    break;

                case 'ambiguous':
                    // Optional: detect follow-up and prefer followup_reply
                    if ($follow = $cfgLang('followup_reply')) {
                        $result->reply = $follow;
                    } else {
                        $result->reply = $cfgLang('no_context_reply')
                            ?: 'Tell me what you’re looking for and I’ll point you to the right page.';
                    }
                    break;
            }
            // Optional CTA
            $payload['status'] = $label;
            $payload['replyText'] = $result->reply;
            $ctaHtml = $this->afterResponse($payload);
            if ($ctaHtml) {
                $result->cta = $ctaHtml;
            }
            return $result;
        }

        // optional: add RAG context as an extra system message if you built it
        $hist = $session->getFor('chatai','history') ?? [];
        $hist[] = ['role'=>'user','content'=>$msg];
        $hist = array_slice($hist, -6); // keep last ~6 entries total
        $session->setFor('chatai','history', $hist);
        if (!empty($context)) $messages[] = ['role'=>'system','content'=>"Site context:\n".$context];
        foreach ($hist as $h) $messages[] = $h;


        // User message last
        $messages[] = ['role' => 'user', 'content' => $msg];

        // Message limit: only applies to OpenAI calls
        $credit = $this->consumeMessageCredit();
        if (!empty($credit['blocked'])) {
            $result->error = $this->getErrorMessage(4); // reached limit
            $result->stop  = true;
            // Optional CTA
            $payload['status'] = 'blocked';
            $payload['error'] = $result->error;
            $payload['replyText'] = $result->reply;
            $ctaHtml = $this->afterResponse($payload);
            if ($ctaHtml) {
                $result->cta = $ctaHtml;
            }
            return $result;
        }

        // Model call
        try {
           $started = microtime(true);
            // After the API call
            $messages = $this->beforeSend($messages);
            $m = $this->callModelForText($messages);
            // Normalize to object
            if (is_string($m)) {
                $decoded = json_decode($m, false);          // decode as object
                $m = $decoded ?? (object)[];
            } elseif (is_array($m)) {
                $m = (object) $m;
            } elseif (!is_object($m)) {
                $m = (object) $m;
            }

            $m = $this->afterSend($m);

            // If the low-level wrapper flagged a cutoff, record it on the result
            if (!empty($m->cutoff)) {
                $result->cutoff = true;
                $result->error  = $this->getErrorMessage(20);
            }

            // Common context
            $ph = $this->previewAndHash((string) $msg);
            $event = !empty($result->cutoff) ? 'cutoff' : 'reply';

            $meta = [
                'event'            => $event,
                'chat_id'          => $this->getCurrentChatId(),
                'latency_ms'       => (int) round((microtime(true) - $started) * 1000),
                'count'            => (int) ($credit['count'] ?? 0),
                'remaining'        => (int) ($credit['remaining'] ?? 0),
                'max_messages'     => (int) ($credit['max'] ?? 0),
                'stop'             => false,
                'lang_id'          => (int) ($userLangId ?? 0),
                'model'            => (string) $this->model,
                'endpoint'         => (stripos($this->model, 'gpt-5') === 0 ? '/v1/responses' : '/v1/chat/completions'),
                'cutoff'           => !empty($result->cutoff),
                'user_msg_preview' => $ph['preview'],
                'user_msg_hash'    => $ph['hash'],

            ];

            if (!$m->ok) {
                $meta['err_code'] = isset($m->error) ? (string)$m->error : 'unknown';
                $this->obsLog($m, $meta);

                // Optional CTA (no return yet)
                $payload['status'] = 'failed';
                $payload['error'] = $meta['err_code'];
                $payload['replyText'] = $result->reply;

            } else {
                // Limit check
                $meta['stop']       = (bool)$result->stop;
                $meta['answer_len'] = strlen((string)strip_tags($result->html ?? $result->reply->msg ?? $m->text));
                $this->obsLog($m, $meta);
            }
        } catch (\Throwable $e) {
            $this->wire('log')->save('chatai', 'sendMessage model error: ' . $e->getMessage());
            $m = (object)['ok' => false, 'error' => 'exception'];

            // Ensure meta exists so later code does not see an undefined variable
            if (!isset($meta)) {
                $meta = [];
            }
        }

        // Interpret
        if (!$m->ok) {
            $code = !empty($m->error) ? (string)$m->error : 'unknown';

            // Normalize provider “too busy / quota / throttled” signals to case 15
            if (in_array($code, ['rate_limit_exceeded', 'rate_limit', 'insufficient_quota', 'throttled'], true)) {
                $result->error = $this->getErrorMessage(15); // object with msg + warning
                $result->stop  = false;

                // Optional CTA
                $payload['status'] = $code;
                $payload['replyText'] = $result->reply;
                $payload['error'] = $result->error;
                $ctaHtml = $this->afterResponse($payload);
                if ($ctaHtml) {
                    $result->cta = $ctaHtml;
                }
                return $result;
            }

            // Everything else → generic failure (case 6)
            $result->error = $this->getErrorMessage(6);     // object with msg + warning
            $result->stop  = true;                          // or false, if you want retries

            // Optional CTA
            $payload['status'] = 'failed';
            $payload['replyText'] = $result->reply;
            $payload['error'] = $result->error;
            $ctaHtml = $this->afterResponse($payload);
            if ($ctaHtml) {
                $result->cta = $ctaHtml;
            }
            return $result;
        }

        $raw = (string) $m->text; // expected HTML fragment per your prompt

        // Sanitize allowed tags server-side
        $allowed = trim((string)($this['values']['allowed_tags'] ?? 'p,ul,li,ol,strong,em,code,br,a[href]'));

        // Ensure anchor allows href if 'a' present without attribute
        if (preg_match('/(^|,)\\s*a(\\s*,|$)/i', $allowed)) {
            $allowed = preg_replace('/(^|,)\\s*a(\\s*,|$)/i', '$1a[href]$2', $allowed);
        }

        // Normalize spaces
        $allowed = implode(',', array_filter(array_map('trim', explode(',', $allowed))));

        $result->html = $this->wire('sanitizer')->purify(
            $raw,
            [ 'HTML.Allowed' => $allowed ]
        );

        // Plain-text fallback (for screen readers / no-HTML environments)
        $plain = trim(strip_tags($raw));
        $result->reply = (object)['msg' => $this->wire('sanitizer')->entities($plain)];

        if ($plain !== '') {
            $hist[] = ['role'=>'assistant','content'=>$plain];
            $session->setFor('chatai','history', array_slice($hist, -6));
        }


        $meta['remaining'] = (int) $credit['remaining'];
        $meta['count']     = (int) ($credit['count'] ?? 0);

        // Use remaining credits to warn/stop (OpenAI-call budget)
        // Do NOT show the "one left" warning if cutoff already forces a hard stop UX.
        if (empty($result->cutoff) && isset($credit['remaining']) && (int)$credit['max'] > 0) {

            $remaining = (int) $credit['remaining'];

            if ($remaining === 1) {
                if (empty($result->stop)) { // only if not already a hard stop
                    $result->error = $this->getErrorMessage(10);
                    $result->stop  = false;
                }
            } elseif ($remaining === 0) {
                $result->error = $this->getErrorMessage(4); // or 11
                $result->stop  = true;
                $payload['status'] = 'cutoff';
                $payload['error'] = $result->error;
            }
        }

        // Optional CTA
        $payload['replyText'] = $result->reply;
        $ctaHtml = $this->afterResponse($payload);
        if ($ctaHtml) {
            $result->cta = $ctaHtml;
        }
        return $result;
    }

    /** Example helper stubs  */

    protected function consumeMessageCredit(): array
    {
        $session = $this->wire('session');
        $max = (int) $this->max_messages;

        if ($max <= 0) {
            return ['blocked' => false, 'max' => 0, 'count' => 0, 'remaining' => 0];
        }

        $count = (int) ($session->getFor('chatai', 'count') ?? 0);

        if ($count >= $max) {
            return ['blocked' => true, 'max' => $max, 'count' => $count, 'remaining' => 0];
        }

        $count++;
        $session->setFor('chatai', 'count', $count);

        return [
            'blocked'   => false,
            'max'       => $max,
            'count'     => $count,
            'remaining' => max(0, $max - $count),
        ];
    }

    public function getObsLog(): \ProcessWire\ChatAIObsLog
    {
        return $this->logger;
    }


    // logs one compact event to chatai_obslog
    protected function obsLog($result, array $meta = []): void
    {
        // 1) Normalise result to array
        if (is_object($result)) {
            $result = json_decode(json_encode($result), true);
        }
        $result = is_array($result) ? $result : [];

        // 2) Build core payload
        $ok      = (bool)($result['ok'] ?? false);
        $errCode = $result['error'] ?? null;

        // Ignore empty, non-informative calls (no meta, no ok flag, no error)
        if (!$ok && $errCode === null && empty($meta)) {
            return;
        }

        $out = [
            't'        => date('c'),
            'event'    => $meta['event'] ?? 'reply',
            'ok'       => $ok,
            'err_code' => $errCode,
        ];

        // Merge caller meta (latency, model, lang, etc)
        foreach ($meta as $k => $v) {
            $out[$k] = $v;
        }

        // 3) Map to obslog columns
        $chatId    = isset($out['chat_id']) ? (string) $out['chat_id'] : '';
        $eventType = isset($out['event']) ? (string) $out['event'] : 'reply';
        $status    = $ok ? 'ok' : 'failed';
        $model     = isset($out['model']) ? (string) $out['model'] : '';

        // Everything else goes into meta JSON
        $metaForDb = $out;
        unset($metaForDb['t'], $metaForDb['event']);

        // 4) Write to chatai_obslog via ChatAI service
        try {
            /** @var \ProcessWire\ChatAI|null $chatAI */
            $chatAI = $this->wire('modules')->get('ChatAI');
            if (!$chatAI || !method_exists($chatAI, 'getObsLog')) return;

            $logger = $chatAI->getObsLog();
            if (!$logger) return;

            $logger->log($eventType, [
                'chat_id' => $chatId,
                'status'  => $status,
                'model'   => $model,
                'meta'    => $metaForDb,
            ]);

        } catch (\Throwable $e) {
            // Final safety net: nothing here should ever break chat
            $this->wire('log')->save('chatai-obslog', $e->getMessage());
        }
    }

    /** @return array{preview:string, hash:string} */
    protected function previewAndHash(string $text, int $limit = 120): array
    {
        // Normalise to plain text
        if (class_exists('\ProcessWire\WireTextTools')) {
            $tt = new \ProcessWire\WireTextTools();
            $plain = $tt->markupToText($text);
        } else {
            $plain = strip_tags($text);
        }
        $plain = trim($plain);

        // Safe UTF-8
        if (!mb_detect_encoding($plain, 'UTF-8', true)) {
            $plain = mb_convert_encoding($plain, 'UTF-8', 'UTF-8');
        }

        // Preview
        $preview = mb_substr($plain, 0, $limit);
        if (mb_strlen($plain) > $limit) $preview .= '…';

        // Hash can include knobs that affect semantics
        $hash = hash('sha256', json_encode([
            'text'   => $plain,
            'model'  => (string) ($this->model ?? ''),
            'lang'   => (int) ($this->langId ?? 0),
            'system' => (string) ($this->systemPrompt ?? ''),
        ], JSON_UNESCAPED_UNICODE | JSON_INVALID_UTF8_SUBSTITUTE));

        return ['preview' => $preview, 'hash' => $hash];
    }

    public function saveToTranscript(string $role, string $content): void {
        $san = $this->wire('sanitizer');
        $t   = $this->wire('session')->getFor('chatai', 'transcript') ?? [];
        $t[] = [
            'role'    => $san->name($role),         // 'system'|'user'|'assistant'
            'content' => $san->text($content),  // plain text normalization
            'ts'      => time(),
        ];

        $this->wire('session')->setFor('chatai', 'transcript', $t);
    }

    public function getErrorMessage($number, $val1 = null, $val2 = null) {
        $errorMsg = new stdClass();
        switch ($number) {
            case 1: // blocked/blacklist
                $errorMsg->msg = $this->_('You have been blocked. Goodbye.');
                $errorMsg->warning = true;
                break;

            case 2: // empty input
                $errorMsg->msg = $this->_('No message submitted.');
                break;

            case 4: // limit reached
                $errorMsg->msg = $this->_('Too many questions. Goodbye.');
                $errorMsg->warning = true;
                break;

            case 5: // token budget (optional usage)
                $errorMsg->msg = $this->_('Insufficient OpenAI tokens');
                break;

            case 6: // generic model/transport failure
                $errorMsg->msg = $this->_("Ooops! Something went wrong. Please try again later.");
                $errorMsg->warning = true;
                break;

            case 7: // rephrase
                $errorMsg->msg = $this->_('Please rephrase your question');
                break;

            case 9: // off-topic (unused)
                $errorMsg->msg = $this->_('Not blacklisted but off topic');
                break;

            case 10: // near-limit warning
                $errorMsg->msg = $this->_('You have one question left before I have to go. Make it a good one!');
                $errorMsg->warning = true;
                break;

            case 11: // last question
                $errorMsg->msg = $this->_('This chat has reached its limit. Please start a new chat to continue.');
                break;

            case 12: // unexpected API response structure
                $errorMsg->msg = $this->_('Unexpected API response structure.');
                break; //

            case 13: // lockout due to repeated inappropriate messages
                $errorMsg->msg = $this->_('You have been locked out due to repeated inappropriate messages.');
                $errorMsg->warning = true;
                break;

            case 14: // rephrase with counters
                if(!empty($val1) && !empty($val2)) {
                    $template = $this->_("Please rephrase your question (Warning: %d/%d)");
                    $errorMsg->msg = sprintf($template, $val1, $val2);
                    $errorMsg->warning = true;
                } else {
                    $errorMsg->msg = $this->_("Please rephrase your question.");
                }
                break;

            case 15: // rate limited / busy (translatable)
                $errorMsg->msg = $this->_('We are a bit busy. Please try again shortly.');
                $errorMsg->warning = true;
                break;

            case 20: // too few tokens
                $errorMsg->msg = $this->_('This chat has reached its limit. Please start a new chat to continue.');
                break;

            default:
                $errorMsg->msg = $this->_('Invalid message number: ' . $number);
                break;
        }
        $errorMsg->number = $number;
        return $errorMsg;
    }

    // Database functions

    private function withTransaction(callable $fn, int $retries = 3) {
        /** @var \WireDatabasePDO $db */
        $db = wire('database');
        $attempt = 0;

        while (true) {
            $attempt++;
            try {
                if (!$db->inTransaction()) $db->beginTransaction();
                $result = $fn($db);
                $db->commit();
                return $result;
            } catch (\PDOException $e) {
                if ($db->inTransaction()) $db->rollBack();

                // MySQL deadlock or lock wait timeout
                $sqlState = $e->getCode(); // SQLSTATE, e.g. '40001'
                $msg = $e->getMessage();
                $isRetryable = $sqlState === '40001' || strpos($msg, 'Deadlock found') !== false || strpos($msg, 'Lock wait timeout exceeded') !== false;

                if ($isRetryable && $attempt < $retries) {
                    usleep(random_int(20_000, 120_000)); // small jitter 20-120ms
                    continue;
                }
                throw $e;
            }
        }
    }

    public function insertUserMessage(string $conversationUid, string $content, ?string $pageUrl = null, ?string $idempotencyKey = null): array {
        return $this->withTransaction(function(\WireDatabasePDO $db) use ($conversationUid, $content, $pageUrl, $idempotencyKey) {

            // 1) Lock the conversation row to serialize writers for this conversation
            $stmt = $db->prepare("
            SELECT id, status
            FROM chatai_conversations
            WHERE conversation_uid = ?
            FOR UPDATE
        ");
            $stmt->execute([$conversationUid]);
            $conv = $stmt->fetch(\PDO::FETCH_ASSOC);
            if (!$conv) {
                throw new \RuntimeException("Conversation not found");
            }
            if (in_array($conv['status'], ['blocked','error','closed'], true)) {
                throw new \RuntimeException("Conversation status does not accept new messages: {$conv['status']}");
            }
            $conversationId = (int)$conv['id'];

            // 2) Idempotency check (optional)
            if ($idempotencyKey) {
                $stmt = $db->prepare("
                SELECT seq, created_at
                FROM chatai_messages
                WHERE conversation_id = ? AND idempotency_key = ?
                LIMIT 1
            ");
                $stmt->execute([$conversationId, $idempotencyKey]);
                $existing = $stmt->fetch(\PDO::FETCH_ASSOC);
                if ($existing) {
                    return [
                        'conversation_uid' => $conversationUid,
                        'seq' => (int)$existing['seq'],
                        'created_at' => $existing['created_at'],
                        'idempotent' => true
                    ];
                }
            }

            // 3) Compute next seq inside the same TX
            $stmt = $db->prepare("SELECT COALESCE(MAX(seq), 0) + 1 AS next_seq FROM chatai_messages WHERE conversation_id = ?");
            $stmt->execute([$conversationId]);
            $nextSeq = (int)$stmt->fetchColumn();

            // 4) Insert the user message
            $messageUid = $this->makeUlid(); // implement ULID/UUID generator
            $stmt = $db->prepare("
            INSERT INTO chatai_messages
                (conversation_id, message_uid, seq, role, content, created_at, idempotency_key, page_url)
            VALUES
                (?, ?, ?, 'user', ?, NOW(), ?, ?)
        ");
            $stmt->execute([
                $conversationId, $messageUid, $nextSeq, $content, $idempotencyKey, $pageUrl
            ]);

            // 5) Update conversation counters and last activity
            $stmt = $db->prepare("
            UPDATE chatai_conversations
            SET message_count = message_count + 1,
                user_message_count = user_message_count + 1,
                last_activity_at = NOW()
            WHERE id = ?
        ");
            $stmt->execute([$conversationId]);

            // Return minimal envelope
            return [
                'conversation_uid' => $conversationUid,
                'message_uid' => $messageUid,
                'seq' => $nextSeq
            ];
        });
    }

    public function insertAssistantMessage(
        string $conversationUid,
        string $content,
        int $promptTokens = 0,
        int $completionTokens = 0,
        ?string $finishReason = null,
        ?string $pageUrl = null
    ): array {
        return $this->withTransaction(function(\WireDatabasePDO $db) use ($conversationUid, $content, $promptTokens, $completionTokens, $finishReason, $pageUrl) {

            // 1) Lock conversation
            $stmt = $db->prepare("
            SELECT id FROM chatai_conversations
            WHERE conversation_uid = ?
            FOR UPDATE
        ");
            $stmt->execute([$conversationUid]);
            $conv = $stmt->fetch(\PDO::FETCH_ASSOC);
            if (!$conv) throw new \RuntimeException("Conversation not found");
            $conversationId = (int)$conv['id'];

            // 2) Next seq
            $stmt = $db->prepare("SELECT COALESCE(MAX(seq), 0) + 1 FROM chatai_messages WHERE conversation_id = ?");
            $stmt->execute([$conversationId]);
            $nextSeq = (int)$stmt->fetchColumn();

            // 3) Insert assistant message
            $messageUid = $this->makeUlid();
            $stmt = $db->prepare("
            INSERT INTO chatai_messages
                (conversation_id, message_uid, seq, role, content, prompt_tokens, completion_tokens, finish_reason, created_at, page_url)
            VALUES
                (?, ?, ?, 'assistant', ?, ?, ?, ?, NOW(), ?)
        ");
            $stmt->execute([
                $conversationId, $messageUid, $nextSeq, $content,
                $promptTokens, $completionTokens, $finishReason, $pageUrl
            ]);

            // 4) Update conversation totals
            $stmt = $db->prepare("
            UPDATE chatai_conversations
            SET message_count = message_count + 1,
                assistant_message_count = assistant_message_count + 1,
                input_tokens = input_tokens + ?,
                output_tokens = output_tokens + ?,
                last_activity_at = NOW()
            WHERE id = ?
        ");
            $stmt->execute([$promptTokens, $completionTokens, $conversationId]);

            return [
                'conversation_uid' => $conversationUid,
                'message_uid' => $messageUid,
                'seq' => $nextSeq
            ];
        });
    }

    private function makeUlid(): string {
        // Replace with a real ULID if you prefer; UUIDv4 here is fine as a drop-in
        $data = random_bytes(16);
        $data[6] = chr((ord($data[6]) & 0x0f) | 0x40); // version 4
        $data[8] = chr((ord($data[8]) & 0x3f) | 0x80); // variant
        return vsprintf('%s%s-%s-%s-%s-%s%s%s', str_split(bin2hex($data), 4));
    }

    private function checkForDuplicateMessages() {
        $db = $this->wire('database');
    $sql = <<<SQL
        SELECT conversation_id, seq, COUNT(*) AS c
        FROM chatai_messages
        GROUP BY conversation_id, seq
        HAVING c > 1
        LIMIT 20;
SQL;
        try {
            $db->query($sql);
            // TODO put duplicate messages on the dashboard tab
        } catch(wireException $e) {
            wire('log')->save('errors', "Problem checking for dupicate ChatAI messages. " . $e->getMessage());
        }

    }

    /** Hookable Methods **/

    /** Hook: mutate outbound request before sending to the model. */
    /** @param array $messages */
    public function ___beforeSend(array $messages): array { return $messages; }

    /** Hook: inspect/mutate raw vendor response before normalisation. */
    /** @param array $rawResponse */
    public function ___afterSend(array|object $rawResponse): array|object {
        return $rawResponse; // no-op by default
    }

    /** Hook: last-mile payload tweak before returning JSON to the widget. */
    /** @param array $payload */
    public function ___afterResponse(array $payload): array { return $payload; }



    /* Determine if page eligible for indexing and rag */
    protected function asmToIds($val): array {
        if ($val instanceof \ProcessWire\WireArray) $val = $val->getArray();
        if (!is_array($val)) return [];
        return array_values(array_unique(array_map('intval', $val)));
    }

    public function validTemplate(Page $p, array $cfg): bool {
        if (!$p->id || !$p->isPublic()) return false;
       
        $inclIds = $this->asmToIds($cfg['rag_candidate_templates'] ?? []);
        $exclIds = $this->asmToIds($cfg['rag_exclude_templates'] ?? []);

        $tplId = (int) $p->template->id;
        if (!empty($exclIds) && in_array($tplId, $exclIds)) return false;
        if (!empty($inclIds) && !in_array($tplId, $inclIds)) return false;
        if ($p->hasField('chatai_exclude') && $p->chatai_exclude) return false;
        return true;
    }



    /* Install, Upgrade, Uninstall */

    private static function _createDBTables() {
        $db = wire('database');

        $sql = <<<SQL

    -- Config / prompt JSON (used for \$cfg)
    CREATE TABLE IF NOT EXISTS chatai_prompt (
      id TINYINT UNSIGNED NOT NULL PRIMARY KEY DEFAULT 1,
      json LONGTEXT NOT NULL,
      created DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
      updated DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
    ) ENGINE=InnoDB
      DEFAULT CHARSET=utf8mb4
      COLLATE=utf8mb4_unicode_520_ci;

    -- Obs log: simple event logger for dashboard and stats
    CREATE TABLE IF NOT EXISTS chatai_obslog (
      id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
      created DATETIME NOT NULL,
      chat_id VARCHAR(64) NOT NULL DEFAULT '',
      event_type VARCHAR(32) NOT NULL DEFAULT '',
      status VARCHAR(32) NOT NULL DEFAULT '',
      model VARCHAR(64) NOT NULL DEFAULT '',
      meta MEDIUMTEXT NULL,
      PRIMARY KEY (id),
      KEY ix_created (created),
      KEY ix_chat (chat_id),
      KEY ix_event (event_type)
    ) ENGINE=InnoDB
      DEFAULT CHARSET=utf8mb4
      COLLATE=utf8mb4_unicode_520_ci;

    -- Vectors: RAG chunks (can be regenerated)
    DROP TABLE IF EXISTS chatai_vec_chunks;
    CREATE TABLE chatai_vec_chunks (
      id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
      page_id INT UNSIGNED NOT NULL,
      lang_id VARCHAR(16) NOT NULL DEFAULT '0',
      chunk_index INT UNSIGNED NOT NULL,
      source_url TEXT NULL,
      title VARCHAR(255) NULL,
      headings MEDIUMTEXT NULL,
      slug VARCHAR(255) NULL,
      text MEDIUMTEXT NOT NULL,
      embedding_csv LONGTEXT NOT NULL,
      created_at DATETIME NOT NULL,
      updated_at DATETIME NOT NULL,
      PRIMARY KEY (id),
      KEY ix_page_lang (page_id, lang_id),
      FULLTEXT KEY ft_text (text)
    ) ENGINE=InnoDB
      DEFAULT CHARSET=utf8mb4;

SQL;

        try {
            $db->query($sql);
        } catch(\Throwable $e) {
            wire('log')->save('errors', 'Failed to create ChatAI tables. ' . $e->getMessage());
        }
    }

    private static function _createTemplate() {
        $templates = wire('templates');
        $files = wire('files');
        $config = wire('config');
        $pages = wire('pages');
        $fieldgroups = wire('fieldgroups');
        $modules = wire('modules');

        $apiTpl = $templates->get('name=chatai-api');
        if(!$apiTpl) {

            // Create fieldgroup
            $fieldgroup = new Fieldgroup();
            $fieldgroup->name = 'chatai-api';
            $fieldgroup->add('title');

            // save fieldgroup
            $fieldgroups->save($fieldgroup);

            // get fieldgroup
            $fieldgroup = $fieldgroups->get('chatai-api');

            // Create template
            $template = new Template();
            $template->name = 'chatai-api';
            $template->label =  self::modName . ' API Template';
            $template->fieldgroup = $fieldgroup;
            $template->filename = $config->paths->templates . 'chatai-api.php';
            $template->noChildren = 1;
            $template->noParents = -1; // one page only
            $template->contentType = "json";
            $template->https = 1; // always only https
            $template->noAppendTemplateFile = 1; // disable auto-append of eg _main.php
            $template->noUnpublish = 1; // must always be published

            // save template
            $templates->save($template);
        }

        $templateFileExists = $files->exists($config->paths->templates . 'chatai-api.php');
        if(!$templateFileExists) {
            $files->copy($modules->siteModulesPath . self::modName . '/chatai-api.php', $config->paths->templates . 'chatai-api.php');
        }

        $apiPage = $pages->get("name=chatai-api");
        if($apiPage instanceof NullPage) {
            $apiPage = new Page();
            $apiPage->name = 'chatai-api';
            $apiPage->parent = 1;
            $apiPage->template = 'chatai-api';
            $apiPage->of(false);
            $apiPage->title = self::modName . " API";
            $apiPage->status(['hidden', 'published']);
            $apiPage->save();
        }

        if(!$files->exists($config->paths->templates . 'chatai-rag.php')) {
            $copyFrom = $modules->siteModulesPath . self::modName . '/classes/RAG/chatai-rag.php';
            $copyTo = $config->paths->templates . 'chatai-rag.php';
            $files->copy($copyFrom, $copyTo);
        }

    }

    public function ___install() : void
    {
        self::_createDBTables();
        self::_createTemplate();

        $permissions = $this->wire()->permissions;
        if (!$permissions->get('chatai')) {
            $p = new Permission();
            $p->name = 'chatai';
            $p->title = 'ChatAI administration';
            $permissions->add($p);
        }

    }

    public function ___uninstall()
    {
        $database = wire('database');
        $pages = wire('pages');
        $templates = wire('templates');

        $sql = <<<SQL
        -- Drop the tables in dependency order (children first)
        DROP TABLE IF EXISTS chatai_prompt;
        DROP TABLE IF EXISTS chatai_obslog;
        DROP TABLE IF EXISTS chatai_vec_chunks;
SQL;

        try {
            $database->query($sql);
        } catch (WireException $e) {
            wire('log')->save('error', "Failed to delete ChatAI db tables. " . $e->getMessage());
        }

        $apiPage = $pages->get("name=chatai-api");
        if(!$apiPage instanceof NullPage)
            $pages->delete($apiPage);

        $apiTemplate = $templates->get('name=chatai-api');
        if($apiTemplate)
            $templates->delete($apiTemplate);

        // clear anything in the cache
        $this->wire('cache')->deleteFor('chatai');
    }
}
